---
import '@fontsource-variable/montserrat';
import '@fontsource-variable/syne';
import '@/styles/global.css';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import SEOHead from '@/components/common/SEOHead.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { poleConfigs, type Pole } from '@/lib/pole-config';
import { getSiteSettings } from '@/lib/site-settings';

interface Props {
  title: string;
  description?: string;
  pole?: Pole | null;
  ogImage?: string;
  jsonLd?: string;
  pagePath?: string;
  noindex?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
  ctaIcon?: boolean;
}

const {
  title,
  description = '',
  pole = null,
  ogImage,
  jsonLd,
  pagePath,
  noindex = false,
  ctaLabel,
  ctaHref,
  ctaIcon = false,
} = Astro.props;

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const poleConfig = pole ? poleConfigs[pole] : null;
const bgStyle = poleConfig ? `background-color: ${poleConfig.light};` : '';

const siteSettings = await getSiteSettings();
const sitePhone = siteSettings?.phone ?? '';
const siteEmail = siteSettings?.email ?? '';
const siteGoogleMapsUrl = siteSettings?.googleMapsUrl ?? '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Fonts loaded via @fontsource-variable imports -->
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      jsonLd={jsonLd}
      pagePath={pagePath}
      noindex={noindex}
    />
    {import.meta.env.PLAUSIBLE_DOMAIN && (
      <script defer data-domain={import.meta.env.PLAUSIBLE_DOMAIN} src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body class="min-h-screen flex flex-col" style={bgStyle}>
    <Header pole={pole} ctaLabel={ctaLabel} ctaHref={ctaHref} ctaIcon={ctaIcon} googleMapsUrl={siteGoogleMapsUrl} />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer phone={sitePhone} email={siteEmail} />

    <!-- Scroll-triggered reveal animations — IntersectionObserver + GSAP -->
    <!-- Using IO instead of ScrollTrigger: immune to pin-spacer position shifts
         from client:only Svelte islands (JourneeTypeTimeline) -->
    <script>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const isHidden = (el: Element) =>
          window.getComputedStyle(el).display === 'none';

        const ioOpts: IntersectionObserverInit = {
          rootMargin: '0px 0px -8% 0px',
          threshold: 0,
        };

        // GSAP loaded lazily on first intersection
        let gsapPromise: Promise<{ gsap: typeof import('gsap').gsap }> | null = null;
        function getGsap() {
          if (!gsapPromise) gsapPromise = import('gsap');
          return gsapPromise;
        }

        // ── [data-reveal] ──
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            revealObserver.unobserve(entry.target);
            const el = entry.target as HTMLElement;

            getGsap().then(({ gsap }) => {
              if (el.querySelector('[data-reveal-stagger]')) {
                gsap.set(el, { opacity: 1 });
              } else {
                gsap.fromTo(el,
                  { opacity: 0, y: 28, filter: 'blur(8px)' },
                  { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.95, ease: 'power3.out' }
                );
              }
            });
          });
        }, ioOpts);

        // ── [data-reveal-stagger] ──
        const staggerObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            staggerObserver.unobserve(entry.target);
            const el = entry.target as HTMLElement;
            const children = Array.from(el.children).filter((c) => !isHidden(c));
            if (!children.length) return;

            getGsap().then(({ gsap }) => {
              gsap.fromTo(
                children,
                { opacity: 0, y: 20, filter: 'blur(4px)' },
                { opacity: 1, y: 0, filter: 'blur(0px)', stagger: 0.08, duration: 0.8, ease: 'power3.out' }
              );
            });
          });
        }, ioOpts);

        document.querySelectorAll('[data-reveal]').forEach((el) => {
          if (!isHidden(el)) revealObserver.observe(el);
        });
        document.querySelectorAll('[data-reveal-stagger]').forEach((el) => {
          if (!isHidden(el)) staggerObserver.observe(el);
        });
      }
    </script>
  </body>
</html>
