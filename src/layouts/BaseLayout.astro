---
import '@/styles/global.css';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import SEOHead from '@/components/common/SEOHead.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { poleConfigs, type Pole } from '@/lib/pole-config';

interface Props {
  title: string;
  description?: string;
  pole?: Pole | null;
  ogImage?: string;
  jsonLd?: string;
  pagePath?: string;
}

const {
  title,
  description = '',
  pole = null,
  ogImage,
  jsonLd,
  pagePath,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const poleConfig = pole ? poleConfigs[pole] : null;
const bgStyle = poleConfig ? `background-color: ${poleConfig.light};` : '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      jsonLd={jsonLd}
      pagePath={pagePath}
    />
  </head>
  <body class="min-h-screen flex flex-col" style={bgStyle}>
    <Header pole={pole} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
