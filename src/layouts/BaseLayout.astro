---
import '@/styles/global.css';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';
import SEOHead from '@/components/common/SEOHead.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { poleConfigs, type Pole } from '@/lib/pole-config';

interface Props {
  title: string;
  description?: string;
  pole?: Pole | null;
  ogImage?: string;
  jsonLd?: string;
  pagePath?: string;
  noindex?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
  ctaIcon?: boolean;
}

const {
  title,
  description = '',
  pole = null,
  ogImage,
  jsonLd,
  pagePath,
  noindex = false,
  ctaLabel,
  ctaHref,
  ctaIcon = false,
} = Astro.props;

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const poleConfig = pole ? poleConfigs[pole] : null;
const bgStyle = poleConfig ? `background-color: ${poleConfig.light};` : '';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin />
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      jsonLd={jsonLd}
      pagePath={pagePath}
      noindex={noindex}
    />
    {import.meta.env.PLAUSIBLE_DOMAIN && (
      <script defer data-domain={import.meta.env.PLAUSIBLE_DOMAIN} src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body class="min-h-screen flex flex-col" style={bgStyle}>
    <Header pole={pole} ctaLabel={ctaLabel} ctaHref={ctaHref} ctaIcon={ctaIcon} />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />

    <!-- Scroll-triggered reveal animations -->
    <script is:inline>
      (function() {
        var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        document.querySelectorAll('[data-reveal], [data-reveal-stagger]').forEach(function(el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
