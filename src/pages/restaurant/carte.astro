---
/**
 * LA CARTE — Restaurant menu page
 * Editorial layout: each service period as a full-width section,
 * generous whitespace, elegant typographic hierarchy.
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import MenuSection from '@/components/restaurant/MenuSection.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs } from '@/lib/pole-config';
import { getSiteSettings, toTelHref } from '@/lib/site-settings';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;
const accent = restaurant.accent;

// Load settings + menu data from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const siteSettings = await getSiteSettings();
const phone = siteSettings?.phone ?? '';
const telHref = toTelHref(phone);
const restaurantData = await reader.singletons.restaurant.read();
const menuSections = restaurantData?.menuSections ?? [];
const pageTexts = await reader.singletons.restaurantMenuTexts.read();
const tx = (path: string) => {
  const [section, field] = path.split('.');
  return getLocalizedField(
    ((pageTexts as Record<string, unknown> | null)?.[section] as Record<string, unknown>) ?? {},
    field,
    lang,
  );
};

// Group sections by period
const midiSections = menuSections.filter((s) => s.group === 'midi');
const soirSections = menuSections.filter((s) => s.group === 'soir');
const dessertsSections = menuSections.filter((s) => s.group === 'desserts');
const enfantSections = menuSections.filter((s) => s.group === 'enfant');

// Helper to localize dishes
function localizeDishes(dishes: typeof menuSections[0]['dishes']) {
  return dishes.map((dish) => ({
    name: getLocalizedField(dish, 'name', lang),
    description: getLocalizedField(dish, 'description', lang) || undefined,
    price: dish.price || undefined,
    tags: dish.tags ?? [],
  }));
}

const seoTitle = `${tx('hero.title')} — ${t('nav.restaurant')} | La Terrasse Saint-Ferréol`;
const seoDescription = tx('hero.subtitle');

// Menu period labels — via translations.ts
const periodLabels = {
  midi: t('restaurant.menu.period.midi'),
  midiSub: t('restaurant.menu.period.midiSub'),
  soir: t('restaurant.menu.period.soir'),
  soirSub: t('restaurant.menu.period.soirSub'),
  desserts: t('restaurant.menu.period.desserts'),
  enfant: t('restaurant.menu.period.enfant'),
};
function label(key: keyof typeof periodLabels) {
  return periodLabels[key];
}
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
  pagePath="/restaurant/carte"
>
  <!-- Hero -->
  <SectionHero
    tagline={tx('hero.title')}
    subtitle={tx('hero.subtitle')}
    pole="restaurant"
    image="/images/heroes/carte.webp"
    breadcrumb={{ parentLabel: t('nav.restaurant'), parentHref: getLocalizedPath('/restaurant', lang), currentLabel: t('restaurant.menu.breadcrumb') }}
  />

  {menuSections.length > 0 ? (
    <>
      <!-- Navigation rapide -->
      <nav class="sticky top-16 z-30 border-b" style={`background: rgba(255,251,245,0.95); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border-color: ${accent}15`} data-menu-nav data-accent={accent}>
        <div class="max-w-5xl mx-auto px-4 sm:px-6">
          <div class="flex items-center justify-center gap-6 sm:gap-10 py-3">
            {midiSections.length > 0 && (
              <a href="#midi" class="menu-nav-link font-heading text-xs sm:text-sm font-bold uppercase tracking-[0.15em] transition-colors" style={`color: ${accent}70`} data-nav-target="midi">
                {label('midi')}
              </a>
            )}
            {soirSections.length > 0 && (
              <a href="#soir" class="menu-nav-link font-heading text-xs sm:text-sm font-bold uppercase tracking-[0.15em] transition-colors" style={`color: ${accent}70`} data-nav-target="soir">
                {label('soir')}
              </a>
            )}
            {dessertsSections.length > 0 && (
              <a href="#desserts" class="menu-nav-link font-heading text-xs sm:text-sm font-bold uppercase tracking-[0.15em] transition-colors" style={`color: ${accent}70`} data-nav-target="desserts">
                {label('desserts')}
              </a>
            )}
            {enfantSections.length > 0 && (
              <a href="#enfant" class="menu-nav-link font-heading text-xs sm:text-sm font-bold uppercase tracking-[0.15em] transition-colors" style={`color: ${accent}70`} data-nav-target="enfant">
                {label('enfant')}
              </a>
            )}
          </div>
        </div>
      </nav>

      {/* ═══════════════════════════════════════════
          MIDI
          ═══════════════════════════════════════════ */}
      {midiSections.length > 0 && (
        <section id="midi" class="py-16 lg:py-24 scroll-mt-20">
          <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            {/* Period header */}
            <div class="text-center mb-14" data-reveal>
              <p class="section-eyebrow mb-3" style={`color: ${accent}80`}>
                {label('midiSub')}
              </p>
              <h2
                class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight"
                style={`color: ${accent}`}
              >
                {label('midi')}
              </h2>
              <div class="flex items-center justify-center gap-3 mt-5">
                <span class="w-10 h-px" style={`background: ${accent}30`}></span>
                <Icon name="lucide:utensils" class="w-4 h-4" style={`color: ${accent}40`} />
                <span class="w-10 h-px" style={`background: ${accent}30`}></span>
              </div>
            </div>

            {/* Menu categories */}
            <div class="space-y-0">
              {midiSections.map((section) => (
                <MenuSection
                  title={getLocalizedField(section, 'title', lang)}
                  dishes={localizeDishes(section.dishes)}
                  accent={accent}
                />
              ))}
            </div>
          </div>
        </section>
      )}

      {/* ═══════════════════════════════════════════
          LE SOIR
          ═══════════════════════════════════════════ */}
      {soirSections.length > 0 && (
        <section id="soir" class="py-16 lg:py-24 scroll-mt-20" style="background: #FFFBF5">
          <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            {/* Period header */}
            <div class="text-center mb-14" data-reveal>
              <p class="section-eyebrow mb-3" style={`color: ${accent}80`}>
                {label('soirSub')}
              </p>
              <h2
                class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight"
                style={`color: ${accent}`}
              >
                {label('soir')}
              </h2>
              <div class="flex items-center justify-center gap-3 mt-5">
                <span class="w-10 h-px" style={`background: ${accent}30`}></span>
                <Icon name="lucide:wine" class="w-4 h-4" style={`color: ${accent}40`} />
                <span class="w-10 h-px" style={`background: ${accent}30`}></span>
              </div>
            </div>

            {/* Menu categories */}
            <div class="space-y-0">
              {soirSections.map((section) => (
                <MenuSection
                  title={getLocalizedField(section, 'title', lang)}
                  dishes={localizeDishes(section.dishes)}
                  accent={accent}
                  hideTitle={soirSections.length === 1}
                />
              ))}
            </div>
          </div>
        </section>
      )}

      {/* ═══════════════════════════════════════════
          DESSERTS
          ═══════════════════════════════════════════ */}
      {dessertsSections.length > 0 && (
        <section id="desserts" class="py-16 lg:py-24 scroll-mt-20">
          <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            {/* Period header */}
            <div class="text-center mb-14" data-reveal>
              <h2
                class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight"
                style={`color: ${accent}`}
              >
                {label('desserts')}
              </h2>
              <div class="flex items-center justify-center gap-3 mt-5">
                <span class="w-10 h-px" style={`background: ${accent}30`}></span>
                <Icon name="lucide:cake-slice" class="w-4 h-4" style={`color: ${accent}40`} />
                <span class="w-10 h-px" style={`background: ${accent}30`}></span>
              </div>
            </div>

            <div class="space-y-0">
              {dessertsSections.map((section) => (
                <MenuSection
                  title={getLocalizedField(section, 'title', lang)}
                  dishes={localizeDishes(section.dishes)}
                  accent={accent}
                  hideTitle={dessertsSections.length === 1}
                />
              ))}
            </div>
          </div>
        </section>
      )}

      {/* ═══════════════════════════════════════════
          MENU ENFANT — Playful card with icons
          ═══════════════════════════════════════════ */}
      {enfantSections.length > 0 && (
        <section id="enfant" class="py-16 lg:py-24 scroll-mt-20" style="background: #FFFBF5">
          <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
            {enfantSections.map((section) => {
              const dishes = localizeDishes(section.dishes);
              const price = dishes.find(d => d.price)?.price;
              const formattedPrice = (() => {
                if (!price) return '';
                const num = parseFloat(price);
                if (isNaN(num)) return price;
                return num.toFixed(2).replace('.', ',') + ' \u20AC';
              })();
              /* Map each dish to an icon — order: sirop, plat, glace, cadeau */
              const dishIcons = ['lucide:cup-soda', 'lucide:utensils', 'lucide:ice-cream-cone', 'lucide:gift'];
              return (
                <div
                  class="relative rounded-3xl overflow-hidden grain-overlay"
                  style={`background-color: ${accent}`}
                  data-reveal
                >
                  {/* Decorative glow */}
                  <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle at 30% 20%, rgba(255,255,255,0.5) 0%, transparent 50%), radial-gradient(circle at 80% 80%, rgba(255,255,255,0.3) 0%, transparent 50%);"></div>

                  <div class="relative py-10 px-8 sm:px-10">
                    {/* Header — Icon + Title + Price */}
                    <div class="text-center mb-8">
                      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/15 mb-4">
                        <Icon name="lucide:baby" class="w-6 h-6 text-white" />
                      </div>
                      <h2 class="font-heading text-2xl sm:text-3xl font-bold text-white">
                        {label('enfant')}
                      </h2>
                      {formattedPrice && (
                        <p class="font-heading font-bold text-lg mt-1.5 text-white/60">
                          {formattedPrice}
                        </p>
                      )}
                    </div>

                    {/* Separator */}
                    <div class="flex items-center justify-center gap-3 mb-8">
                      <span class="w-12 h-px bg-white/15"></span>
                    </div>

                    {/* Items grid — 2×2 with icons */}
                    <div class="grid grid-cols-2 gap-3">
                      {dishes.map((dish, i) => (
                        <div class="enfant-item flex flex-col items-center gap-2.5 py-4 px-3 rounded-2xl bg-white/10 backdrop-blur-xs text-center">
                          <div class="flex items-center justify-center w-9 h-9 rounded-full bg-white/15">
                            <Icon name={dishIcons[i] || 'lucide:circle'} class="w-4.5 h-4.5 text-white" />
                          </div>
                          <span class="text-sm font-medium text-white leading-snug">
                            {dish.name}
                          </span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}
    </>
  ) : (
    <section class="py-16 lg:py-24">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gray-50 rounded-2xl p-12 text-center">
          <p class="text-gray-400">{t('restaurant.menu.empty')}</p>
        </div>
      </div>
    </section>
  )}

  <!-- CTA — Réserver votre table -->
  <section class="relative py-(--spacing-section-mobile) lg:py-(--spacing-section) text-white grain-overlay overflow-hidden" style={`background-color: ${accent}`}>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.15) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow text-white/40 mb-3">{tx('cta.eyebrow')}</p>
      <h2 class="font-heading text-3xl font-bold mb-6">
        {tx('cta.title')}
      </h2>
      <p class="text-white/70 text-lg mb-8">
        {tx('cta.subtitle')}
      </p>
      <a
        href={telHref}
        class="inline-flex items-center gap-3 text-white text-2xl lg:text-3xl font-bold mb-8 hover:text-white/90 transition-colors"
      >
        <Icon name="lucide:phone" class="w-8 h-8" />
        {phone}
      </a>
      <div class="block">
        <a
          href={telHref}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-heading font-semibold text-sm transition-all hover:shadow-lg hover:-translate-y-px"
          style={`background-color: white; color: ${accent}`}
        >
          {t('restaurant.cta.label')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={t('crosslink.carte.aventure')}
    href={getLocalizedPath('/aventure', lang)}
    pole="aventure"
  />

  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>

<style>
  .menu-nav-link {
    position: relative;
    padding-bottom: 0.375rem;
  }

  .menu-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    border-radius: 1px;
    background: currentColor;
    transform: scaleX(0);
    transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .menu-nav-link.active::after {
    transform: scaleX(1);
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('[data-menu-nav]');
  if (nav) {
    const accent = nav.dataset.accent!;
    const links = nav.querySelectorAll<HTMLAnchorElement>('[data-nav-target]');
    const sectionIds = Array.from(links).map((l) => l.dataset.navTarget!);
    const sections = sectionIds
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    function setActive(id: string) {
      links.forEach((link) => {
        const isActive = link.dataset.navTarget === id;
        link.classList.toggle('active', isActive);
        link.style.color = isActive ? accent : `${accent}70`;
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        }
      },
      { rootMargin: '-20% 0px -60% 0px' }
    );

    sections.forEach((s) => observer.observe(s));
  }
</script>
