---
/**
 * LA CARTE — Restaurant menu page
 * Brun terre identity, Keystatic-powered menu sections
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import MenuSection from '@/components/restaurant/MenuSection.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs, PHONE_NUMBER } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;

// Load menu data from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const restaurantData = await reader.singletons.restaurant.read();
const menuSections = restaurantData?.menuSections ?? [];

const seoTitle = 'La Carte — Restaurant | La Terrasse Saint-Ferréol';
const seoDescription = 'Découvrez la carte du restaurant La Terrasse : entrées, plats, desserts et boissons. Cuisine locale et de saison au lac de Saint-Ferréol.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
>
  <!-- Hero — Brun terre with food image -->
  <SectionHero
    tagline={t('restaurant.menu.heroTitle')}
    subtitle={t('restaurant.menu.heroSubtitle')}
    pole="restaurant"
    image="/images/placeholders/emma-harper.webp"
    class="min-h-[40vh] lg:min-h-[50vh] flex items-end"
  />

  <!-- Breadcrumb + Menu content -->
  <section class="py-12 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a
              href={getLocalizedPath('/restaurant', lang)}
              class="font-medium uppercase tracking-wider hover:underline"
              style={`color: ${restaurant.accent}; font-variant: small-caps`}
            >
              Restaurant
            </a>
          </li>
          <li class="text-gray-400" aria-hidden="true">/</li>
          <li class="text-gray-500">{t('restaurant.menu.breadcrumb')}</li>
        </ol>
      </nav>

      <!-- Menu sections -->
      {menuSections.length > 0 ? (
        menuSections.map((section) => {
          const sectionTitle = getLocalizedField(section, 'title', lang);
          const localizedDishes = section.dishes.map((dish) => ({
            name: getLocalizedField(dish, 'name', lang),
            description: getLocalizedField(dish, 'description', lang) || undefined,
            price: dish.price ?? '0',
            tags: dish.tags ?? [],
          }));
          return (
            <MenuSection
              title={sectionTitle}
              dishes={localizedDishes}
              accent={restaurant.accent}
            />
          );
        })
      ) : (
        <div class="bg-gray-50 rounded-2xl p-12 text-center">
          <p class="text-gray-400">{t('restaurant.menu.empty')}</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA — Réserver votre table -->
  <section class="py-12 lg:py-24" style={`background-color: ${restaurant.accent}`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-6">
        {t('restaurant.menu.ctaTitle')}
      </h2>
      <p class="text-white/80 text-lg mb-8">
        {t('restaurant.menu.ctaSubtitle')}
      </p>
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center gap-3 text-white text-2xl lg:text-3xl font-bold mb-8 hover:text-white/90 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {PHONE_NUMBER.replace('+33', '0 ').replace(/(\d{1})(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5')}
      </a>
      <div class="block">
        <a
          href={restaurant.ctaHref}
          class="inline-block px-8 py-4 rounded-lg font-medium text-lg transition-colors hover:bg-gray-100"
          style={`background-color: white; color: ${restaurant.accent}`}
        >
          {restaurant.ctaLabel}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-sell contextuel -->
  <section class="py-12 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-gray-500 italic">
        {t('restaurant.menu.crossSell')}
      </p>
      <a
        href={getLocalizedPath('/aventure', lang)}
        class="inline-block mt-4 font-medium hover:underline"
        style={`color: ${poleConfigs.aventure.accent}`}
      >
        {t('restaurant.menu.crossSellLink')}
      </a>
    </div>
  </section>

  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>
