---
/**
 * RESTAURANT HUB — Brun terre
 * Tone: sensoriel, chaleureux, contemplatif
 * Hero: le moment vécu, pas le menu
 * Entonnoir émotionnel: atmosphère → offre → détails → CTA
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import SoireesSection from '@/components/homepage/SoireesSection.astro';
import OffreJournee from '@/components/common/OffreJournee.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs } from '@/lib/pole-config';
import { getSiteSettings, toTelHref } from '@/lib/site-settings';
import { generateRestaurantLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;
const siteSettings = await getSiteSettings();
const phone = siteSettings?.phone ?? '';
const telHref = toTelHref(phone);
const jsonLd = generateRestaurantLD();

// CMS texts for this page
const reader = createReader(process.cwd(), keystaticConfig);
const pageTexts = await reader.singletons.restaurantHub.read();
const tx = (path: string) => {
  const [section, field] = path.split('.');
  return getLocalizedField(
    ((pageTexts as Record<string, unknown> | null)?.[section] as Record<string, unknown>) ?? {},
    field,
    lang,
  );
};

const seoTitle = 'Restaurant en terrasse au lac de Saint-Ferréol, près de Toulouse';
const seoDescription = 'Restaurant en terrasse au bord du lac de Saint-Ferréol, à 45 min de Toulouse. Tapas, burgers, salades — produits locaux du Tarn, ambiance guinguette. Concerts et soirées.';

const subPages = [
  {
    title: t('restaurant.subpage.carte.title'),
    href: '/restaurant/carte',
    description: tx('subpage.carteDesc'),
    icon: 'lucide:book-open',
  },
  {
    title: t('restaurant.subpage.producteurs.title'),
    href: '/restaurant/producteurs',
    description: tx('subpage.producteursDesc'),
    icon: 'lucide:leaf',
  },
];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
  jsonLd={jsonLd}
  pagePath="/restaurant"
  ctaHref={telHref}
  ctaIcon={true}
>
  <!-- Hero — Atmosphère, le moment vécu -->
  <SectionHero
    tagline={tx('hero.tagline')}
    subtitle={tx('hero.subtitle')}
    pole="restaurant"
    image="/images/heroes/restaurant.webp"
  >
    <div class="flex flex-wrap gap-4">
      <a
        href={getLocalizedPath('/restaurant/carte', lang)}
        class="inline-flex items-center gap-2 bg-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all"
        style={`color: ${restaurant.accent}`}
      >
        {t('restaurant.hub.viewMenu')}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a
        href={getLocalizedPath('/contact', lang)}
        class="inline-flex items-center gap-2 border border-white/30 text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all"
      >
        {t('common.reserve')}
      </a>
    </div>
  </SectionHero>

  <!-- Sous-pages — Navigation vers les détails (core offering) -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-3xl mx-auto" data-reveal-stagger>
        {subPages.map((page) => (
          <a
            href={getLocalizedPath(page.href, lang)}
            class="group block bg-white p-8 rounded-2xl border border-gray-200/60 card-hover"
          >
            <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style={`background-color: ${restaurant.accent}0a;`}>
              <Icon name={page.icon} class="w-5 h-5" style={`color: ${restaurant.accent};`} />
            </div>
            <h3 class="font-heading text-xl font-bold mb-2 text-gray-900">
              {page.title}
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed">{page.description}</p>
            <span class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold group-hover:gap-2.5 transition-all" style={`color: ${restaurant.accent};`}>
              {t('common.discover')}
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Atmosphère — Section sensorielle (why us) -->
  <section class="py-16 lg:py-28" style={`background-color: ${restaurant.light}`}>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow mb-6" style={`color: ${restaurant.accent}50`}>{tx('moment.eyebrow')}</p>
      <h2 class="font-heading text-3xl lg:text-4xl font-bold mb-8 text-gray-900">
        {tx('moment.title')}
      </h2>
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed">
        {tx('moment.body')}
      </p>
    </div>
  </section>

  <!-- Offre Journée (deal/conversion) -->
  <OffreJournee lang={lang} />

  <!-- Soirées en terrasse (events) -->
  <SoireesSection lang={lang} hideRestaurantCta />

  <!-- CTA — Réserver votre table -->
  <section class="relative py-(--spacing-section-mobile) lg:py-(--spacing-section) grain-overlay overflow-hidden" style={`background-color: ${restaurant.accent}`}>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 40% 50%, rgba(255,255,255,0.15) 0%, transparent 60%);"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10" data-reveal>
      <p class="section-eyebrow text-white/30 mb-6">{tx('reserve.eyebrow')}</p>
      <h2 class="font-heading text-3xl lg:text-4xl font-bold text-white mb-6">
        {tx('reserve.title')}
      </h2>
      <p class="text-white/50 text-lg mb-10">
        {tx('reserve.subtitle')}
      </p>
      <a
        href={telHref}
        class="inline-flex items-center gap-3 text-white text-2xl lg:text-3xl font-bold mb-10 hover:text-white/80 transition-colors"
      >
        <Icon name="lucide:phone" class="w-7 h-7" />
        {phone}
      </a>
      <div class="block">
        <a
          href={telHref}
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-heading font-semibold text-base transition-all hover:shadow-lg hover:-translate-y-px"
          style={`background-color: white; color: ${restaurant.accent}`}
        >
          {t('restaurant.cta.label')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Le cadre — SEO prose section -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow mb-4" style={`color: ${restaurant.accent}50`}>{tx('location.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-6 text-gray-900">
        {tx('location.title')}
      </h2>
      <p class="text-gray-600 leading-relaxed text-base lg:text-lg">
        {tx('location.body')}
      </p>
    </div>
  </section>

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={t('crosslink.restaurantHub.aventure')}
    href={getLocalizedPath('/aventure', lang)}
    pole="aventure"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>
