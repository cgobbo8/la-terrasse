---
/**
 * RESTAURANT HUB — Brun terre
 * Tone: sensoriel, chaleureux, contemplatif
 * Hero: le moment vécu, pas le menu
 * Entonnoir émotionnel: atmosphère → offre → détails → CTA
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { poleConfigs, PHONE_NUMBER } from '@/lib/pole-config';
import { generateRestaurantLD } from '@/lib/seo';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;
const jsonLd = generateRestaurantLD();

const seoTitle = 'Restaurant au lac de Saint-Ferréol — La Terrasse';
const seoDescription = 'Restaurant avec terrasse et vue sur le lac de Saint-Ferréol. Cuisine locale et de saison, producteurs du terroir, repas de groupe. Réservez votre table.';

const subPages = [
  {
    title: 'La Carte',
    href: '/restaurant/carte',
    description: 'Découvrez nos plats et nos vins',
  },
  {
    title: 'Nos Producteurs',
    href: '/restaurant/producteurs',
    description: 'Les artisans derrière nos assiettes',
  },
  {
    title: 'Repas de Groupe',
    href: '/restaurant/repas-groupe',
    description: 'Privatisez notre terrasse dès 10 personnes',
  },
];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
  jsonLd={jsonLd}
>
  <!-- Hero — Atmosphère, le moment vécu -->
  <SectionHero
    tagline={t('restaurant.hero.tagline')}
    subtitle={t('restaurant.hero.subtitle')}
    pole="restaurant"
    image="/images/placeholders/emma-harper.webp"
    class="min-h-[50vh] lg:min-h-[70vh] flex items-end"
  >
    <div class="flex flex-wrap gap-4">
      <a
        href={getLocalizedPath('/restaurant/carte', lang)}
        class="bg-white px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors"
        style={`color: ${restaurant.accent}`}
      >
        Voir la carte
      </a>
      <a
        href={getLocalizedPath('/contact', lang)}
        class="border border-white/30 text-white px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors"
      >
        {t('common.reserve')}
      </a>
    </div>
  </SectionHero>

  <!-- Atmosphère — Section sensorielle -->
  <section class="py-12 lg:py-24" style={`background-color: ${restaurant.light}`}>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-bold mb-6" style={`color: ${restaurant.accent}`}>
        Un moment à partager
      </h2>
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed">
        À quelques pas du lac, la terrasse s'ouvre sur l'eau et la nature.
        Ici, on prend le temps de déjeuner au soleil, de savourer des produits
        du terroir, de dîner entre amis au coucher du soleil. Chaque repas est
        une invitation à prolonger le moment — par une balade au bord de l'eau
        ou simplement en contemplant le reflet des arbres sur le lac.
      </p>
    </div>
  </section>

  <!-- Sous-pages — Navigation vers les détails -->
  <section class="py-12 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {subPages.map((page) => (
          <a
            href={getLocalizedPath(page.href, lang)}
            class="block bg-white p-8 rounded-2xl border transition-all duration-200 hover:shadow-lg hover:-translate-y-1"
            style={`border-color: ${restaurant.accent}20`}
          >
            <h3 class="font-heading text-xl font-bold mb-2" style={`color: ${restaurant.accent}`}>
              {page.title}
            </h3>
            <p class="text-gray-600 text-sm">{page.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA — Réserver votre table -->
  <section class="py-12 lg:py-24" style={`background-color: ${restaurant.accent}`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-bold text-white mb-6">
        Réservez votre table
      </h2>
      <p class="text-white/80 text-lg mb-8">
        Appelez-nous pour réserver ou venez directement profiter de la terrasse.
      </p>
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center gap-3 text-white text-2xl lg:text-3xl font-bold mb-8 hover:text-white/90 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {PHONE_NUMBER.replace('+33', '0 ').replace(/(\d{1})(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5')}
      </a>
      <div class="block">
        <a
          href={restaurant.ctaHref}
          class="inline-block px-8 py-4 rounded-lg font-medium text-lg transition-colors hover:bg-gray-100"
          style={`background-color: white; color: ${restaurant.accent}`}
        >
          {restaurant.ctaLabel}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={t('crosslink.restaurantHub.aventure')}
    href={getLocalizedPath('/aventure', lang)}
    pole="aventure"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>
