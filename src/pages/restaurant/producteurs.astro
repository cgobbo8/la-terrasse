---
/**
 * NOS PRODUCTEURS — Local producers storytelling page
 * Brun terre identity, Keystatic-powered producer grid
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import ProducerCard from '@/components/restaurant/ProducerCard.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs } from '@/lib/pole-config';
import { getSiteSettings, toTelHref } from '@/lib/site-settings';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;
const siteSettings = await getSiteSettings();
const telHref = toTelHref(siteSettings?.phone ?? '');

// Load page content from Keystatic (texts + producers list inline)
const reader = createReader(process.cwd(), keystaticConfig);
const pageTexts = await reader.singletons.restaurantProducteurs.read();
const tx = (path: string) => {
  const [section, field] = path.split('.');
  return getLocalizedField(
    ((pageTexts as Record<string, unknown> | null)?.[section] as Record<string, unknown>) ?? {},
    field,
    lang,
  );
};
const introText = getLocalizedField(
  (pageTexts as Record<string, unknown> | null) ?? {},
  'intro',
  lang,
);
const producers = (pageTexts?.producers ?? []).filter((p) => p.visible);

const seoTitle = 'Nos Producteurs — Restaurant | La Terrasse Saint-Ferréol';
const seoDescription = 'Découvrez les producteurs locaux qui fournissent le restaurant La Terrasse : miel, fromages, vins de Gaillac, légumes bio. Circuits courts et terroir.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
  pagePath="/restaurant/producteurs"
>
  <!-- Hero — Terroir / farm-to-table feel -->
  <SectionHero
    tagline={t('restaurant.producers.title')}
    subtitle={tx('hero.subtitle')}
    pole="restaurant"
    image="/images/heroes/producteurs.webp"
    breadcrumb={{ parentLabel: t('nav.restaurant'), parentHref: getLocalizedPath('/restaurant', lang), currentLabel: t('restaurant.producers.breadcrumb') }}
  />

  <!-- Intro -->
  <section class="pt-12 lg:pt-24 pb-8 lg:pb-12">
    <div class="max-w-[768px] mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed text-center">
        {introText}
      </p>
    </div>
  </section>

  <!-- Producer grid -->
  <section class="pb-12 lg:pb-24 pt-4 lg:pt-8">
    <div class="max-w-[1080px] mx-auto px-4 sm:px-6 lg:px-8">
      {producers.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {producers.map((producer) => (
            <ProducerCard
              name={producer.name}
              photo={producer.photo ?? '/images/placeholders/daniel-jacob.webp'}
              product={getLocalizedField(producer, 'product', lang)}
              story={getLocalizedField(producer, 'story', lang)}
              location={producer.location}
              distance={producer.distance}
              website={producer.website}
            />
          ))}
        </div>
      ) : (
        <div class="bg-gray-50 rounded-2xl p-12 text-center">
          <p class="text-gray-400">Fiches producteurs à venir — géré via Keystatic CMS</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA — Subtle, storytelling-appropriate -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)" style={`background-color: ${restaurant.light}`}>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow mb-3" style={`color: ${restaurant.accent}80`}>{tx('cta.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-4 text-gray-900">
        {tx('cta.title')}
      </h2>
      <p class="text-gray-600 text-lg mb-8">
        {tx('cta.subtitle')}
      </p>
      <a
        href={telHref}
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-heading font-semibold text-sm text-white transition-all hover:shadow-lg hover:-translate-y-px"
        style={`background-color: ${restaurant.accent}`}
      >
        {t('restaurant.cta.label')}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>
