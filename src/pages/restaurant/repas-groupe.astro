---
/**
 * REPAS DE GROUPE — Group dining page
 * Brun terre identity, phone-first CTA for persona "Karine"
 * Emotional funnel: hero → intro → formulas → practical → CTA
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import GroupFormulaCard from '@/components/restaurant/GroupFormulaCard.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs, PHONE_NUMBER, EMAIL_ADDRESS } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;

// Load group dining data from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const restaurantData = await reader.singletons.restaurant.read();
const groupFormulas = restaurantData?.groupFormulas ?? [];
const groupIntro = restaurantData ? getLocalizedField(restaurantData, 'groupDiningIntro', lang) : '';
const seoTitle = 'Repas de Groupe — Restaurant | La Terrasse Saint-Ferréol';
const seoDescription = 'Organisez votre repas de groupe au restaurant La Terrasse : formules dès 25€/pers, terrasse privatisable face au lac de Saint-Ferréol. Anniversaires, séminaires, événements.';

const formattedPhone = PHONE_NUMBER.replace('+33', '0 ').replace(/(\d{1})(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5');

// Pre-compute localized formula data to avoid complex expressions in template
const localizedFormulas = groupFormulas.map((formula) => {
  const formulaName = getLocalizedField(formula, 'name', lang);
  const inclusionsKey = lang === 'fr' ? 'inclusions' : `inclusions_${lang}`;
  const localizedInclusions = (formula as Record<string, unknown>)[inclusionsKey] as string[] | undefined;
  const inclusions = (localizedInclusions && localizedInclusions.length > 0) ? localizedInclusions : (formula.inclusions ?? []);
  return {
    name: formulaName,
    pricePerPerson: formula.pricePerPerson,
    minGroupSize: formula.minGroupSize,
    inclusions,
    recommended: formula.recommended ?? false,
  };
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
>
  <!-- Hero — Group dining atmosphere -->
  <SectionHero
    tagline={t('restaurant.groups.heroTitle')}
    subtitle={t('restaurant.groups.heroSubtitle')}
    pole="restaurant"
    image="/images/placeholders/emma-harper.webp"
    class="min-h-[40vh] lg:min-h-[50vh] flex items-end"
  />

  <!-- Breadcrumb + Intro -->
  <section class="py-12 lg:py-24">
    <div class="max-w-[768px] mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a
              href={getLocalizedPath('/restaurant', lang)}
              class="font-medium uppercase tracking-wider hover:underline"
              style={`color: ${restaurant.accent}; font-variant: small-caps`}
            >
              Restaurant
            </a>
          </li>
          <li class="text-gray-400" aria-hidden="true">/</li>
          <li class="text-gray-500">{t('restaurant.groups.breadcrumb')}</li>
        </ol>
      </nav>

      <!-- Intro text -->
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed text-center">
        {groupIntro}
      </p>
    </div>
  </section>

  <!-- Formula cards -->
  <section class="py-12 lg:py-24" style={`background-color: ${restaurant.light}`}>
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-center mb-12" style={`color: ${restaurant.accent}`}>
        {t('restaurant.groups.formulasTitle')}
      </h2>

      {localizedFormulas.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {localizedFormulas.map((formula) => (
            <GroupFormulaCard
              name={formula.name}
              pricePerPerson={formula.pricePerPerson}
              minGroupSize={formula.minGroupSize}
              inclusions={formula.inclusions}
              recommended={formula.recommended}
              perPersonLabel={t('restaurant.groups.perPerson')}
              minSizeLabel={t('restaurant.groups.minSize')}
              recommendedLabel={t('restaurant.groups.recommended')}
              accent={restaurant.accent}
            />
          ))}
        </div>
      ) : (
        <div class="bg-white rounded-2xl p-12 text-center">
          <p class="text-gray-400">Formules groupe à venir — géré via Keystatic CMS</p>
        </div>
      )}
    </div>
  </section>

  <!-- Practical info -->
  <section class="py-12 lg:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl lg:text-3xl font-bold text-center mb-8" style={`color: ${restaurant.accent}`}>
        {t('restaurant.groups.practicalTitle')}
      </h2>
      <p class="text-center text-gray-500 mb-10">
        {t('restaurant.groups.practicalSubtitle')}
      </p>

      <ul class="space-y-4">
        {[
          t('restaurant.groups.practical1'),
          t('restaurant.groups.practical2'),
          t('restaurant.groups.practical3'),
          t('restaurant.groups.practical4'),
        ].map((item) => (
          <li class="flex items-start gap-3 text-gray-600">
            <span class="mt-1 shrink-0 text-sm" style={`color: ${restaurant.accent}`}>&#x2022;</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Contact CTA — Phone-first for persona Karine -->
  <section class="py-16 lg:py-24" style={`background-color: ${restaurant.accent}`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl lg:text-4xl font-bold text-white mb-6">
        {t('restaurant.groups.ctaTitle')}
      </h2>
      <p class="text-white/80 text-lg mb-10">
        {t('restaurant.groups.ctaReassurance')}
      </p>

      <!-- Phone — Primary CTA, very prominent -->
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center gap-3 text-white text-2xl lg:text-[32px] font-bold mb-8 hover:text-white/90 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 lg:w-10 lg:h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {formattedPhone}
      </a>

      <!-- Email — Secondary -->
      <div class="block">
        <a
          href={`mailto:${EMAIL_ADDRESS}?subject=Repas%20de%20groupe`}
          class="inline-flex items-center gap-2 text-white/70 text-base hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          {EMAIL_ADDRESS}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-sell contextuel -->
  <section class="py-12 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-gray-500 italic">
        {t('restaurant.groups.crossSell')}
      </p>
      <a
        href={getLocalizedPath('/aventure', lang)}
        class="inline-block mt-4 font-medium hover:underline"
        style={`color: ${poleConfigs.aventure.accent}`}
      >
        {t('restaurant.groups.crossSellLink')}
      </a>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>
