---
/**
 * REPAS DE GROUPE — Group dining page
 * Brun terre identity, phone-first CTA for persona "Karine"
 * Emotional funnel: hero → intro → formulas → practical → CTA
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import GroupFormulaCard from '@/components/restaurant/GroupFormulaCard.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs, PHONE_NUMBER, EMAIL_ADDRESS } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const restaurant = poleConfigs.restaurant;

// Load group dining data from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const restaurantData = await reader.singletons.restaurant.read();
const groupFormulas = restaurantData?.groupFormulas ?? [];
const groupIntro = restaurantData ? getLocalizedField(restaurantData, 'groupDiningIntro', lang) : '';
const seoTitle = 'Repas de Groupe — Restaurant | La Terrasse Saint-Ferréol';
const seoDescription = 'Organisez votre repas de groupe au restaurant La Terrasse : formules dès 25€/pers, terrasse privatisable face au lac de Saint-Ferréol. Anniversaires, séminaires, événements.';

const formattedPhone = PHONE_NUMBER.replace('+33', '0 ').replace(/(\d{1})(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5');

// Pre-compute localized formula data to avoid complex expressions in template
const localizedFormulas = groupFormulas.map((formula) => {
  const formulaName = getLocalizedField(formula, 'name', lang);
  const inclusionsKey = lang === 'fr' ? 'inclusions' : `inclusions_${lang}`;
  const localizedInclusions = (formula as Record<string, unknown>)[inclusionsKey] as string[] | undefined;
  const inclusions = (localizedInclusions && localizedInclusions.length > 0) ? localizedInclusions : (formula.inclusions ?? []);
  return {
    name: formulaName,
    pricePerPerson: formula.pricePerPerson,
    minGroupSize: formula.minGroupSize,
    inclusions,
    recommended: formula.recommended ?? false,
  };
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="restaurant"
  pagePath="/restaurant/repas-groupe"
>
  <!-- Hero — Group dining atmosphere -->
  <SectionHero
    tagline={t('restaurant.groups.heroTitle')}
    subtitle={t('restaurant.groups.heroSubtitle')}
    pole="restaurant"
    image="/images/heroes/repas-groupe.jpg"
  />

  <!-- Breadcrumb + Intro -->
  <section class="py-12 lg:py-24">
    <div class="max-w-[768px] mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm">
          <li>
            <a
              href={getLocalizedPath('/restaurant', lang)}
              class="font-medium uppercase tracking-wider hover:underline"
              style={`color: ${restaurant.accent}; font-variant: small-caps`}
            >
              Restaurant
            </a>
          </li>
          <li class="text-gray-400" aria-hidden="true">/</li>
          <li class="text-gray-500">{t('restaurant.groups.breadcrumb')}</li>
        </ol>
      </nav>

      <!-- Intro text -->
      <p class="text-lg lg:text-xl text-gray-600 leading-relaxed text-center">
        {groupIntro}
      </p>
    </div>
  </section>

  <!-- Formula cards -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)" style={`background-color: ${restaurant.light}`}>
    <div class="max-w-[1280px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-reveal>
        <p class="section-eyebrow mb-3" style={`color: ${restaurant.accent}80`}>Nos formules</p>
        <h2 class="font-heading text-3xl font-bold" style={`color: ${restaurant.accent}`}>
          {t('restaurant.groups.formulasTitle')}
        </h2>
      </div>

      {localizedFormulas.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {localizedFormulas.map((formula) => (
            <GroupFormulaCard
              name={formula.name}
              pricePerPerson={formula.pricePerPerson}
              minGroupSize={formula.minGroupSize}
              inclusions={formula.inclusions}
              recommended={formula.recommended}
              perPersonLabel={t('restaurant.groups.perPerson')}
              minSizeLabel={t('restaurant.groups.minSize')}
              recommendedLabel={t('restaurant.groups.recommended')}
              accent={restaurant.accent}
            />
          ))}
        </div>
      ) : (
        <div class="bg-white rounded-2xl p-12 text-center">
          <p class="text-gray-400">Formules groupe à venir — géré via Keystatic CMS</p>
        </div>
      )}
    </div>
  </section>

  <!-- Practical info -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-reveal>
        <p class="section-eyebrow mb-3" style={`color: ${restaurant.accent}80`}>Pratique</p>
        <h2 class="font-heading text-3xl font-bold" style={`color: ${restaurant.accent}`}>
          {t('restaurant.groups.practicalTitle')}
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6" data-reveal-stagger>
        <!-- Customizable menu -->
        <div class="flex items-start gap-4 bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${restaurant.light}`}>
            <Icon name="lucide:calendar" class="w-5 h-5" stroke-width="1.5" style={`color: ${restaurant.accent}`} />
          </div>
          <div>
            <p class="font-medium text-gray-800">{t('restaurant.groups.practical1')}</p>
          </div>
        </div>

        <!-- Dietary needs -->
        <div class="flex items-start gap-4 bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${restaurant.light}`}>
            <Icon name="lucide:badge-check" class="w-5 h-5" stroke-width="1.5" style={`color: ${restaurant.accent}`} />
          </div>
          <div>
            <p class="font-medium text-gray-800">{t('restaurant.groups.practical2')}</p>
          </div>
        </div>

        <!-- Terrace -->
        <div class="flex items-start gap-4 bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${restaurant.light}`}>
            <Icon name="lucide:users" class="w-5 h-5" stroke-width="1.5" style={`color: ${restaurant.accent}`} />
          </div>
          <div>
            <p class="font-medium text-gray-800">{t('restaurant.groups.practical3')}</p>
          </div>
        </div>

        <!-- Activities combo -->
        <div class="flex items-start gap-4 bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${restaurant.light}`}>
            <Icon name="lucide:star" class="w-5 h-5" stroke-width="1.5" style={`color: ${restaurant.accent}`} />
          </div>
          <div>
            <p class="font-medium text-gray-800">{t('restaurant.groups.practical4')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA — Phone-first for persona Karine -->
  <section class="relative py-(--spacing-section-mobile) lg:py-(--spacing-section) text-white grain-overlay overflow-hidden" style={`background-color: ${restaurant.accent}`}>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 60% 40%, rgba(255,255,255,0.15) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow text-white/40 mb-3">Réservation groupe</p>
      <h2 class="font-heading text-3xl lg:text-4xl font-bold mb-6">
        {t('restaurant.groups.ctaTitle')}
      </h2>
      <p class="text-white/70 text-lg mb-10">
        {t('restaurant.groups.ctaReassurance')}
      </p>

      <!-- Phone — Primary CTA, very prominent -->
      <a
        href={`tel:${PHONE_NUMBER}`}
        class="inline-flex items-center gap-3 text-white text-2xl lg:text-[32px] font-bold mb-8 hover:text-white/90 transition-colors"
      >
        <Icon name="lucide:phone" class="w-8 h-8 lg:w-10 lg:h-10" />
        {formattedPhone}
      </a>

      <!-- Email — Secondary -->
      <div class="block">
        <a
          href={`mailto:${EMAIL_ADDRESS}?subject=Repas%20de%20groupe`}
          class="inline-flex items-center gap-2 text-white/50 text-base hover:text-white transition-colors"
        >
          <Icon name="lucide:mail" class="w-5 h-5" stroke-width="1.5" />
          {EMAIL_ADDRESS}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={t('crosslink.repasGroupe.aventure')}
    href={getLocalizedPath('/aventure', lang)}
    pole="aventure"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="restaurant" />
</BaseLayout>
