---
import Icon from '@/components/common/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);
---

<BaseLayout
  title={t('error.404.pageTitle')}
  description={t('error.404.description')}
  noindex={true}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 text-center">
    <p class="text-8xl md:text-9xl font-bold text-gray-200 select-none">404</p>
    <h1 class="mt-4 text-2xl md:text-3xl font-bold text-gray-800">
      {t('error.404.title')}
    </h1>
    <p class="mt-4 text-gray-600 max-w-md mx-auto">
      {t('error.404.description')}
    </p>
    <a
      href={getLocalizedPath('/', lang)}
      class="mt-8 inline-flex items-center gap-2 bg-brun-terre text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all"
    >
      <Icon name="lucide:arrow-left" class="w-4 h-4" />
      {t('error.404.cta')}
    </a>
  </div>
</BaseLayout>
