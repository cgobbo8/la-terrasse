---
/**
 * LA SALLE HUB — Bleu ardoise
 * Venue vitrine: specs, equipment, configurations
 * Dispatch to sub-pages: Séminaires & Pro, Événementiel
 * Agenda preview of upcoming events
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import VenueSpecs from '@/components/salle/VenueSpecs.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { generateEventVenueLD } from '@/lib/seo';
import { buildQuoteMailto, poleConfigs } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';

const { accent: salleAccent, light: salleLight } = poleConfigs.salle;
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load venue data from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const venueData = await reader.singletons.venue.read();

const capacitySeated = venueData?.capacitySeated ?? 0;
const capacityStanding = venueData?.capacityStanding ?? 0;
const surfaceM2 = venueData?.surfaceM2 ?? 0;

// For array fields, check localized version first, fall back to FR
const venueAny = venueData as Record<string, unknown> | null;
const equipment = venueData
  ? (lang !== defaultLang && venueAny?.[`equipment_${lang}`] as readonly string[])
    || venueData.equipment
    || []
  : [] as readonly string[];
const layoutOptions = venueData
  ? (lang !== defaultLang && venueAny?.[`layoutOptions_${lang}`] as readonly { name: string; capacity: number }[])
    || venueData.layoutOptions
    || []
  : [] as readonly { name: string; capacity: number }[];

const seoTitle = 'La Salle — Location de salle pour pros & associations — La Terrasse Saint-Ferréol';
const seoDescription = 'Salle modulable au lac de Saint-Ferréol : capacité jusqu\'à ' + capacityStanding + ' personnes. Location pour séminaires, concerts, foires, soirées. Sur réservation pour pros & associations.';

const jsonLd = generateEventVenueLD({
  capacitySeated,
  capacityStanding,
  amenities: venueData?.equipment ?? [],
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="salle"
  jsonLd={jsonLd}
  pagePath="/la-salle"
>
  <!-- Hero -->
  <SectionHero
    tagline={t('salle.hero.tagline')}
    subtitle={t('salle.hero.subtitle')}
    pole="salle"
    image="/images/heroes/salle.webp"
  >
    <div class="flex flex-wrap gap-4">
      <a href={getLocalizedPath('/la-salle/seminaires', lang)} class="inline-flex items-center gap-2 bg-white text-salle px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
        {t('salle.hub.seminairesCta')}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a href={getLocalizedPath('/la-salle/evenementiel', lang)} class="inline-flex items-center gap-2 border border-white/30 text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all">
        {t('salle.hub.evenementielCta')}
      </a>
    </div>
  </SectionHero>

  <!-- L'ESPACE — Venue specs -->
  <div class="pt-(--spacing-section-mobile) lg:pt-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow mb-4" style={`color: ${salleAccent}50;`}>L'espace</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-2 text-gray-900">
        {t('salle.venue.title')}
      </h2>
    </div>
    <VenueSpecs
      capacitySeated={capacitySeated}
      capacityStanding={capacityStanding}
      surfaceM2={surfaceM2}
      equipment={equipment}
      layoutOptions={layoutOptions}
      lang={lang}
    />
  </div>

  <!-- DOUBLE DISPATCH: Événementiel + Séminaires -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6" data-reveal-stagger>
        <!-- Événementiel card -->
        <a
          href={getLocalizedPath('/la-salle/evenementiel', lang)}
          class="group block rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover"
        >
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src="/images/heroes/evenementiel.webp"
              alt="Événementiel"
              class="w-full h-full object-cover card-zoom-img"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <h3 class="font-heading text-xl font-bold mb-2 text-gray-900">
              {t('salle.hub.evenementielTitle')}
            </h3>
            <p class="text-gray-500 text-sm mb-4 leading-relaxed">Louez la salle pour vos concerts, foires, expositions, soirées privées — un espace modulable à votre disposition.</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold group-hover:gap-2.5 transition-all" style={`color: ${salleAccent};`}>
              {t('salle.hub.evenementielCta')}
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </span>
          </div>
        </a>

        <!-- Séminaires card -->
        <a
          href={getLocalizedPath('/la-salle/seminaires', lang)}
          class="group block rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover"
        >
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src="/images/heroes/seminaires.webp"
              alt="Séminaires"
              class="w-full h-full object-cover card-zoom-img"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <h3 class="font-heading text-xl font-bold mb-2 text-gray-900">
              {t('salle.hub.seminairesTitle')}
            </h3>
            <p class="text-gray-500 text-sm mb-4 leading-relaxed">{t('salle.hub.seminairesDesc')}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold group-hover:gap-2.5 transition-all" style={`color: ${salleAccent};`}>
              {t('salle.hub.seminairesCta')}
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Section contact -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) grain-overlay overflow-hidden" style={`background-color: ${salleAccent};`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10" data-reveal>
      <p class="section-eyebrow text-white/30 mb-6">Contact</p>
      <h2 class="font-heading text-3xl font-bold text-white mb-4">Un projet en tête ?</h2>
      <p class="text-white/50 mb-10 max-w-lg mx-auto">
        {t('common.requestQuoteDesc')}
      </p>
      <a href={buildQuoteMailto()} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-heading font-semibold text-sm transition-all hover:shadow-lg hover:-translate-y-px text-white bg-white/15 border border-white/20 hover:bg-white/25">
        {t('common.requestQuote')}
        <Icon name="lucide:mail" class="w-4 h-4" />
      </a>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="salle" />
</BaseLayout>
