---
/**
 * LA SALLE HUB — Bleu ardoise
 * Venue vitrine: specs, equipment, configurations
 * Dispatch to sub-pages: Séminaires & Pro, Événementiel
 * Agenda preview of upcoming events
 */
import Icon from '@/components/common/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import VenueSpecs from '@/components/salle/VenueSpecs.astro';
import VenueSpaces from '@/components/salle/VenueSpaces.svelte';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import CollectivitesCallout from '@/components/salle/CollectivitesCallout.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedArray, getLocalizedField } from '@/i18n/utils';
import { generateEventVenueLD } from '@/lib/seo';
import { buildQuoteMailto, poleConfigs } from '@/lib/pole-config';
import { getSiteSettings } from '@/lib/site-settings';
import { createReader } from '@keystatic/core/reader';

const { accent: salleAccent, light: salleLight } = poleConfigs.salle;
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load settings + venue data from Keystatic
const siteSettings = await getSiteSettings();
const siteEmail = siteSettings?.email ?? '';
const sitePhone = siteSettings?.phone ?? '';
const reader = createReader(process.cwd(), keystaticConfig);
const pageTexts = await reader.singletons.salleHub.read();
const venueData = pageTexts;
const tx = (path: string) => {
  const [section, field] = path.split('.');
  return getLocalizedField(
    ((pageTexts as Record<string, unknown> | null)?.[section] as Record<string, unknown>) ?? {},
    field,
    lang,
  );
};

const capacityMax = venueData?.space.capacityMax ?? 0;
const surfaceM2 = venueData?.space.surfaceM2 ?? 0;
const equipment = getLocalizedArray(venueData ?? {}, 'equipment', lang);
const layoutSuggestions = getLocalizedArray(venueData ?? {}, 'layoutSuggestions', lang);

const seoTitle = 'Location de salle au lac de Saint-Ferréol, près de Toulouse';
const seoDescription = 'Salle modulable au lac de Saint-Ferréol, entre Toulouse et Castres : jusqu\'à ' + capacityMax + ' personnes. Séminaires, concerts, foires, soirées privées. Devis sur mesure.';

const jsonLd = generateEventVenueLD({
  capacityMax,
  amenities: venueData?.equipment.fr ?? [],
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="salle"
  jsonLd={jsonLd}
  pagePath="/la-salle"
>
  <!-- Hero -->
  <SectionHero
    tagline={tx('hero.tagline')}
    subtitle={tx('hero.subtitle')}
    pole="salle"
    image="/images/heroes/salle.webp"
  >
    <div class="flex flex-wrap gap-4">
      <a href={getLocalizedPath('/la-salle/seminaires', lang)} class="inline-flex items-center gap-2 bg-white text-salle px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
        {t('salle.hub.seminairesCta')}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a href={getLocalizedPath('/la-salle/evenementiel', lang)} class="inline-flex items-center gap-2 border border-white/30 text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all">
        {t('salle.hub.evenementielCta')}
      </a>
    </div>
  </SectionHero>

  <!-- L'ESPACE — Venue specs -->
  <div class="pt-(--spacing-section-mobile) lg:pt-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow mb-4" style={`color: ${salleAccent}50;`}>{tx('overview.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-2 text-gray-900">
        {tx('overview.title')}
      </h2>
    </div>
    <VenueSpecs
      capacityMax={capacityMax}
      surfaceM2={surfaceM2}
      equipment={equipment}
      layoutSuggestions={layoutSuggestions}
      lang={lang}
    />
  </div>

  <!-- LES ESPACES — 3 cards: salle, sanitaires, traiteur -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10" data-reveal>
        <p class="section-eyebrow mb-4" style={`color: ${salleAccent}50;`}>{tx('spaces.eyebrow')}</p>
        <h2 class="font-heading text-2xl lg:text-3xl font-bold text-gray-900">
          {tx('spaces.title')}
        </h2>
      </div>
      <VenueSpaces
        client:visible
        accent={salleAccent}
        light={salleLight}
        detailsLabel={tx('spaces.detailsLabel')}
        hideLabel={tx('spaces.hideLabel')}
        cards={(venueData?.spaces?.list ?? []).map((card) => ({
          icon: card.icon,
          title: getLocalizedField(card, 'title', lang),
          desc: getLocalizedField(card, 'desc', lang),
          details: (card.details ?? []).map((d) => (d as Record<string, string>)[lang] || (d as Record<string, string>).fr || '').filter(Boolean),
        }))}
      />
    </div>
  </section>

  <!-- Tarifs groupes & collectivités -->
  <CollectivitesCallout />

  <!-- DOUBLE DISPATCH: Événementiel + Séminaires -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6" data-reveal-stagger>
        <!-- Événementiel card -->
        <a
          href={getLocalizedPath('/la-salle/evenementiel', lang)}
          class="group block rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover"
        >
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src="/images/heroes/evenementiel.webp"
              alt="Événementiel"
              class="w-full h-full object-cover card-zoom-img"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <h3 class="font-heading text-xl font-bold mb-2 text-gray-900">
              {tx('dispatch.evenementielTitle')}
            </h3>
            <p class="text-gray-500 text-sm mb-4 leading-relaxed">{tx('dispatch.evenementielDesc')}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold group-hover:gap-2.5 transition-all" style={`color: ${salleAccent};`}>
              {t('salle.hub.evenementielCta')}
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </span>
          </div>
        </a>

        <!-- Séminaires card -->
        <a
          href={getLocalizedPath('/la-salle/seminaires', lang)}
          class="group block rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover"
        >
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src="/images/heroes/seminaires.webp"
              alt="Séminaires"
              class="w-full h-full object-cover card-zoom-img"
              loading="lazy"
            />
          </div>
          <div class="p-7">
            <h3 class="font-heading text-xl font-bold mb-2 text-gray-900">
              {tx('dispatch.seminairesTitle')}
            </h3>
            <p class="text-gray-500 text-sm mb-4 leading-relaxed">{tx('dispatch.seminairesDesc')}</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold group-hover:gap-2.5 transition-all" style={`color: ${salleAccent};`}>
              {t('salle.hub.seminairesCta')}
              <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Section contact -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) grain-overlay overflow-hidden" style={`background-color: ${salleAccent};`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10" data-reveal>
      <p class="section-eyebrow text-white/30 mb-6">{tx('contact.eyebrow')}</p>
      <h2 class="font-heading text-3xl font-bold text-white mb-4">{tx('contact.title')}</h2>
      <p class="text-white/50 mb-10 max-w-lg mx-auto">
        {tx('contact.subtitle')}
      </p>
      <a href={buildQuoteMailto(siteEmail)} class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full font-heading font-semibold text-sm transition-all hover:shadow-lg hover:-translate-y-px text-white bg-white/15 border border-white/20 hover:bg-white/25">
        {t('common.requestQuote')}
        <Icon name="lucide:mail" class="w-4 h-4" />
      </a>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="salle" />
</BaseLayout>
