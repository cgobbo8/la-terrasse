---
/**
 * LA SALLE — SÉMINAIRES & PRO
 * Dedicated page for seminar packages (Simple, Gourmet, Aventure)
 * CTA: mailto for quote requests
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import PackComparator from '@/components/salle/PackComparator.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { buildQuoteMailto } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load seminar packages from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const allSeminars = await reader.collections.seminars.all();
const seminars = allSeminars
  .filter((s) => s.entry.visible)
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

const packages = seminars.map((s) => ({
  slug: s.slug,
  title: s.entry.title,
  subtitle: s.entry.subtitle ?? '',
  description: s.entry.description ?? '',
  includes: [...(s.entry.includes ?? [])],
  priceFrom: s.entry.priceFrom ?? 'Sur devis',
  features: s.entry.features,
  ctaHref: buildQuoteMailto(s.entry.title),
  highlighted: s.slug === 'seminaire-gourmet',
}));

const seoTitle = 'Séminaire nature près de Toulouse — La Terrasse Saint-Ferréol';
const seoDescription = 'Formules séminaire au lac de Saint-Ferréol : salle équipée, restauration et team building. 3 packs pour entreprises, écoles et institutions.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="salle"
  pagePath="/la-salle/seminaires"
>
  <!-- Hero -->
  <SectionHero
    tagline={t('salle.seminaires.hero.tagline')}
    subtitle={t('salle.seminaires.hero.subtitle')}
    pole="salle"
  >
    <a href={buildQuoteMailto()} class="bg-white text-bleu-ardoise px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
      {t('common.requestQuote')}
    </a>
  </SectionHero>

  <!-- LES PACKS — Comparateur side-by-side -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-center mb-8" style="color: #3d4969;">
        {t('salle.packs.title')}
      </h2>
      <PackComparator packages={packages} lang={lang} />
    </div>
  </section>

  <!-- Section groupes -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 italic mb-4">
        {t('salle.groups.cta')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/en-entreprise', lang)} class="text-white px-6 py-3 rounded-lg font-medium transition-colors" style="background-color: #3d4969;">
          {t('salle.hub.fullDayButton')}
        </a>
        <a href={buildQuoteMailto()} class="px-6 py-3 rounded-lg font-medium transition-colors" style="border: 1px solid #3d4969; color: #3d4969;">
          {t('common.requestQuote')}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-links narratifs -->
  <ContextualCrossLink
    text={t('crosslink.salleHub.aventure')}
    href={getLocalizedPath('/aventure', lang)}
    pole="aventure"
  />
  <ContextualCrossLink
    text={t('crosslink.salleHub.restaurant')}
    href={getLocalizedPath('/restaurant', lang)}
    pole="restaurant"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="salle" />
</BaseLayout>
