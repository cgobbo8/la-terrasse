---
/**
 * LA SALLE — SÉMINAIRES & PRO
 * Dedicated page for seminar packages (Simple, Gourmet, Aventure)
 * CTA: mailto for quote requests
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import SeminarConfigurator from '@/components/salle/SeminarConfigurator.svelte';
import VenueSpecs from '@/components/salle/VenueSpecs.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import CollectivitesCallout from '@/components/salle/CollectivitesCallout.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { buildQuoteMailto, poleConfigs } from '@/lib/pole-config';
import { getSiteSettings, toTelHref } from '@/lib/site-settings';
import { generateFAQLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';

const { accent: salleAccent, light: salleLight } = poleConfigs.salle;
const { accent: aventureAccent, light: aventureLight } = poleConfigs.aventure;
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load settings + seminar packages + venue data from Keystatic
const siteSettings = await getSiteSettings();
const siteEmail = siteSettings?.email ?? '';
const telHref = toTelHref(siteSettings?.phone ?? '');
const reader = createReader(process.cwd(), keystaticConfig);
const allSeminars = await reader.collections.seminars.all();
const venueData = await reader.singletons.venue.read();
const pricingData = await reader.singletons.seminarsPricing.read();
const capacityMax = venueData?.capacityMax ?? 0;
const surfaceM2 = venueData?.surfaceM2 ?? 0;
const venueAny = venueData as Record<string, unknown> | null;
const equipment = venueData
  ? (lang !== defaultLang && venueAny?.[`equipment_${lang}`] as readonly string[]) || venueData.equipment || []
  : [] as readonly string[];
const layoutSuggestions = venueData
  ? (lang !== defaultLang && venueAny?.[`layoutSuggestions_${lang}`] as readonly string[]) || venueData.layoutSuggestions || []
  : [] as readonly string[];
const seminars = allSeminars
  .filter((s) => s.entry.visible)
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

const packages = seminars.map((s) => ({
  slug: s.slug,
  title: s.entry.title,
  subtitle: s.entry.subtitle ?? '',
  description: s.entry.description ?? '',
  includes: [...(s.entry.includes ?? [])],
  priceFrom: s.entry.priceFrom ?? 'Sur devis',
  features: s.entry.features,
  ctaHref: buildQuoteMailto(siteEmail, s.entry.title),
  highlighted: false,
}));

const seoTitle = 'Séminaire au lac de Saint-Ferréol, près de Toulouse';
const seoDescription = 'Séminaire d\'entreprise au lac de Saint-Ferréol, à 45 min de Toulouse. Salle équipée jusqu\'à 80 personnes, restauration locale, team building nature. Devis sous 24h.';

const faqItems = [
  { question: t('salle.seminaires.faq.q1'), answer: t('salle.seminaires.faq.a1') },
  { question: t('salle.seminaires.faq.q2'), answer: t('salle.seminaires.faq.a2') },
  { question: t('salle.seminaires.faq.q3'), answer: t('salle.seminaires.faq.a3') },
  { question: t('salle.seminaires.faq.q4'), answer: t('salle.seminaires.faq.a4') },
  { question: t('salle.seminaires.faq.q5'), answer: t('salle.seminaires.faq.a5') },
];
const faqJsonLd = generateFAQLD(faqItems);
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="salle"
  pagePath="/la-salle/seminaires"
  jsonLd={faqJsonLd}
>
  <!-- Hero -->
  <SectionHero
    tagline={t('salle.seminaires.hero.tagline')}
    subtitle={t('salle.seminaires.hero.subtitle')}
    pole="salle"
    image="/images/heroes/seminaires.webp"
    breadcrumb={{ parentLabel: t('nav.salle'), parentHref: getLocalizedPath('/la-salle', lang), currentLabel: t('nav.salle.seminairesPro') }}
  >
    <a href={buildQuoteMailto()} class="bg-white text-salle px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all inline-flex items-center gap-2">
      {t('common.requestQuote')}
    </a>
  </SectionHero>

  <!-- DEVIS — Configurateur + Callout custom -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">

    <!-- Configurateur -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10" data-reveal>
        <p class="section-eyebrow mb-3" style={`color: ${salleAccent}80;`}>{t('salle.seminaires.config.eyebrow')}</p>
        <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-3 text-gray-900">
          {t('salle.seminaires.config.title')}
        </h2>
        <p class="text-gray-500 max-w-xl mx-auto text-sm leading-relaxed">
          {t('salle.seminaires.config.desc')}
        </p>
      </div>
      <SeminarConfigurator
        accentColor={salleAccent}
        quoteMailto={buildQuoteMailto(siteEmail, 'Séminaire')}
        lang={lang}
        flatJournee={pricingData?.flatJournee ?? 600}
        flatSoiree={pricingData?.flatSoiree ?? 500}
        priceMealFull={pricingData?.priceMealFull ?? 45}
        priceMealApero={pricingData?.priceMealApero ?? 35}
        priceTeamBuilding={pricingData?.priceTeamBuilding ?? 25}
        priceExtraHour={pricingData?.priceExtraHour ?? 50}
        minRepasComplet={pricingData?.minRepasComplet ?? 12}
        minApero={pricingData?.minApero ?? 15}
        maxParticipants={pricingData?.maxParticipants ?? 80}
        client:visible
      />
    </div>

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Séparateur "ou" -->
      <div class="relative flex items-center gap-4 my-10">
        <div class="flex-1 h-px bg-gray-300/60"></div>
        <span class="font-heading font-bold text-xs uppercase tracking-widest text-gray-400">
          {t('salle.seminaires.separator')}
        </span>
        <div class="flex-1 h-px bg-gray-300/60"></div>
      </div>

      <!-- Callout: demande particulière -->
      <div
        class="relative rounded-2xl p-6 overflow-hidden"
        style="background: linear-gradient(135deg, var(--color-soleil) 0%, #FFE066 100%); border: 1.5px solid #E6D45C;"
        data-reveal
      >
        <div class="flex flex-col sm:flex-row items-start gap-5">
          <span class="w-12 h-12 rounded-xl bg-white/50 flex items-center justify-center flex-shrink-0">
            <Icon name="lucide:message-circle" class="w-6 h-6 text-brun-terre" />
          </span>
          <div class="flex-1 min-w-0">
            <p class="font-heading font-bold text-base text-brun-terre leading-tight">
              {t('salle.seminaires.callout.title')}
            </p>
            <p class="text-sm text-brun-terre/70 mt-1.5 leading-relaxed max-w-2xl">
              {t('salle.seminaires.callout.desc')}
            </p>
            <div class="flex flex-wrap items-center gap-3 mt-4">
              <a
                href={telHref}
                class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-brun-terre text-white text-sm font-heading font-bold hover:bg-brun-terre/90 transition-colors"
              >
                <Icon name="lucide:phone" class="w-4 h-4" />
                {t('salle.seminaires.callout.phone')}
              </a>
              <a
                href={buildQuoteMailto(siteEmail, 'Demande particulière')}
                class="inline-flex items-center gap-1.5 px-5 py-2.5 rounded-full bg-white/60 text-brun-terre text-sm font-heading font-bold hover:bg-white/80 transition-colors"
              >
                {t('salle.seminaires.callout.email')}
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- TEAM BUILDING -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-reveal>
        <p class="section-eyebrow mb-3" style={`color: ${salleAccent}80;`}>{t('salle.seminaires.tb.eyebrow')}</p>
        <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-4 text-gray-900">
          {t('salle.seminaires.tb.title')}
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          {t('salle.seminaires.tb.desc')}
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Activités du centre -->
        <div class="rounded-2xl border border-gray-200/60 bg-white p-8 hover:border-gray-300/80 transition-colors">
          <div class="flex items-center gap-3 mb-6">
            <span class="w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${aventureLight};`}>
              <Icon name="lucide:trees" class="w-6 h-6 text-aventure" />
            </span>
            <div>
              <h3 class="font-heading text-lg font-bold text-gray-900">{t('salle.seminaires.tb.outdoor.title')}</h3>
              <p class="text-sm text-gray-500">{t('salle.seminaires.tb.outdoor.subtitle')}</p>
            </div>
          </div>
          <ul class="space-y-3">
            {[
              { icon: 'lucide:target', label: t('salle.seminaires.tb.outdoor.archery'), desc: t('salle.seminaires.tb.outdoor.archery.desc') },
              { icon: 'lucide:waves', label: t('salle.seminaires.tb.outdoor.paddle'), desc: t('salle.seminaires.tb.outdoor.paddle.desc') },
              { icon: 'lucide:bike', label: t('salle.seminaires.tb.outdoor.vtt'), desc: t('salle.seminaires.tb.outdoor.vtt.desc') },
              { icon: 'lucide:compass', label: t('salle.seminaires.tb.outdoor.orientation'), desc: t('salle.seminaires.tb.outdoor.orientation.desc') },
              { icon: 'lucide:anchor', label: t('salle.seminaires.tb.outdoor.pedalo'), desc: t('salle.seminaires.tb.outdoor.pedalo.desc') },
            ].map((item) => (
              <li class="flex items-center gap-3 text-sm">
                <Icon name={item.icon} class="w-4 h-4 text-aventure flex-shrink-0" />
                <span class="font-medium text-gray-800">{item.label}</span>
                <span class="text-gray-400">—</span>
                <span class="text-gray-500">{item.desc}</span>
              </li>
            ))}
          </ul>
          <a
            href={getLocalizedPath('/aventure', lang)}
            class="inline-flex items-center gap-1 mt-6 text-sm font-medium text-aventure hover:underline"
          >
            {t('salle.seminaires.tb.outdoor.cta')}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>

        <!-- Programme coach -->
        <div class="rounded-2xl border-2 p-8 relative overflow-hidden" style={`border-color: ${salleAccent}; background: linear-gradient(135deg, ${salleLight} 0%, white 100%);`}>
          <div class="absolute top-4 right-4">
            <span class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full text-white" style={`background-color: ${salleAccent};`}>
              <Icon name="lucide:sparkles" class="w-3 h-3" />
              {t('salle.seminaires.tb.premium')}
            </span>
          </div>
          <div class="flex items-center gap-3 mb-6">
            <span class="w-12 h-12 rounded-xl flex items-center justify-center" style={`background-color: ${salleAccent}15;`}>
              <Icon name="lucide:trophy" class="w-6 h-6" style={`color: ${salleAccent};`} />
            </span>
            <div>
              <h3 class="font-heading text-lg font-bold text-gray-900">{t('salle.seminaires.tb.coaching.title')}</h3>
              <p class="text-sm text-gray-500">{t('salle.seminaires.tb.coaching.subtitle')}</p>
            </div>
          </div>
          <ul class="space-y-3">
            {[
              { icon: 'lucide:flame', label: t('salle.seminaires.tb.coaching.kohlanta'), desc: t('salle.seminaires.tb.coaching.kohlanta.desc') },
              { icon: 'lucide:brain', label: t('salle.seminaires.tb.coaching.mental'), desc: t('salle.seminaires.tb.coaching.mental.desc') },
              { icon: 'lucide:users', label: t('salle.seminaires.tb.coaching.cohesion'), desc: t('salle.seminaires.tb.coaching.cohesion.desc') },
              { icon: 'lucide:puzzle', label: t('salle.seminaires.tb.coaching.logic'), desc: t('salle.seminaires.tb.coaching.logic.desc') },
              { icon: 'lucide:medal', label: t('salle.seminaires.tb.coaching.sport'), desc: t('salle.seminaires.tb.coaching.sport.desc') },
            ].map((item) => (
              <li class="flex items-center gap-3 text-sm">
                <Icon name={item.icon} class="w-4 h-4 flex-shrink-0" style={`color: ${salleAccent};`} />
                <span class="font-medium text-gray-800">{item.label}</span>
                <span class="text-gray-400">—</span>
                <span class="text-gray-500">{item.desc}</span>
              </li>
            ))}
          </ul>
          <a
            href={buildQuoteMailto('Team building avec coach')}
            class="inline-flex items-center gap-2 mt-6 font-heading font-semibold text-sm text-white px-7 py-3.5 rounded-full transition-all hover:shadow-lg hover:-translate-y-px"
            style={`background-color: ${salleAccent};`}
          >
            {t('salle.seminaires.tb.coaching.cta')}
            <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- L'ESPACE — Venue specs (proof/details) -->
  <div class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow mb-4" style={`color: ${salleAccent}80;`}>{t('salle.seminaires.venue.eyebrow')}</p>
      <h2 class="font-heading text-2xl font-bold mb-2 text-gray-900">
        {t('salle.venue.title')}
      </h2>
    </div>
    <VenueSpecs
      capacityMax={capacityMax}
      surfaceM2={surfaceM2}
      equipment={equipment}
      layoutSuggestions={layoutSuggestions}
      lang={lang}
    />
  </div>

  <!-- Tarifs groupes & collectivités -->
  <CollectivitesCallout />

  <!-- Section contact -->
  <section class="relative py-(--spacing-section-mobile) lg:py-(--spacing-section) text-white grain-overlay overflow-hidden" style={`background-color: ${salleAccent};`}>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 70% 50%, rgba(255,255,255,0.15) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow text-white/40 mb-3">{t('salle.seminaires.contact.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-4">
        {t('common.requestQuoteDesc')}
      </h2>
      <a href={buildQuoteMailto(siteEmail)} class="inline-flex items-center gap-2 bg-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm transition-all hover:shadow-lg hover:-translate-y-px" style={`color: ${salleAccent};`}>
        <Icon name="lucide:mail" class="w-4 h-4" />
        {t('common.requestQuote')}
      </a>
    </div>
  </section>

  <!-- Pourquoi Saint-Ferréol — SEO prose section -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow mb-4" style={`color: ${salleAccent}80;`}>{t('salle.seminaires.why.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-6 text-gray-900">
        {t('salle.seminaires.why.title')}
      </h2>
      <p class="text-gray-600 leading-relaxed text-base lg:text-lg">
        {t('salle.seminaires.why.body')}
      </p>
    </div>
  </section>

  <!-- FAQ — SEO + user info -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-8 text-gray-900" data-reveal>
        {t('salle.seminaires.faq.title')}
      </h2>
      <dl class="space-y-6" data-reveal-stagger>
        {faqItems.map((faq) => (
          <div class="border-b border-gray-200 pb-6">
            <dt class="font-heading font-bold text-gray-900 mb-2">{faq.question}</dt>
            <dd class="text-gray-600 leading-relaxed">{faq.answer}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="salle" />
</BaseLayout>
