---
/**
 * LA SALLE — ÉVÉNEMENTIEL
 * New page for non-seminar events: concerts, fairs, exhibitions, private parties
 * CTA: contact (phone or email for inquiries)
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import VenueSpecs from '@/components/salle/VenueSpecs.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { buildEventContactMailto, poleConfigs } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';

const { accent: salleAccent, light: salleLight } = poleConfigs.salle;
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load venue data
const reader = createReader(process.cwd(), keystaticConfig);
const venueData = await reader.singletons.venue.read();
const capacitySeated = venueData?.capacitySeated ?? 0;
const capacityStanding = venueData?.capacityStanding ?? 0;
const surfaceM2 = venueData?.surfaceM2 ?? 0;
const venueAny = venueData as Record<string, unknown> | null;
const equipment = venueData
  ? (lang !== defaultLang && venueAny?.[`equipment_${lang}`] as readonly string[]) || venueData.equipment || []
  : [] as readonly string[];
const layoutOptions = venueData
  ? (lang !== defaultLang && venueAny?.[`layoutOptions_${lang}`] as readonly { name: string; capacity: number }[]) || venueData.layoutOptions || []
  : [] as readonly { name: string; capacity: number }[];

const eventTypes = [
  {
    title: t('salle.evenementiel.concerts'),
    description: t('salle.evenementiel.concerts.desc'),
    icon: 'lucide:music',
    image: '/images/salle/concert.webp',
  },
  {
    title: t('salle.evenementiel.foires'),
    description: t('salle.evenementiel.foires.desc'),
    icon: 'lucide:store',
    image: '/images/salle/exposition.webp',
  },
  {
    title: t('salle.evenementiel.soirees'),
    description: t('salle.evenementiel.soirees.desc'),
    icon: 'lucide:sparkles',
    image: '/images/salle/soirees-privees.webp',
  },
  {
    title: t('salle.evenementiel.marches'),
    description: t('salle.evenementiel.marches.desc'),
    icon: 'lucide:shopping-bag',
    image: '/images/salle/foire-expo.webp',
  },
];

const seoTitle = 'Location événementielle — Salle à louer près de Toulouse — La Terrasse Saint-Ferréol';
const seoDescription = 'Louez notre salle au lac de Saint-Ferréol pour vos événements : concerts, foires, expositions, soirées privées. Salle modulable jusqu\'à 120 personnes, sur réservation.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="salle"
  pagePath="/la-salle/evenementiel"
>
  <!-- Hero -->
  <SectionHero
    tagline={t('salle.evenementiel.hero.tagline')}
    subtitle={t('salle.evenementiel.hero.subtitle')}
    pole="salle"
    image="/images/heroes/evenementiel.webp"
  >
    <a href={buildEventContactMailto()} class="bg-white text-salle px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all inline-flex items-center gap-2">
      {t('salle.evenementiel.cta')}
    </a>
  </SectionHero>

  <!-- Intro (what this page is about) -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow mb-3" style={`color: ${salleAccent}80;`}>La Salle</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-4 text-gray-900">
        {t('salle.evenementiel.intro.title')}
      </h2>
      <p class="text-gray-600 leading-relaxed max-w-2xl mx-auto">
        {t('salle.evenementiel.intro.desc')}
      </p>
    </div>
  </section>

  <!-- Types d'événements (what events work here) -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-reveal>
        <p class="section-eyebrow mb-3" style={`color: ${salleAccent}80;`}>Événementiel</p>
        <h2 class="font-heading text-2xl lg:text-3xl font-bold text-gray-900">
          {t('salle.evenementiel.types.title')}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-reveal-stagger>
        {eventTypes.map((type) => (
          <div class="group rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover">
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={type.image}
                alt={type.title}
                class="w-full h-full object-cover card-zoom-img"
                loading="lazy"
              />
            </div>
            <div class="p-6 lg:p-8">
              <div class="flex items-center gap-3 mb-3">
                <span
                  class="shrink-0 w-11 h-11 rounded-xl flex items-center justify-center"
                  style={`background-color: ${salleLight}; color: ${salleAccent};`}
                >
                  <Icon name={type.icon} class="w-5 h-5" />
                </span>
                <h3 class="font-heading text-lg font-bold text-gray-900">
                  {type.title}
                </h3>
              </div>
              <p class="text-gray-600 text-sm leading-relaxed">{type.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- L'ESPACE — Venue specs (detailed proof) -->
  <div class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow mb-4" style={`color: ${salleAccent}80;`}>L'espace</p>
      <h2 class="font-heading text-2xl font-bold mb-2 text-gray-900">
        {t('salle.venue.title')}
      </h2>
    </div>
    <VenueSpecs
      capacitySeated={capacitySeated}
      capacityStanding={capacityStanding}
      surfaceM2={surfaceM2}
      equipment={equipment}
      layoutOptions={layoutOptions}
      lang={lang}
    />
  </div>

  <!-- CTA -->
  <section class="relative py-(--spacing-section-mobile) lg:py-(--spacing-section) text-white grain-overlay overflow-hidden" style={`background-color: ${salleAccent};`}>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.15) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow text-white/40 mb-3">Contact</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-4">
        {t('salle.evenementiel.intro.title')}
      </h2>
      <p class="text-white/70 mb-8 max-w-xl mx-auto">
        {t('salle.evenementiel.intro.desc')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={buildEventContactMailto()} class="bg-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm transition-all hover:shadow-lg hover:-translate-y-px inline-flex items-center gap-2" style={`color: ${salleAccent};`}>
          <Icon name="lucide:mail" class="w-4 h-4" />
          {t('salle.evenementiel.cta')}
        </a>
        <a href={getLocalizedPath('/la-salle', lang)} class="px-7 py-3.5 rounded-full font-heading font-semibold text-sm transition-all hover:bg-white/10 inline-flex items-center gap-2 border border-white/20 text-white">
          {t('salle.venue.title')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="salle" />
</BaseLayout>
