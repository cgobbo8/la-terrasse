---
/**
 * HOMEPAGE — Narrative lieu-first
 * 1. Hero = Saint-Ferréol, le lac, l'atmosphère
 * 2. "3 façons de profiter" = les pôles
 * 3. "Une journée à La Terrasse" = section créative immersive
 * 4. Agenda / événements
 * 5. CTA final
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import VideoHero from '@/components/homepage/VideoHero.astro';
import LogoMaskReveal from '@/components/homepage/LogoMaskReveal.svelte';
import PoleDiscovery from '@/components/homepage/PoleDiscovery.astro';
import JourneeTypeTimeline from '@/components/homepage/JourneeTypeTimeline.svelte';
import BentoMeteo from '@/components/homepage/BentoMeteo.astro';
import AgendaFloatingWidget from '@/components/homepage/AgendaFloatingWidget.astro';
import SoireesSection from '@/components/homepage/SoireesSection.astro';
import OffreJournee from '@/components/common/OffreJournee.astro';
import { Icon } from 'astro-icon/components';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load Keystatic CMS data
const reader = createReader(process.cwd(), keystaticConfig);
const settings = await reader.singletons.settings.read() ?? {};
const allEvents = await reader.collections.events.all();

const timeBlocks = [
  {
    time: '9h00',
    title: t('home.dayTrip.block0.title'),
    description: t('home.dayTrip.block0.description'),
    image: '/images/journee/arrivee.webp',
    href: '#',
    poleAccent: '#2D2B1B',
  },
  {
    time: '9h30',
    title: t('home.dayTrip.block1.title'),
    description: t('home.dayTrip.block1.description'),
    image: '/images/journee/kayak.webp',
    href: getLocalizedPath('/aventure', lang),
    poleAccent: '#537b47',
  },
  {
    time: '12h30',
    title: t('home.dayTrip.block2.title'),
    description: t('home.dayTrip.block2.description'),
    image: '/images/journee/dejeuner.webp',
    href: getLocalizedPath('/restaurant', lang),
    poleAccent: '#2D2B1B',
  },
  {
    time: '14h30',
    title: t('home.dayTrip.block3.title'),
    description: t('home.dayTrip.block3.description'),
    image: '/images/journee/paddle.webp',
    href: getLocalizedPath('/aventure', lang),
    poleAccent: '#537b47',
  },
  {
    time: '17h00',
    title: t('home.dayTrip.block4.title'),
    description: t('home.dayTrip.block4.description'),
    image: '/images/journee/detente.webp',
    href: '#',
    poleAccent: '#2D2B1B',
  },
  {
    time: '19h30',
    title: t('home.dayTrip.block5.title'),
    description: t('home.dayTrip.block5.description'),
    image: '/images/journee/apero.webp',
    href: getLocalizedPath('/restaurant', lang),
    poleAccent: '#2D2B1B',
  },
];
---

<BaseLayout title={t('home.page.title')} description={t('home.page.description')} pagePath="/">
  <!-- 0. INTRO — Logo mask reveal (first visit only) -->
  <script is:inline>
    // Prevent flash: hide overlay immediately for return visitors (before Svelte hydrates)
    if (sessionStorage.getItem('la-terrasse-intro-seen')) {
      document.documentElement.classList.add('intro-seen');
    }
  </script>
  <noscript>
    <style>
      .logo-reveal-overlay { display: none !important; }
    </style>
  </noscript>
  <LogoMaskReveal client:only="svelte" />

  <!-- 1. HERO — Le lieu (vidéo plein écran) -->
  <VideoHero tagline={t('home.hero.tagline')} subtitle={t('home.hero.subtitle')}>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={getLocalizedPath('/agenda', lang)} class="inline-flex items-center gap-2 bg-white text-brun-terre px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
        {t('home.hero.ctaAgenda')}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center gap-2 text-white border border-white/30 px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all">
        {t('home.hero.ctaContact')}
      </a>
    </div>
  </VideoHero>

  <!-- 2. AGENDA WIDGET — Floating between hero and poles -->
  <AgendaFloatingWidget events={allEvents} lang={lang} />

  <!-- 3. TROIS FAÇONS DE PROFITER — Les pôles (core value prop) -->
  <PoleDiscovery lang={lang} />

  <!-- 4. INFOS PRATIQUES — Bento grid (practical) -->
  <BentoMeteo settings={settings} lang={lang} />

  <!-- 5. UNE JOURNÉE À LA TERRASSE — Pièce créative (Svelte island) -->
  <JourneeTypeTimeline
    client:only="svelte"
    timeBlocks={timeBlocks}
    lang={lang}
    sectionTitle={t('home.dayTrip.title')}
    ctaLabel={t('home.dayTrip.cta')}
  />

  <!-- 6. SOIRÉES & ÉVÉNEMENTS (what's on) -->
  <SoireesSection lang={lang} />

  <!-- 7. OFFRE JOURNÉE — Pass Journée promo (conversion) -->
  <OffreJournee lang={lang} />

  <!-- 8. HISTOIRE — Le lieu comme 4ème personnage (storytelling) -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-brun-terre text-white grain-overlay overflow-hidden">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Image -->
        <div class="order-2 lg:order-1" data-reveal>
          <div class="relative group cursor-pointer">
            <img
              src="/images/heroes/riquet.webp"
              alt="Portrait de Pierre-Paul Riquet, créateur du Canal du Midi et du lac de Saint-Ferréol"
              class="aspect-[4/5] w-full rounded-2xl object-cover"
              loading="lazy"
            />
            <img
              src="/images/heroes/riquet-wink.webp"
              alt="Pierre-Paul Riquet fait un clin d'œil"
              class="absolute inset-0 aspect-[4/5] w-full rounded-2xl object-cover opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            />
            <!-- Decorative frame offset -->
            <div class="absolute -inset-3 border border-white/10 rounded-3xl -z-10" aria-hidden="true"></div>
          </div>
        </div>
        <!-- Text -->
        <div class="order-1 lg:order-2" data-reveal>
          <p class="section-eyebrow text-white/30 mb-6">Notre histoire</p>
          <h2 class="font-heading text-3xl lg:text-5xl font-bold mb-8 leading-tight">
            {t('home.history.title')}
          </h2>
          <p class="text-xl text-white/80 font-medium mb-6 leading-relaxed">
            {t('home.history.intro')}
          </p>
          <p class="text-white/50 leading-relaxed mb-8">
            {t('home.history.body')}
          </p>
          <p class="text-white/60 leading-relaxed italic border-l-2 border-white/20 pl-6">
            {t('home.history.closing')}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. CTA FINAL -->
  <section
    class="relative py-(--spacing-section-mobile) lg:py-32 text-white overflow-hidden bg-cover bg-center bg-fixed bg-brun-terre"
    style="background-image: url('/images/heroes/contact.webp');"
  >
    <div class="absolute inset-0 bg-black/60" />
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10" data-reveal>
      <p class="section-eyebrow text-white/30 mb-6">Rendez-vous au lac</p>
      <h2 class="font-heading text-3xl lg:text-5xl font-bold mb-6 leading-tight">
        {t('home.cta.title')}
      </h2>
      <p class="text-white/50 text-lg mb-10 max-w-xl mx-auto">
        Une journée, trois univers — à 45 minutes de Toulouse.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/agenda', lang)} class="inline-flex items-center gap-2 bg-white text-brun-terre px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
          {t('home.hero.ctaAgenda')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center border border-white/30 text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all">
          {t('home.hero.ctaContact')}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
