---
/**
 * HOMEPAGE — Narrative lieu-first
 * 1. Hero = Saint-Ferréol, le lac, l'atmosphère
 * 2. "3 façons de profiter" = les pôles
 * 3. "Une journée à La Terrasse" = section créative immersive
 * 4. Agenda / événements
 * 5. CTA final
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import VideoHero from '@/components/homepage/VideoHero.astro';
import LogoMaskReveal from '@/components/homepage/LogoMaskReveal.svelte';
import PoleDiscovery from '@/components/homepage/PoleDiscovery.astro';
import JourneeTypeTimeline from '@/components/homepage/JourneeTypeTimeline.svelte';
import BentoMeteo from '@/components/homepage/BentoMeteo.astro';
import AgendaFloatingWidget from '@/components/homepage/AgendaFloatingWidget.astro';
import SoireesSection from '@/components/homepage/SoireesSection.astro';
import OffreJournee from '@/components/common/OffreJournee.astro';
import NearbySection from '@/components/homepage/NearbySection.astro';
import Icon from '@/components/common/Icon.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs } from '@/lib/pole-config';
import { generateLocalBusinessLD } from '@/lib/seo';
import { getSiteSettings } from '@/lib/site-settings';
import Sunburst from '@/components/common/Sunburst.astro';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load Keystatic CMS data
const reader = createReader(process.cwd(), keystaticConfig);
const settings = (await getSiteSettings()) ?? {};
const homeTexts = await reader.singletons.homepage.read();

// Helper: resolve a dotted path (e.g. "hero.tagline") from the CMS
// homepage texts and pick the current language (fallback FR).
const tx = (path: string) => {
  const [section, field] = path.split('.');
  return getLocalizedField(
    ((homeTexts as Record<string, unknown> | null)?.[section] as Record<string, unknown>) ?? {},
    field,
    lang,
  );
};

const dayTripPoleHrefs: Record<string, string> = {
  restaurant: getLocalizedPath('/restaurant', lang),
  aventure: getLocalizedPath('/aventure', lang),
  salle: getLocalizedPath('/la-salle', lang),
};

const timeBlocks = (homeTexts?.dayTrip ?? []).map((block) => {
  const pole = block.pole ?? 'none';
  return {
    time: block.timeLabel,
    title: getLocalizedField(block, 'title', lang),
    description: getLocalizedField(block, 'desc', lang),
    image: block.image || '',
    href: dayTripPoleHrefs[pole] ?? '#',
    poleAccent:
      pole !== 'none' && pole in poleConfigs
        ? poleConfigs[pole as keyof typeof poleConfigs].accent
        : poleConfigs.restaurant.accent,
  };
});

const poleDescriptions = {
  restaurant: tx('poles.restaurantDesc'),
  aventure: tx('poles.aventureDesc'),
  salle: tx('poles.salleDesc'),
};
---

<BaseLayout title={tx('seo.pageTitle')} description={tx('seo.pageDescription')} pagePath="/" jsonLd={generateLocalBusinessLD()}>
  <!-- 0. INTRO — Logo mask reveal (first visit only) -->
  <script is:inline>
    // Prevent flash: hide overlay immediately for return visitors (before Svelte hydrates)
    if (sessionStorage.getItem('la-terrasse-intro-seen')) {
      document.documentElement.classList.add('intro-seen');
    }
  </script>
  <noscript>
    <style>
      .logo-reveal-overlay { display: none !important; }
    </style>
  </noscript>
  <LogoMaskReveal client:only="svelte" />

  <!-- 1. HERO — Le lieu (vidéo plein écran) -->
  <VideoHero tagline={tx('hero.tagline')} subtitle={tx('hero.subtitle')}>
    <div class="flex flex-wrap justify-center gap-4">
      <a href={getLocalizedPath('/agenda', lang)} class="inline-flex items-center gap-2 bg-white text-brun-terre px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
        {t('home.hero.ctaAgenda')}
        <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </a>
      <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center gap-2 text-white border border-white/30 px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all">
        {t('home.hero.ctaContact')}
      </a>
    </div>
  </VideoHero>

  <!-- 2. AGENDA WIDGET — Floating between hero and poles -->
  <AgendaFloatingWidget lang={lang} />

  <!-- 3. TROIS FAÇONS DE PROFITER — Les pôles (core value prop) -->
  <PoleDiscovery lang={lang} descriptions={poleDescriptions} />

  <!-- 4. INFOS PRATIQUES — Bento grid (practical) -->
  <BentoMeteo settings={settings} lang={lang} />

  <!-- 5. UNE JOURNÉE À LA TERRASSE — Pièce créative (Svelte island) -->
  <JourneeTypeTimeline
    client:only="svelte"
    timeBlocks={timeBlocks}
    lang={lang}
    sectionEyebrow={tx('dayTripIntro.eyebrow')}
    sectionTitle={tx('dayTripIntro.title')}
    ctaLabel={tx('dayTripIntro.cta')}
  />

  <!-- We keep dayTrip.title + dayTrip.cta in i18n (functional labels) — descriptions + block titles come from CMS via timeBlocks above. -->

  <!-- 6. SOIRÉES & ÉVÉNEMENTS (what's on) -->
  <SoireesSection lang={lang} />

  <!-- 7. OFFRE JOURNÉE — Pass Journée promo (conversion) -->
  <OffreJournee lang={lang} />

    <!-- 8. HISTOIRE — Le lieu comme 4ème personnage (storytelling) -->
    <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite overflow-hidden">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
                <!-- Image -->
                <div class="order-2 lg:order-1" data-reveal>
                    <div class="relative group cursor-pointer" data-riquet-container>
                        <img
                                src="/images/heroes/riquet.webp"
                                alt="Portrait de Pierre-Paul Riquet, créateur du Canal du Midi et du lac de Saint-Ferréol"
                                class="aspect-[4/5] w-full rounded-2xl object-cover"
                                loading="lazy"
                                data-raw
                        />
                        <img
                                src="/images/heroes/riquet-wink.webp"
                                alt="Pierre-Paul Riquet fait un clin d'œil"
                                class="absolute inset-0 aspect-[4/5] w-full rounded-2xl object-cover opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                                data-raw
                        />
                        <!-- Sunburst decoration — top left -->
                        <div class="absolute -top-[12%] -left-[12%] w-[clamp(120px,30%,200px)] aspect-square z-20" data-riquet-sunburst>
                            <Sunburst variant={2} size="100%" />
                        </div>
                        <!-- Decorative frame offset -->
                        <div class="absolute -inset-3 border border-brun-terre/8 rounded-3xl -z-10" aria-hidden="true"></div>
                    </div>
                </div>
                <!-- Text -->
                <div class="order-1 lg:order-2" data-reveal>
                    <p class="section-eyebrow text-brun-terre/30 mb-6">{tx('history.eyebrow')}</p>
                    <h2 class="font-heading text-3xl lg:text-5xl font-bold mb-8 leading-tight text-brun-terre">
                        {tx('history.title')}
                    </h2>
                    <p class="text-xl text-brun-terre/80 font-medium mb-6 leading-relaxed">
                        {tx('history.intro')}
                    </p>
                    <p class="text-gray-600 leading-relaxed mb-8">
                        {tx('history.body')}
                    </p>
                    <p class="text-gray-500 leading-relaxed italic border-l-2 border-aventure/30 pl-6">
                        {tx('history.closing')}
                    </p>
                </div>
            </div>
        </div>
    </section>

  <!-- 9. À PROXIMITÉ — Nearby places of interest -->
    <NearbySection lang={lang} />


  <!-- Riquet sunburst: rotate on hover -->
  <script>
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const container = document.querySelector<HTMLElement>('[data-riquet-container]');
      const sunburst = document.querySelector<HTMLElement>('[data-riquet-sunburst]');

      if (container && sunburst) {
        container.addEventListener('mouseenter', () => {
          import('gsap').then(({ gsap }) => {
            gsap.to(sunburst, { rotation: '+=120', duration: 1.2, ease: 'power2.out' });
          });
        });
      }
    }
  </script>

  <!-- 9. CTA FINAL — warm, saturated photo CTA -->
  <section
    class="relative py-(--spacing-section-mobile) lg:py-32 text-white overflow-hidden bg-cover bg-center"
    style="background-image: url('/images/heroes/contact.webp');"
  >
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(22, 163, 74, 0.7) 0%, rgba(45, 38, 32, 0.75) 100%);" />
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10" data-reveal>
      <p class="section-eyebrow text-white/40 mb-6">{tx('cta.eyebrow')}</p>
      <h2 class="font-heading text-3xl lg:text-5xl font-bold mb-6 leading-tight">
        {tx('cta.title')}
      </h2>
      <p class="text-white/60 text-lg mb-10 max-w-xl mx-auto">
        {tx('cta.subtitle')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/agenda', lang)} class="inline-flex items-center gap-2 bg-soleil text-brun-terre px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
          {t('home.hero.ctaAgenda')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center border border-white/30 text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/50 transition-all">
          {t('home.hero.ctaContact')}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
