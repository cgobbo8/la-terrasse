---
/**
 * HOMEPAGE — Narrative lieu-first
 * 1. Hero = Saint-Ferréol, le lac, l'atmosphère
 * 2. "3 façons de profiter" = les pôles
 * 3. "Une journée à La Terrasse" = section créative immersive
 * 4. Agenda / événements
 * 5. CTA final
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import VideoHero from '@/components/homepage/VideoHero.astro';
import LogoMaskReveal from '@/components/homepage/LogoMaskReveal.svelte';
import PoleDiscovery from '@/components/homepage/PoleDiscovery.astro';
import JourneeTypeTimeline from '@/components/homepage/JourneeTypeTimeline.svelte';
import BentoMeteo from '@/components/homepage/BentoMeteo.astro';
import AgendaSection from '@/components/homepage/AgendaSection.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load Keystatic CMS data
const reader = createReader(process.cwd(), keystaticConfig);
const settings = await reader.singletons.settings.read() ?? {};
const allEvents = await reader.collections.events.all();

const timeBlocks = [
  {
    time: '9h30',
    title: t('home.dayTrip.block1.title'),
    description: t('home.dayTrip.block1.description'),
    image: '/images/journee/kayak.webp',
    href: getLocalizedPath('/aventure', lang),
    poleAccent: '#537b47',
  },
  {
    time: '12h30',
    title: t('home.dayTrip.block2.title'),
    description: t('home.dayTrip.block2.description'),
    image: '/images/journee/dejeuner.webp',
    href: getLocalizedPath('/restaurant', lang),
    poleAccent: '#2D2B1B',
  },
  {
    time: '14h30',
    title: t('home.dayTrip.block3.title'),
    description: t('home.dayTrip.block3.description'),
    image: '/images/journee/paddle.webp',
    href: getLocalizedPath('/aventure', lang),
    poleAccent: '#537b47',
  },
  {
    time: '17h00',
    title: t('home.dayTrip.block4.title'),
    description: t('home.dayTrip.block4.description'),
    image: '/images/journee/detente.webp',
    href: '#',
    poleAccent: '#2D2B1B',
  },
  {
    time: '19h30',
    title: t('home.dayTrip.block5.title'),
    description: t('home.dayTrip.block5.description'),
    image: '/images/journee/apero.webp',
    href: getLocalizedPath('/restaurant', lang),
    poleAccent: '#2D2B1B',
  },
];
---

<BaseLayout title={t('home.page.title')} description={t('home.page.description')} pagePath="/">
  <!-- 0. INTRO — Logo mask reveal (first visit only) -->
  <script is:inline>
    // Prevent flash: hide overlay immediately for return visitors (before Svelte hydrates)
    if (sessionStorage.getItem('la-terrasse-intro-seen')) {
      document.documentElement.classList.add('intro-seen');
    }
  </script>
  <noscript>
    <style>
      .logo-reveal-overlay { display: none !important; }
    </style>
  </noscript>
  <LogoMaskReveal client:only="svelte" />

  <!-- 1. HERO — Le lieu (vidéo plein écran) -->
  <VideoHero tagline={t('home.hero.tagline')} subtitle={t('home.hero.subtitle')}>
    <div class="flex flex-wrap gap-4">
      <a href={getLocalizedPath('/restaurant', lang)} class="bg-white text-brun-terre px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
        {t('nav.restaurant')}
      </a>
      <a href={getLocalizedPath('/aventure', lang)} class="bg-white/20 text-white border border-white/30 px-6 py-3 rounded-lg font-medium hover:bg-white/30 transition-colors">
        {t('nav.aventure')}
      </a>
      <a href={getLocalizedPath('/la-salle', lang)} class="bg-white/20 text-white border border-white/30 px-6 py-3 rounded-lg font-medium hover:bg-white/30 transition-colors">
        {t('nav.salle')}
      </a>
    </div>
  </VideoHero>

  <!-- 2. TROIS FAÇONS DE PROFITER — Les pôles -->
  <PoleDiscovery lang={lang} />

  <!-- 3. HISTOIRE — Le lieu comme 4ème personnage -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-brun-terre text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-center">
        <!-- Texte -->
        <div class="lg:col-span-3">
          <h2 class="font-heading text-3xl lg:text-4xl font-bold mb-6">
            {t('home.history.title')}
          </h2>
          <p class="text-xl text-white/90 font-medium mb-4">
            {t('home.history.intro')}
          </p>
          <p class="text-white/70 leading-relaxed mb-6">
            {t('home.history.body')}
          </p>
          <p class="text-white/80 leading-relaxed italic">
            {t('home.history.closing')}
          </p>
        </div>
        <!-- Image historique du lac -->
        <div class="lg:col-span-2">
          <img
            src="/images/placeholders/claudia-chiavazza.webp"
            alt="Le lac de Saint-Ferréol"
            class="aspect-[3/4] w-full rounded-2xl object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 4. UNE JOURNÉE À LA TERRASSE — Pièce créative (Svelte island) -->
  <JourneeTypeTimeline
    client:only="svelte"
    timeBlocks={timeBlocks}
    lang={lang}
    sectionTitle={t('home.dayTrip.title')}
    ctaLabel={t('home.dayTrip.cta')}
  />

  <!-- 5. INFOS PRATIQUES — Bento grid -->
  <BentoMeteo settings={settings} lang={lang} />

  <!-- 6. AGENDA — Les rendez-vous -->
  <AgendaSection events={allEvents} lang={lang} />

  <!-- 7. CTA FINAL -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-brun-terre text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl lg:text-4xl font-bold mb-8">
        {t('home.cta.title')}
      </h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/restaurant', lang)} class="bg-white text-brun-terre px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
          {t('nav.restaurant')}
        </a>
        <a href={getLocalizedPath('/aventure', lang)} class="border border-white/30 px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors">
          {t('nav.aventure')}
        </a>
        <a href={getLocalizedPath('/la-salle', lang)} class="border border-white/30 px-6 py-3 rounded-lg font-medium hover:bg-white/10 transition-colors">
          {t('nav.salle')}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
