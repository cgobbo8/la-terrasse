---
/**
 * PAGE CONTACT — Coordonnées, horaires, carte et accès
 * Brand-mother neutral styling (no pole-specific theming)
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { generateLocalBusinessLD } from '@/lib/seo';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const phone = '05 61 83 XX XX';
const phoneTel = '+33561830000';
const email = 'contact@baseloisirs-saintferreol.fr';
const googleMapsEmbedUrl = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5780.5!2d2.0505!3d43.4504!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDI3JzAxLjQiTiAywrAwMycwMS44IkU!5e0!3m2!1sfr!2sfr!4v1';
const googleMapsUrl = 'https://maps.google.com/?q=Lac+de+Saint-Ferr%C3%A9ol';

const jsonLd = generateLocalBusinessLD();
---

<BaseLayout
  title={t('contact.page.title')}
  description={t('contact.page.description')}
  jsonLd={jsonLd}
  pagePath="/contact"
  ctaLabel={phone}
  ctaHref={`tel:${phoneTel}`}
  ctaIcon={true}
>
  <SectionHero
    tagline={t('contact.hero.tagline')}
    subtitle={t('contact.hero.subtitle')}
    image="/images/heroes/contact.webp"
  />

  <!-- Contact info + Hours + Map -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Left column: Contact info + Hours -->
        <div class="space-y-10" data-reveal>
          <!-- Contact details -->
          <div>
            <p class="section-eyebrow text-brun-terre/60 mb-3">{t('common.contact')}</p>
            <h2 class="font-heading text-2xl font-bold text-brun-terre mb-8">
              {t('contact.info.title')}
            </h2>
            <div class="space-y-5">
              <!-- Phone -->
              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-200/60 bg-white">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brun-terre/8 flex items-center justify-center">
                  <Icon name="lucide:phone" class="w-5 h-5 text-brun-terre" stroke-width="1.5" />
                </div>
                <div>
                  <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">{t('common.phone')}</p>
                  <a
                    href={`tel:${phoneTel}`}
                    class="text-xl font-bold text-brun-terre hover:text-brun-terre/80 transition-colors min-h-[44px] inline-flex items-center"
                  >
                    {phone}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-200/60 bg-white">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brun-terre/8 flex items-center justify-center">
                  <Icon name="lucide:mail" class="w-5 h-5 text-brun-terre" stroke-width="1.5" />
                </div>
                <div>
                  <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">{t('common.email')}</p>
                  <a
                    href={`mailto:${email}`}
                    class="text-base font-medium text-brun-terre hover:text-brun-terre/80 transition-colors min-h-[44px] inline-flex items-center break-all"
                  >
                    {email}
                  </a>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4 p-4 rounded-xl border border-gray-200/60 bg-white">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brun-terre/8 flex items-center justify-center">
                  <Icon name="lucide:map-pin" class="w-5 h-5 text-brun-terre" stroke-width="1.5" />
                </div>
                <div>
                  <p class="text-xs font-medium text-gray-400 uppercase tracking-wider mb-1">{t('common.address')}</p>
                  <p class="text-gray-800 font-medium">{t('contact.info.name')}</p>
                  <p class="text-gray-600 text-sm">{t('contact.info.address')}</p>
                  <p class="text-gray-600 text-sm">{t('contact.info.city')}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Opening hours -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-brun-terre mb-6">
              {t('contact.hours.title')}
            </h2>
            <div class="space-y-4">
              <!-- Seasons -->
              <div class="rounded-xl p-6 border border-gray-200/60 bg-white">
                <h3 class="section-eyebrow text-gray-400 mb-4">Saison</h3>
                <div class="space-y-2">
                  <div class="flex justify-between items-center py-2.5 border-b border-gray-100">
                    <span class="text-gray-800 font-medium">Mai & septembre</span>
                    <span class="text-brun-terre font-bold text-sm">Weekends & jours fériés</span>
                  </div>
                  <div class="flex justify-between items-center py-2.5">
                    <span class="text-gray-800 font-medium">Juin, juillet, août</span>
                    <span class="text-brun-terre font-bold text-sm">Tous les jours</span>
                  </div>
                </div>
              </div>
              <!-- Horaires -->
              <div class="rounded-xl p-6 border border-gray-200/60 bg-white">
                <h3 class="section-eyebrow text-gray-400 mb-4">Horaires</h3>
                <div class="space-y-2">
                  <div class="flex justify-between items-center py-2.5 border-b border-gray-100">
                    <span class="text-gray-800 font-medium flex items-center gap-2">
                      <Icon name="lucide:mountain" class="w-4 h-4 text-aventure" />
                      Activités
                    </span>
                    <span class="text-brun-terre font-bold">10h – 19h</span>
                  </div>
                  <div class="flex justify-between items-center py-2.5">
                    <span class="text-gray-800 font-medium flex items-center gap-2">
                      <Icon name="lucide:utensils" class="w-4 h-4 text-restaurant" />
                      Restaurant
                    </span>
                    <span class="text-brun-terre font-bold">9h – 22h</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right column: Map -->
        <div data-reveal>
          <p class="section-eyebrow text-brun-terre/60 mb-3">{t('contact.map.title')}</p>
          <h2 class="font-heading text-2xl font-bold text-brun-terre mb-6">
            {t('contact.map.title')}
          </h2>
          <div class="rounded-2xl overflow-hidden border border-gray-200/60">
            <iframe
              src={googleMapsEmbedUrl}
              title={t('contact.map.title')}
              class="w-full h-[300px] lg:h-[450px] border-0"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 mt-4 text-brun-terre font-medium hover:text-brun-terre/80 transition-colors min-h-[44px]"
          >
            <Icon name="lucide:external-link" class="w-4 h-4" />
            {t('contact.map.fallback')}
            <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Directions -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-reveal>
        <p class="section-eyebrow text-brun-terre/60 mb-3">Accès</p>
        <h2 class="font-heading text-3xl font-bold text-brun-terre">
          {t('contact.directions.title')}
        </h2>
      </div>

      <!-- Distance callout -->
      <div class="flex flex-wrap justify-center gap-4 mb-12" data-reveal>
        <div class="rounded-full px-6 py-3 border border-gray-200/60 bg-white text-center">
          <p class="text-lg font-bold text-brun-terre">{t('contact.directions.distance')}</p>
        </div>
        <div class="rounded-full px-6 py-3 border border-gray-200/60 bg-white text-center">
          <p class="text-lg font-bold text-brun-terre">{t('contact.directions.duration')}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-reveal-stagger>
        <!-- Car -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-brun-terre/8 flex items-center justify-center mb-5">
            <Icon name="lucide:car" class="w-5 h-5 text-brun-terre" stroke-width="1.5" />
          </div>
          <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{t('contact.directions.car')}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{t('contact.directions.carDesc')}</p>
        </div>

        <!-- Parking -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-brun-terre/8 flex items-center justify-center mb-5">
            <Icon name="lucide:square-parking" class="w-5 h-5 text-brun-terre" stroke-width="1.5" />
          </div>
          <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{t('contact.directions.parking')}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{t('contact.directions.parkingDesc')}</p>
        </div>

        <!-- Public transport -->
        <div class="bg-white rounded-2xl p-6 border border-gray-200/60 hover:border-gray-300/80 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-brun-terre/8 flex items-center justify-center mb-5">
            <Icon name="lucide:globe" class="w-5 h-5 text-brun-terre" stroke-width="1.5" />
          </div>
          <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{t('contact.directions.transport')}</h3>
          <p class="text-gray-600 text-sm leading-relaxed">{t('contact.directions.transportDesc')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
