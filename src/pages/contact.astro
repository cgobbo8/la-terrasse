---
/**
 * PAGE CONTACT — Coordonnées, horaires, carte et accès
 * Brand-mother neutral styling (no pole-specific theming)
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { generateLocalBusinessLD } from '@/lib/seo';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const phone = '05 61 83 XX XX';
const phoneTel = '+33561830000';
const email = 'contact@laterrasse-saintferreol.fr';
const googleMapsEmbedUrl = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5780.5!2d2.0505!3d43.4504!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDPCsDI3JzAxLjQiTiAywrAwMycwMS44IkU!5e0!3m2!1sfr!2sfr!4v1';
const googleMapsUrl = 'https://maps.google.com/?q=Lac+de+Saint-Ferr%C3%A9ol';

const jsonLd = generateLocalBusinessLD();
---

<BaseLayout
  title={t('contact.page.title')}
  description={t('contact.page.description')}
  jsonLd={jsonLd}
  pagePath="/contact"
>
  <SectionHero
    tagline={t('contact.hero.tagline')}
    subtitle={t('contact.hero.subtitle')}
    image="/images/placeholders/dirk-von-loen-wagner.webp"
  />

  <!-- Contact info + Hours + Map -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Left column: Contact info + Hours -->
        <div class="space-y-10">
          <!-- Contact details -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-brun-terre mb-6">
              {t('contact.info.title')}
            </h2>
            <div class="space-y-5">
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brun-terre/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-400 mb-1">{t('common.phone')}</p>
                  <a
                    href={`tel:${phoneTel}`}
                    class="text-2xl font-bold text-brun-terre hover:text-brun-terre/80 transition-colors min-h-[44px] inline-flex items-center"
                  >
                    {phone}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brun-terre/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-400 mb-1">{t('common.email')}</p>
                  <a
                    href={`mailto:${email}`}
                    class="text-lg font-medium text-brun-terre hover:text-brun-terre/80 transition-colors min-h-[44px] inline-flex items-center break-all"
                  >
                    {email}
                  </a>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-brun-terre/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm font-medium text-gray-400 mb-1">{t('common.address')}</p>
                  <p class="text-gray-800 font-medium">{t('contact.info.name')}</p>
                  <p class="text-gray-600">{t('contact.info.address')}</p>
                  <p class="text-gray-600">{t('contact.info.city')}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Opening hours -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-brun-terre mb-6">
              {t('contact.hours.title')}
            </h2>
            <div class="bg-offwhite rounded-xl p-6">
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-200">
                  <span class="text-gray-800 font-medium">{t('contact.hours.monFri')}</span>
                  <span class="text-brun-terre font-bold">{t('contact.hours.monFriTime')}</span>
                </div>
                <div class="flex justify-between items-center py-2">
                  <span class="text-gray-800 font-medium">{t('contact.hours.satSun')}</span>
                  <span class="text-brun-terre font-bold">{t('contact.hours.satSunTime')}</span>
                </div>
              </div>
              <p class="text-sm text-gray-400 mt-4">{t('contact.hours.note')}</p>
            </div>
          </div>
        </div>

        <!-- Right column: Map -->
        <div>
          <h2 class="font-heading text-2xl font-bold text-brun-terre mb-6">
            {t('contact.map.title')}
          </h2>
          <div class="rounded-xl overflow-hidden shadow-sm">
            <iframe
              src={googleMapsEmbedUrl}
              title={t('contact.map.title')}
              class="w-full h-[300px] lg:h-[400px] border-0"
              loading="lazy"
              allowfullscreen
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
          <a
            href={googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-4 text-brun-terre font-medium hover:text-brun-terre/80 transition-colors min-h-[44px]"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
            {t('contact.map.fallback')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Directions -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-brun-terre text-center mb-12">
        {t('contact.directions.title')}
      </h2>

      <!-- Distance callout -->
      <div class="flex flex-wrap justify-center gap-6 mb-12">
        <div class="bg-white rounded-xl px-6 py-4 shadow-sm text-center">
          <p class="text-2xl font-bold text-brun-terre">{t('contact.directions.distance')}</p>
        </div>
        <div class="bg-white rounded-xl px-6 py-4 shadow-sm text-center">
          <p class="text-2xl font-bold text-brun-terre">{t('contact.directions.duration')}</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Car -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-10 h-10 rounded-full bg-brun-terre/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{t('contact.directions.car')}</h3>
          <p class="text-gray-600 text-sm">{t('contact.directions.carDesc')}</p>
        </div>

        <!-- Parking -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-10 h-10 rounded-full bg-brun-terre/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m0-6H15a3 3 0 0 1 0 6H9m-6 6h18a2.25 2.25 0 0 0 2.25-2.25V5.25A2.25 2.25 0 0 0 21 3H3A2.25 2.25 0 0 0 .75 5.25v13.5A2.25 2.25 0 0 0 3 21Z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{t('contact.directions.parking')}</h3>
          <p class="text-gray-600 text-sm">{t('contact.directions.parkingDesc')}</p>
        </div>

        <!-- Public transport -->
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <div class="w-10 h-10 rounded-full bg-brun-terre/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{t('contact.directions.transport')}</h3>
          <p class="text-gray-600 text-sm">{t('contact.directions.transportDesc')}</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
