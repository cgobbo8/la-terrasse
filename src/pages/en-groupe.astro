---
/**
 * PAGE TRANSVERSALE — En Groupe
 * Cross-pole page: group activities + dining + phone CTA + journée type
 * Brand-mother neutral styling (brun terre headings)
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import JourneeTypeSection from '@/components/common/JourneeTypeSection.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const PHONE_NUMBER = '+33 5 XX XX XX XX';
const PHONE_TEL = 'tel:+335XXXXXXXX';

const journeeTypeSteps = [
  { time: '9h30', title: 'Accueil du groupe', description: 'Installation et briefing des activités de la journée.', pole: undefined },
  { time: '10h00', title: 'Activité sportive ou ludique', description: 'Archery tag, course d\'orientation, canoë... au choix selon le groupe.', pole: 'aventure' as const },
  { time: '12h30', title: 'Repas de groupe au restaurant', description: 'Menu convivial avec produits locaux, adapté à la taille du groupe.', pole: 'restaurant' as const },
  { time: '14h30', title: 'Deuxième activité ou temps libre', description: 'Pédalo, paddle, mini-golf ou balade autour du lac.', pole: 'aventure' as const },
];

const groupOfferings = [
  {
    title: 'Activités de groupe',
    description: 'De 10 à 50 personnes : archery tag, course d\'orientation, canoë, paddle, mini-golf... Des activités adaptées à tous les niveaux.',
    ctaText: t('groupe.offerings.ctaActivities'),
    ctaHref: getLocalizedPath('/aventure', lang),
    poleAccent: '#537b47',
  },
  {
    title: 'Repas de groupe',
    description: 'Menu convivial adapté à la taille de votre groupe. Produits locaux, terrasse privatisable avec vue sur le lac.',
    ctaText: t('groupe.offerings.ctaRestaurant'),
    ctaHref: getLocalizedPath('/restaurant', lang),
    poleAccent: '#2D2B1B',
  },
  {
    title: 'Journée complète',
    description: 'Combinez activités et repas pour une journée clé en main. On s\'occupe de tout, vous profitez.',
    ctaText: t('groupe.offerings.ctaContact'),
    ctaHref: PHONE_TEL,
    poleAccent: '#2D2B1B',
  },
];
---

<BaseLayout title={t('groupe.page.title')} description={t('groupe.hero.tagline')} pagePath="/en-groupe">
  <SectionHero tagline={t('groupe.hero.tagline')} subtitle={t('groupe.hero.subtitle')}>
    <a href={PHONE_TEL} class="bg-white text-brun-terre px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
      {t('groupe.hero.cta')}
    </a>
  </SectionHero>

  <!-- Phone callout — high visibility -->
  <section class="py-12 lg:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-offwhite rounded-2xl p-8 lg:p-12 text-center">
        <p class="text-gray-600 text-lg mb-3">{t('groupe.phone.label')}</p>
        <a
          href={PHONE_TEL}
          class="block font-heading text-3xl lg:text-4xl font-bold text-brun-terre hover:underline transition-colors"
        >
          {PHONE_NUMBER}
        </a>
        <p class="text-gray-600 mt-3">
          {t('groupe.phone.subtitle')}
        </p>
      </div>
    </div>
  </section>

  <!-- Journée type groupe -->
  <JourneeTypeSection
    title={t('groupe.journee.title')}
    steps={journeeTypeSteps}
  />

  <!-- Offres groupe -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-brun-terre text-center mb-4">
        {t('groupe.offerings.title')}
      </h2>
      <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12">
        {t('groupe.offerings.intro')}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {groupOfferings.map((offering) => (
          <div class="bg-white rounded-xl p-6 shadow-sm">
            <div class="w-10 h-1 rounded-full mb-4" style={`background-color: ${offering.poleAccent}`} />
            <h3 class="font-heading font-bold text-brun-terre text-lg mb-2">{offering.title}</h3>
            <p class="text-gray-600 text-sm mb-6">{offering.description}</p>
            <a
              href={offering.ctaHref}
              class="inline-block text-sm font-medium hover:underline transition-colors"
              style={`color: ${offering.poleAccent}`}
            >
              {offering.ctaText} →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing indication -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold text-brun-terre mb-4">
        {t('groupe.pricing.title')}
      </h2>
      <p class="text-gray-600 mb-2">
        {t('groupe.pricing.desc')}
      </p>
      <p class="font-heading text-2xl font-bold text-brun-terre mb-6">
        {t('groupe.pricing.price')}
      </p>
      <p class="text-gray-500 text-sm mb-8">
        {t('groupe.pricing.note')}
      </p>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold text-brun-terre mb-6">
        {t('groupe.cta.title')}
      </h2>
      <a href={PHONE_TEL} class="inline-block bg-brun-terre text-white px-8 py-4 rounded-lg font-medium text-lg hover:bg-brun-terre/90 transition-colors">
        {t('groupe.cta.button')}
      </a>
    </div>
  </section>
</BaseLayout>
