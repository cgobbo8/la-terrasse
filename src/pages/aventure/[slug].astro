---
/**
 * Activity detail page — dynamic route for each Keystatic activity.
 * Pole: Aventure — accent from poleConfigs
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import ActivityPrevNext from '@/components/aventure/ActivityPrevNext.astro';
import AlternativeSuggestions from '@/components/aventure/AlternativeSuggestions.astro';
import { getLangFromUrl, useTranslations, getLocalizedField, getLocalizedPath } from '@/i18n/utils';
import { poleConfigs } from '@/lib/pole-config';
import { getSiteSettings, toTelHref } from '@/lib/site-settings';
import { generateSportsActivityLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

export async function getStaticPaths() {
  const reader = createReader(process.cwd(), keystaticConfig);
  const allActivities = await reader.collections.activities.all();

  const visible = allActivities
    .filter((a) => a.entry.visible)
    .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

  const activitiesList = visible.map((a) => ({
    title: a.entry.title,
    slug: a.slug,
    price: a.entry.price ?? '',
    priceDetails: a.entry.priceDetails ?? '',
    priceDetails_en: a.entry.priceDetails_en ?? '',
    priceDetails_es: a.entry.priceDetails_es ?? '',
    age_min: a.entry.age_min ?? 0,
    duration: a.entry.duration ?? '',
    image: a.entry.image ?? null,
    description: a.entry.description ?? '',
    category: a.entry.category ?? 'terrestre',
    title_en: a.entry.title_en ?? '',
    title_es: a.entry.title_es ?? '',
    description_en: a.entry.description_en ?? '',
    description_es: a.entry.description_es ?? '',
    priceTiers: (a.entry as any).priceTiers ?? [],
    isPremium: (a.entry as any).isPremium ?? false,
  }));

  return visible.map((activity) => ({
    params: { slug: activity.slug },
    props: {
      activity: { slug: activity.slug, ...activity.entry },
      allActivities: activitiesList,
    },
  }));
}

const { activity, allActivities } = Astro.props;
const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);
const pole = poleConfigs.aventure;
const siteSettings = await getSiteSettings();
const telHref = toTelHref(siteSettings?.phone ?? '');

const localizedTitle = getLocalizedField(activity, 'title', lang);
const localizedDescription = getLocalizedField(activity, 'description', lang);
const localizedPriceDetails = getLocalizedField(activity, 'priceDetails', lang);

// Load compiled MDX content
// FR files only — eager (10 files, fast)
const mdxModules = import.meta.glob<{ Content: any }>('/src/content/activities/*.mdx', { eager: true });
// Locale files — lazy (only the one needed is loaded per page)
const localeMdxModules = import.meta.glob<{ Content: any }>('/src/content/activities/locales/*.mdx');

let Content: any = undefined;
if (lang !== 'fr') {
  const localeKey = `/src/content/activities/locales/${activity.slug}.${lang}.mdx`;
  if (localeMdxModules[localeKey]) {
    const mod = await localeMdxModules[localeKey]();
    Content = mod.Content;
  }
}
if (!Content) {
  Content = mdxModules[`/src/content/activities/${activity.slug}.mdx`]?.Content;
}

// Placeholder images — cycled by slug hash for consistency
const placeholderImages = [
  '/images/placeholders/pietro-de-grandi.webp',
  '/images/placeholders/cristian-negraia.webp',
  '/images/placeholders/daniel-jacob.webp',
  '/images/placeholders/dirk-von-loen-wagner.webp',
  '/images/placeholders/nils-lindner.webp',
  '/images/placeholders/claudia-chiavazza.webp',
];
const placeholderIndex = activity.slug.length % placeholderImages.length;
const heroImage = activity.image || placeholderImages[placeholderIndex];

// Narrative cross-link text per activity (unique per page, never generic)
const crossLinkTexts: Record<string, string> = {
  paddle: t('crosslink.activity.paddle.restaurant'),
  'archery-tag': t('crosslink.activity.archeryTag.restaurant'),
  pedalo: t('crosslink.activity.pedalo.restaurant'),
  canoe: t('crosslink.activity.canoe.restaurant'),
  vtt: t('crosslink.activity.vtt.restaurant'),
  'mini-golf': t('crosslink.activity.miniGolf.restaurant'),
};
const crossLinkText = crossLinkTexts[activity.slug] ?? t('crosslink.activityDefault.restaurant');

// SEO
const siteUrl = 'https://baseloisirs-saintferreol.fr';
const seoTitle = `${localizedTitle} — Aventure | La Terrasse Saint-Ferréol`;
const seoDescription = localizedDescription.slice(0, 155);
const jsonLd = generateSportsActivityLD({
  name: localizedTitle,
  description: localizedDescription,
  url: `${siteUrl}/aventure/${activity.slug}`,
  image: activity.image ? `${siteUrl}${activity.image}` : undefined,
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="aventure"
  jsonLd={jsonLd}
  pagePath={`/aventure/${activity.slug}`}
>
  <!-- Hero Section -->
  <section class="activity-hero relative overflow-hidden -mt-16 min-h-[60vh] lg:min-h-[80vh] flex flex-col">
    <img
      src={heroImage}
      alt={localizedTitle}
      width="1920"
      height="1080"
      class="absolute inset-0 w-full h-full object-cover scale-[1.05]"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
    <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent" />

    <!-- Spacer: compensate for fixed header -->
    <div class="h-16 shrink-0" aria-hidden="true"></div>

    <div class="relative flex-1 flex items-end pb-16 lg:pb-24">
      <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" class="mb-4">
        <a
          href={getLocalizedPath('/aventure', lang)}
          class="section-eyebrow text-white/60 hover:text-white transition-colors"
        >
          {t('nav.aventure')}
        </a>
        <span class="text-white/30 mx-2">›</span>
        <span class="section-eyebrow text-white/80">{localizedTitle}</span>
      </nav>

      <!-- Title -->
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-7xl font-bold text-white max-w-3xl leading-[1.05]">
        {localizedTitle}
      </h1>
      </div>
    </div>
  </section>

  <!-- Accent line below hero -->
  <div class="h-1" style={`background-color: ${pole.accent};`}></div>

  <!-- Practical Info Grid -->
  <section class="py-8 lg:py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      {activity.isPremium && (
        <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl border border-amber-200 bg-amber-50">
          <Icon name="lucide:star" class="w-5 h-5 text-amber-500 flex-shrink-0" />
          <div>
            <span class="text-sm font-bold text-amber-800">Activité phare</span>
            <span class="text-sm text-amber-700 ml-1">— éligible à l'offre Journée à La Terrasse </span>
            <a href={getLocalizedPath('/restaurant', lang) + '#offre'} target="_blank" rel="noopener" class="text-sm font-medium text-amber-800 underline hover:text-amber-900">(−{siteSettings?.passJourneeDiscount ?? 20}% restaurant)</a>
          </div>
        </div>
      )}
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Price (single or multi-tier) -->
        {activity.priceTiers && activity.priceTiers.length > 0 ? (
          <div class="col-span-2 lg:col-span-1 flex flex-col items-center text-center p-4 rounded-xl border border-gray-200/60">
            <Icon name="lucide:euro" class="w-6 h-6 mb-2" style={`color: ${pole.accent};`} />
            <span class="text-xs uppercase tracking-wider text-gray-400 mb-2">{t('common.price')}</span>
            <div class="space-y-1 w-full">
              {activity.priceTiers.map((tier: any) => {
                const tierLabel = lang === 'en' && tier.label_en ? tier.label_en : lang === 'es' && tier.label_es ? tier.label_es : tier.label;
                return (
                  <div class="flex items-center justify-between gap-2 text-sm">
                    <span class="text-gray-600">{tierLabel}</span>
                    <span class="font-bold text-gray-800">{tier.price}</span>
                  </div>
                );
              })}
            </div>
            <span class="text-xs text-gray-500 mt-1">{localizedPriceDetails}</span>
          </div>
        ) : activity.price && (
          <div class="flex flex-col items-center text-center p-4 rounded-xl border border-gray-200/60">
            <Icon name="lucide:euro" class="w-6 h-6 mb-2" style={`color: ${pole.accent};`} />
            <span class="text-xs uppercase tracking-wider text-gray-400 mb-1">{t('common.price')}</span>
            <span class="text-lg font-bold text-gray-800">{activity.price}</span>
            {localizedPriceDetails && (
              <span class="text-xs text-gray-500 mt-0.5">{localizedPriceDetails}</span>
            )}
          </div>
        )}

        <!-- Age -->
        {activity.age_min != null && activity.age_min > 0 && (
          <div class="flex flex-col items-center text-center p-4 rounded-xl border border-gray-200/60">
            <Icon name="lucide:user" class="w-6 h-6 mb-2" style={`color: ${pole.accent};`} />
            <span class="text-xs uppercase tracking-wider text-gray-400 mb-1">{t('aventure.activity.ageLabel')}</span>
            <span class="text-lg font-bold text-gray-800">{t('aventure.activity.ageFrom').replace('{age}', String(activity.age_min))}</span>
          </div>
        )}

        <!-- Duration -->
        {activity.duration && (
          <div class="flex flex-col items-center text-center p-4 rounded-xl border border-gray-200/60">
            <Icon name="lucide:clock" class="w-6 h-6 mb-2" style={`color: ${pole.accent};`} />
            <span class="text-xs uppercase tracking-wider text-gray-400 mb-1">{t('common.duration')}</span>
            <span class="text-lg font-bold text-gray-800">{activity.duration}</span>
          </div>
        )}

        <!-- Group size -->
        {(activity.minPersons || activity.maxPersons) && (
          <div class="flex flex-col items-center text-center p-4 rounded-xl border border-gray-200/60">
            <Icon name="lucide:users" class="w-6 h-6 mb-2" style={`color: ${pole.accent};`} />
            <span class="text-xs uppercase tracking-wider text-gray-400 mb-1">{t('aventure.activity.groupLabel')}</span>
            <span class="text-lg font-bold text-gray-800">
              {activity.minPersons && activity.maxPersons
                ? `${activity.minPersons}–${activity.maxPersons}`
                : activity.maxPersons
                  ? `Max ${activity.maxPersons}`
                  : `Min ${activity.minPersons}`
              } {t('common.persons')}
            </span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- MDX Body Content + Sticky CTA layout -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
        <!-- MDX Content -->
        <div class="prose prose-lg max-w-[768px] mx-auto lg:mx-0">
          {Content ? (
            <Content />
          ) : (
            <p class="text-gray-600">{localizedDescription}</p>
          )}
        </div>

        <!-- Desktop Sticky CTA Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <div class="rounded-2xl border border-gray-200/60 bg-white p-6 text-center">
              <p class="text-sm text-gray-600 mb-4">
                {localizedDescription}
              </p>
              {activity.priceTiers && activity.priceTiers.length > 0 ? (
                <div class="mb-4 space-y-1">
                  {activity.priceTiers.map((tier: any) => {
                    const tierLabel = lang === 'en' && tier.label_en ? tier.label_en : lang === 'es' && tier.label_es ? tier.label_es : tier.label;
                    return (
                      <div class="flex items-center justify-between text-sm">
                        <span class="text-gray-600">{tierLabel}</span>
                        <span class="text-lg font-bold" style={`color: ${pole.accent};`}>{tier.price}</span>
                      </div>
                    );
                  })}
                  <p class="text-xs text-gray-500">{localizedPriceDetails}</p>
                </div>
              ) : activity.price && (
                <p class="text-2xl font-bold mb-4" style={`color: ${pole.accent};`}>
                  {activity.price}
                </p>
              )}
              <a
                href={telHref}
                class="block w-full py-3.5 px-7 rounded-full text-white font-heading font-semibold text-sm text-center transition-all hover:shadow-lg hover:-translate-y-px"
                style={`background-color: ${pole.accent};`}
              >
                {t('aventure.cta.label')}
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Divider + Lateral Navigation -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <hr class="border-gray-200" />
  </div>

  <div class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <ActivityPrevNext currentSlug={activity.slug} activities={allActivities} lang={lang} />
  </div>

  <!-- Alternative Suggestions -->
  <AlternativeSuggestions currentSlug={activity.slug} activities={allActivities} lang={lang} />

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={crossLinkText}
    href={getLocalizedPath('/restaurant', lang)}
    pole="restaurant"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="aventure" />

  <!-- Mobile Sticky Bottom CTA -->
  <div class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-white border-t border-gray-200 px-4 py-3 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
    <a
      href={telHref}
      class="block w-full py-3.5 rounded-full text-white font-heading font-semibold text-sm text-center transition-all hover:shadow-lg hover:-translate-y-px"
      style={`background-color: ${pole.accent};`}
    >
      {t('aventure.cta.label')}
    </a>
  </div>

  <!-- Bottom padding to account for sticky mobile CTA -->
  <div class="lg:hidden h-16"></div>
</BaseLayout>

<style>
  .prose {
    line-height: 1.75;
    color: var(--color-gray-800);
  }
  .prose :global(h2) {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-black);
  }
  .prose :global(h3) {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-black);
  }
  .prose :global(p) {
    margin-bottom: 1rem;
  }
  .prose :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose :global(li) {
    margin-bottom: 0.25rem;
  }
  .prose :global(strong) {
    font-weight: 700;
  }
  .prose :global(a) {
    color: var(--color-aventure);
    text-decoration: underline;
  }
</style>
