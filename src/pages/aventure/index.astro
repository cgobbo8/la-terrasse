---
/**
 * AVENTURE HUB — Vert végétal
 * Tone: dynamique, fun, familial
 * Displays all activities from Keystatic collection
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import ActivityCard from '@/components/aventure/ActivityCard.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs } from '@/lib/pole-config';
import { generateSportsActivityLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pole = poleConfigs.aventure;

// Load activities from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const allActivities = await reader.collections.activities.all();

// Filter visible, sort by order
const activities = allActivities
  .filter((a) => a.entry.visible)
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

// Placeholder images — cycled across activity cards
const placeholderImages = [
  '/images/placeholders/pietro-de-grandi.webp',
  '/images/placeholders/cristian-negraia.webp',
  '/images/placeholders/daniel-jacob.webp',
  '/images/placeholders/dirk-von-loen-wagner.webp',
  '/images/placeholders/nils-lindner.webp',
  '/images/placeholders/claudia-chiavazza.webp',
  '/images/placeholders/emma-harper.webp',
];

// Generate JSON-LD for SportsActivityLocation
const siteUrl = 'https://laterrasse-saintferreol.fr';
const jsonLd = generateSportsActivityLD({
  name: 'Aventure — Activités plein air | La Terrasse Saint-Ferréol',
  description: t('aventure.hero.subtitle'),
  url: `${siteUrl}/aventure`,
});

const seoTitle = 'Aventure — Activités plein air | La Terrasse Saint-Ferréol';
const seoDescription = 'Découvrez toutes les activités plein air au lac de Saint-Ferréol : pédalo, paddle, canoë, mini-golf, vélo, archery tag et plus. Activités lac Saint-Ferréol pour toute la famille.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="aventure"
  jsonLd={jsonLd}
>
  <!-- Hero — 70vh desktop / 50vh mobile -->
  <section class="relative overflow-hidden" style={`background-color: ${pole.accent}`}>
    <img
      src="/images/placeholders/pietro-de-grandi.webp"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent" />

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col justify-end h-[50vh] lg:h-[70vh] pb-12 lg:pb-16">
      <h1 class="font-heading text-4xl lg:text-6xl font-bold text-white">
        Aventure
      </h1>
      <p class="mt-4 text-lg lg:text-xl text-white/80 max-w-2xl">
        {t('aventure.hero.tagline')}
      </p>
    </div>
  </section>

  <!-- Activity Grid -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {activities.map((activity, i) => (
          <ActivityCard
            activity={{
              title: activity.entry.title,
              slug: activity.slug,
              price: activity.entry.price ?? '',
              age_min: activity.entry.age_min ?? 0,
              duration: activity.entry.duration ?? '',
              image: activity.entry.image ?? null,
              description: activity.entry.description ?? '',
              title_en: activity.entry.title_en ?? '',
              title_es: activity.entry.title_es ?? '',
              description_en: activity.entry.description_en ?? '',
              description_es: activity.entry.description_es ?? '',
            }}
            lang={lang}
            placeholderImage={placeholderImages[i % placeholderImages.length]}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section groupes -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)" style={`background-color: ${pole.light}`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold mb-4" style={`color: ${pole.accent}`}>
        {t('aventure.groups.title')}
      </h2>
      <p class="text-gray-600 mb-6">
        Organisez une sortie de groupe — activités personnalisées pour entreprises, associations, écoles et groupes d'amis.
      </p>
      <p class="text-gray-500 italic mb-6">
        {t('aventure.groups.cta')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={getLocalizedPath('/en-groupe', lang)}
          class="text-white px-6 py-3 rounded-lg font-medium transition-colors"
          style={`background-color: ${pole.accent}`}
        >
          Sortie de groupe
        </a>
        <a
          href={getLocalizedPath('/contact', lang)}
          class="px-6 py-3 rounded-lg font-medium transition-colors"
          style={`border: 1px solid ${pole.accent}; color: ${pole.accent}`}
        >
          {t('common.contact')}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-sell contextuel -->
  <section class="py-8 bg-restaurant-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 italic">{t('aventure.afterActivity')}</p>
      <a href={getLocalizedPath('/restaurant', lang)} class="inline-block mt-2 text-restaurant font-medium hover:underline">
        Découvrir le restaurant →
      </a>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="aventure" />
</BaseLayout>
