---
/**
 * AVENTURE HUB — Vert végétal
 * Tone: dynamique, fun, familial
 * Fiches navigables avec suggestions d'alternatives
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import ActivityCard from '@/components/aventure/ActivityCard.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { generateSportsActivityLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Load activities from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const allActivities = await reader.collections.activities.all();

// Filter visible, sort by order, split by category
const visible = allActivities
  .filter((a) => a.entry.visible)
  .sort((a, b) => (a.entry.order ?? 0) - (b.entry.order ?? 0));

const aquatiques = visible.filter((a) => a.entry.category === 'aquatique');
const terrestres = visible.filter((a) => a.entry.category === 'terrestre');

// Placeholder images — cycled across activity cards per category
const aquaticImages = [
  '/images/placeholders/pietro-de-grandi.webp',
  '/images/placeholders/cristian-negraia.webp',
  '/images/placeholders/daniel-jacob.webp',
];
const terrestreImages = [
  '/images/placeholders/dirk-von-loen-wagner.webp',
  '/images/placeholders/nils-lindner.webp',
  '/images/placeholders/claudia-chiavazza.webp',
  '/images/placeholders/daniel-jacob.webp',
];

// SEO — SportsActivityLocation JSON-LD
const siteUrl = 'https://laterrasse-saintferreol.fr';
const jsonLd = generateSportsActivityLD({
  name: 'Aventure — Activités plein air | La Terrasse Saint-Ferréol',
  description: t('aventure.hero.subtitle'),
  url: `${siteUrl}/aventure`,
});

const seoTitle = 'Aventure — Activités plein air | La Terrasse Saint-Ferréol';
const seoDescription = 'Découvrez toutes les activités plein air au lac de Saint-Ferréol : pédalo, paddle, canoë, mini-golf, vélo, archery tag et plus. Activités lac Saint-Ferréol pour toute la famille.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="aventure"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <SectionHero
    tagline={t('aventure.hero.tagline')}
    subtitle={t('aventure.hero.subtitle')}
    pole="aventure"
  >
    <a href="#activites" class="bg-white text-aventure px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
      Voir les activités
    </a>
  </SectionHero>

  <!-- Activités aquatiques -->
  <section id="activites" class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-aventure mb-8">
        {t('aventure.aquatique')}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {aquatiques.map((activity, i) => (
          <ActivityCard
            activity={{
              title: activity.entry.title,
              slug: activity.slug,
              price: activity.entry.price ?? '',
              priceDetails: activity.entry.priceDetails ?? '',
              age_min: activity.entry.age_min ?? 0,
              duration: activity.entry.duration ?? '',
              image: activity.entry.image ?? null,
              description: activity.entry.description ?? '',
              title_en: activity.entry.title_en ?? '',
              title_es: activity.entry.title_es ?? '',
            }}
            lang={lang}
            placeholderImage={aquaticImages[i % aquaticImages.length]}
            variant="aquatique"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Activités terrestres -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-aventure mb-8">
        {t('aventure.terrestre')}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {terrestres.map((activity, i) => (
          <ActivityCard
            activity={{
              title: activity.entry.title,
              slug: activity.slug,
              price: activity.entry.price ?? '',
              priceDetails: activity.entry.priceDetails ?? '',
              age_min: activity.entry.age_min ?? 0,
              duration: activity.entry.duration ?? '',
              image: activity.entry.image ?? null,
              description: activity.entry.description ?? '',
              title_en: activity.entry.title_en ?? '',
              title_es: activity.entry.title_es ?? '',
            }}
            lang={lang}
            placeholderImage={terrestreImages[i % terrestreImages.length]}
            variant="terrestre"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section groupes -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold text-aventure mb-4">
        {t('aventure.groups.title')}
      </h2>
      <p class="text-gray-600 mb-6">
        Organisez une sortie de groupe — activités personnalisées pour entreprises, associations, écoles et groupes d'amis.
      </p>
      <p class="text-gray-500 italic mb-6">
        {t('aventure.groups.cta')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/en-groupe', lang)} class="bg-aventure text-white px-6 py-3 rounded-lg font-medium hover:bg-aventure/90 transition-colors">
          Sortie de groupe
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="border border-aventure text-aventure px-6 py-3 rounded-lg font-medium hover:bg-aventure-light transition-colors">
          {t('common.contact')}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={t('crosslink.aventureHub.restaurant')}
    href={getLocalizedPath('/restaurant', lang)}
    pole="restaurant"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="aventure" />
</BaseLayout>
