---
/**
 * AVENTURE HUB — Vert végétal
 * Tone: dynamique, fun, familial
 * Fiches navigables avec suggestions d'alternatives
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Static activity data for V1 — will be replaced by Keystatic reader
const activities = {
  aquatique: [
    { slug: 'pedalo', title: 'Pédalo', price: '25€/h', detail: '4-5 personnes' },
    { slug: 'paddle', title: 'Paddle', price: '12€/h', detail: 'par personne' },
    { slug: 'canoe', title: 'Canoë', price: '12€/h', detail: 'par personne' },
  ],
  terrestre: [
    { slug: 'mini-golf', title: 'Mini-golf', price: '8€', detail: 'par personne' },
    { slug: 'velo-electrique', title: 'Vélo électrique', price: '35€', detail: 'demi-journée' },
    { slug: 'velo-classique', title: 'Vélo classique', price: '15€', detail: 'demi-journée' },
    { slug: 'archery-tag', title: 'Archery Tag', price: '20€', detail: 'par pers. (min 8)' },
    { slug: 'course-orientation', title: 'Course d\'orientation', price: '8€', detail: 'par personne' },
    { slug: 'jeu-de-poste', title: 'Jeu de poste', price: '8€', detail: 'par personne' },
    { slug: 'trampoline', title: 'Trampoline', price: '5€', detail: '5 minutes' },
  ],
};
---

<BaseLayout title="Aventure" description={t('aventure.hero.subtitle')} pole="aventure">
  <!-- Hero -->
  <SectionHero
    tagline={t('aventure.hero.tagline')}
    subtitle={t('aventure.hero.subtitle')}
    pole="aventure"
  >
    <a href="#activites" class="bg-white text-aventure px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
      Voir les activités
    </a>
  </SectionHero>

  <!-- Activités aquatiques -->
  <section id="activites" class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-aventure mb-8">
        {t('aventure.aquatique')}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {activities.aquatique.map((activity) => (
          <a
            href={getLocalizedPath(`/aventure/${activity.slug}`, lang)}
            class="group block bg-aventure-light rounded-2xl overflow-hidden border border-aventure/10 hover:shadow-lg hover:-translate-y-1 transition-all"
          >
            <div class="aspect-[16/10] bg-aventure/10" />
            <div class="p-6">
              <h3 class="font-heading text-lg font-bold text-aventure">{activity.title}</h3>
              <p class="mt-2 text-sm text-gray-600">
                <span class="font-semibold">{activity.price}</span>
                <span class="text-gray-400"> — {activity.detail}</span>
              </p>
              <span class="inline-block mt-3 text-sm text-aventure font-medium group-hover:underline">
                {t('common.discover')} →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Activités terrestres -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-aventure mb-8">
        {t('aventure.terrestre')}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {activities.terrestre.map((activity) => (
          <a
            href={getLocalizedPath(`/aventure/${activity.slug}`, lang)}
            class="group block bg-white rounded-2xl overflow-hidden border border-gray-200 hover:shadow-lg hover:-translate-y-1 transition-all"
          >
            <div class="aspect-[16/10] bg-aventure/5" />
            <div class="p-6">
              <h3 class="font-heading text-lg font-bold text-aventure">{activity.title}</h3>
              <p class="mt-2 text-sm text-gray-600">
                <span class="font-semibold">{activity.price}</span>
                <span class="text-gray-400"> — {activity.detail}</span>
              </p>
              <span class="inline-block mt-3 text-sm text-aventure font-medium group-hover:underline">
                {t('common.discover')} →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section groupes (adaptée Aventure) -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-2xl font-bold text-aventure mb-4">
        {t('aventure.groups.title')}
      </h2>
      <p class="text-gray-600 mb-6">
        Organisez une sortie de groupe — activités personnalisées pour entreprises, associations, écoles et groupes d'amis.
      </p>
      <p class="text-gray-500 italic mb-6">
        {t('aventure.groups.cta')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/en-groupe', lang)} class="bg-aventure text-white px-6 py-3 rounded-lg font-medium hover:bg-aventure/90 transition-colors">
          Sortie de groupe
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="border border-aventure text-aventure px-6 py-3 rounded-lg font-medium hover:bg-aventure-light transition-colors">
          {t('common.contact')}
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-sell contextuel -->
  <section class="py-8 bg-restaurant-light">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 italic">{t('aventure.afterActivity')}</p>
      <a href={getLocalizedPath('/restaurant', lang)} class="inline-block mt-2 text-restaurant font-medium hover:underline">
        Découvrir le restaurant →
      </a>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="aventure" />
</BaseLayout>
