---
/**
 * AVENTURE HUB — Vert végétal
 * Tone: dynamique, fun, familial
 * Fiches navigables avec suggestions d'alternatives
 */
import { Icon } from 'astro-icon/components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import ActivityCard from '@/components/aventure/ActivityCard.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import ContextualCrossLink from '@/components/common/ContextualCrossLink.astro';
import OffreJournee from '@/components/common/OffreJournee.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { generateSportsActivityLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

// Load activities from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const allActivities = await reader.collections.activities.all();
const pageTexts = await reader.singletons.aventureHubTexts.read();
const tx = (path: string) => {
  const [section, field] = path.split('.');
  return getLocalizedField(
    ((pageTexts as Record<string, unknown> | null)?.[section] as Record<string, unknown>) ?? {},
    field,
    lang,
  );
};
const alsoLikeText = getLocalizedField(
  (pageTexts as Record<string, unknown> | null) ?? {},
  'alsoLike',
  lang,
);

// Filter visible, sort by order, split by category
const visible = allActivities
  .filter((a) => a.entry.meta.visible)
  .sort((a, b) => (a.entry.meta.order ?? 0) - (b.entry.meta.order ?? 0));

const aquatiques = visible.filter((a) => a.entry.category === 'aquatique');
const terrestres = visible.filter((a) => a.entry.category === 'terrestre');

function toCardProps(a: typeof visible[number]) {
  return {
    title: a.entry.title,
    slug: a.slug,
    price: a.entry.pricing.price ?? '',
    priceDetails: a.entry.pricing.priceDetails.fr ?? '',
    priceDetails_en: a.entry.pricing.priceDetails.en ?? '',
    priceDetails_es: a.entry.pricing.priceDetails.es ?? '',
    age_min: a.entry.practical.age_min ?? 0,
    duration: a.entry.practical.duration ?? '',
    image: a.entry.practical.image ?? null,
    description: a.entry.description.fr ?? '',
    description_en: a.entry.description.en ?? '',
    description_es: a.entry.description.es ?? '',
    title_en: a.entry.title_en ?? '',
    title_es: a.entry.title_es ?? '',
    isPremium: a.entry.practical.isPremium ?? false,
  };
}

// Placeholder images — cycled across activity cards per category
const aquaticImages = [
  '/images/placeholders/pietro-de-grandi.webp',
  '/images/placeholders/cristian-negraia.webp',
  '/images/placeholders/daniel-jacob.webp',
];
const terrestreImages = [
  '/images/placeholders/dirk-von-loen-wagner.webp',
  '/images/placeholders/nils-lindner.webp',
  '/images/placeholders/claudia-chiavazza.webp',
  '/images/placeholders/daniel-jacob.webp',
];

// SEO — SportsActivityLocation JSON-LD
const siteUrl = 'https://baseloisirs-saintferreol.fr';
const jsonLd = generateSportsActivityLD({
  name: 'Aventure — Activités plein air | La Terrasse Saint-Ferréol',
  description: tx('hero.subtitle'),
  url: `${siteUrl}/aventure`,
});

const seoTitle = 'Activités plein air au lac de Saint-Ferréol, près de Toulouse';
const seoDescription = 'Activités plein air et nautiques au lac de Saint-Ferréol, entre Toulouse et Castres : paddle, canoë, pédalo, VTT, mini-golf, archery tag. Familles et groupes, dans le Tarn.';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="aventure"
  jsonLd={jsonLd}
  pagePath="/aventure"
>
  <!-- Hero -->
  <SectionHero
    tagline={tx('hero.tagline')}
    subtitle={tx('hero.subtitle')}
    pole="aventure"
    image="/images/heroes/aventure.webp"
  >
    <a href="#activites" class="inline-flex items-center gap-2 bg-white text-aventure px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
      {t('aventure.hub.viewActivities')}
      <Icon name="lucide:arrow-down" class="w-4 h-4" />
    </a>
  </SectionHero>

  <!-- Intro prose — SEO section -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8" data-reveal>
      <p class="section-eyebrow text-aventure/40 mb-4">{tx('intro.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold mb-6 text-gray-900">
        {tx('intro.title')}
      </h2>
      <p class="text-gray-600 leading-relaxed text-base lg:text-lg">
        {tx('intro.body')}
      </p>
    </div>
  </section>

  <!-- Activités aquatiques -->
  <section id="activites" class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-8" data-reveal>
        <div class="w-10 h-10 rounded-xl bg-aventure/10 flex items-center justify-center">
          <Icon name="lucide:waves" class="w-5 h-5 text-aventure" />
        </div>
        <h2 class="font-heading text-2xl font-bold text-gray-900">
          {tx('cats.aquatique')}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal-stagger>
        {aquatiques.map((activity, i) => (
          <ActivityCard
            activity={toCardProps(activity)}
            lang={lang}
            placeholderImage={aquaticImages[i % aquaticImages.length]}
            variant="aquatique"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Activités terrestres -->
  <section id="terrestres" class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 mb-8" data-reveal>
        <div class="w-10 h-10 rounded-xl bg-aventure/10 flex items-center justify-center">
          <Icon name="lucide:mountain" class="w-5 h-5 text-aventure" />
        </div>
        <h2 class="font-heading text-2xl font-bold text-gray-900">
          {tx('cats.terrestre')}
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" data-reveal-stagger>
        {terrestres.map((activity, i) => (
          <ActivityCard
            activity={toCardProps(activity)}
            lang={lang}
            placeholderImage={terrestreImages[i % terrestreImages.length]}
            variant="terrestre"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Section groupes -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <p class="section-eyebrow text-aventure/40 mb-4">{tx('groups.eyebrow')}</p>
      <h2 class="font-heading text-2xl lg:text-3xl font-bold text-gray-900 mb-4">
        {tx('groups.title')}
      </h2>
      <p class="text-gray-500 mb-6 max-w-xl mx-auto">
        {tx('groups.body')}
      </p>
      <p class="text-gray-400 italic mb-8">
        {tx('groups.combine')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center gap-2 bg-aventure text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
          {t('aventure.hub.groupCta')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center gap-2 border border-aventure/30 text-aventure px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-aventure-light transition-all">
          {t('common.contact')}
        </a>
      </div>
    </div>
  </section>

  <!-- Offre Journée -->
  <OffreJournee lang={lang} />

  <!-- Cross-link narratif contextuel -->
  <ContextualCrossLink
    text={t('crosslink.aventureHub.restaurant')}
    href={getLocalizedPath('/restaurant', lang)}
    pole="restaurant"
  />

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="aventure" />
</BaseLayout>
