---
/**
 * ÉVÉNEMENTS HUB — Bleu ardoise
 * Tone: sobre, professionnel, rassurant
 * Specs-first: salle, capacité, équipements dès le hero
 * 3 packs nommés par expérience
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHero from '@/components/common/SectionHero.astro';
import VenueSpecs from '@/components/evenements/VenueSpecs.astro';
import CrossLinkBlock from '@/components/common/CrossLinkBlock.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { defaultLang } from '@/i18n/translations';
import { generateEventVenueLD } from '@/lib/seo';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Load venue data from Keystatic
const reader = createReader(process.cwd(), keystaticConfig);
const venueData = await reader.singletons.venue.read();

const capacitySeated = venueData?.capacitySeated ?? 0;
const capacityStanding = venueData?.capacityStanding ?? 0;
const surfaceM2 = venueData?.surfaceM2 ?? 0;

// For array fields, check localized version first, fall back to FR
const venueAny = venueData as Record<string, unknown> | null;
const equipment = venueData
  ? (lang !== defaultLang && venueAny?.[`equipment_${lang}`] as readonly string[])
    || venueData.equipment
    || []
  : [] as readonly string[];
const layoutOptions = venueData
  ? (lang !== defaultLang && venueAny?.[`layoutOptions_${lang}`] as readonly { name: string; capacity: number }[])
    || venueData.layoutOptions
    || []
  : [] as readonly { name: string; capacity: number }[];

const packs = [
  {
    slug: 'seminaire-simple',
    title: 'Séminaire Simple',
    subtitle: 'Location sèche',
    description: 'La salle et les équipements pour votre réunion ou formation.',
    includes: ['Salle équipée', 'Vidéoprojecteur', 'Wi-Fi', 'Parking'],
  },
  {
    slug: 'seminaire-gourmet',
    title: 'Séminaire Gourmet',
    subtitle: 'Avec restauration',
    description: 'Votre séminaire accompagné d\'un repas fait maison avec des produits locaux.',
    includes: ['Salle équipée', 'Petit-déjeuner d\'accueil', 'Déjeuner', 'Pauses café'],
  },
  {
    slug: 'seminaire-aventure',
    title: 'Séminaire Aventure',
    subtitle: 'Team building complet',
    description: 'La journée de cohésion parfaite : séminaire, repas et activités nature.',
    includes: ['Salle équipée', 'Repas', 'Activités team building', 'Encadrement'],
  },
];

const seoTitle = 'Séminaire nature près de Toulouse — La Terrasse Saint-Ferréol';
const seoDescription = 'Salle de séminaire au lac de Saint-Ferréol : capacité jusqu\'à ' + capacityStanding + ' personnes, équipements modernes, cadre nature. Formules séminaire, restauration et team building.';

const jsonLd = generateEventVenueLD({
  capacitySeated,
  capacityStanding,
  amenities: venueData?.equipment ?? [],
});
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  pole="evenements"
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <SectionHero
    tagline={t('evenements.hero.tagline')}
    subtitle={t('evenements.hero.subtitle')}
    pole="evenements"
  >
    <a href={getLocalizedPath('/contact', lang)} class="bg-white text-bleu-ardoise px-6 py-3 rounded-lg font-medium hover:bg-white/90 transition-colors">
      Demander un devis
    </a>
  </SectionHero>

  <!-- LA SALLE — Specs first -->
  <div class="pt-(--spacing-section-mobile) lg:pt-(--spacing-section)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold mb-2" style="color: #3d4969;">
        {t('evenements.venue.title')}
      </h2>
    </div>
    <VenueSpecs
      capacitySeated={capacitySeated}
      capacityStanding={capacityStanding}
      surfaceM2={surfaceM2}
      equipment={equipment}
      layoutOptions={layoutOptions}
    />
  </div>

  <!-- LES PACKS — Nommés par expérience -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-center mb-8" style="color: #3d4969;">
        {t('evenements.packs.title')}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {packs.map((pack) => (
          <a
            href={getLocalizedPath(`/evenements/${pack.slug}`, lang)}
            class="group block bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all"
          >
            <div class="p-8">
              <p class="text-sm font-medium uppercase tracking-wider" style="color: #3d4969; opacity: 0.6;">{pack.subtitle}</p>
              <h3 class="font-heading text-xl font-bold mt-1 mb-3" style="color: #3d4969;">{pack.title}</h3>
              <p class="text-gray-600 text-sm mb-6">{pack.description}</p>
              <ul class="space-y-2">
                {pack.includes.map((item) => (
                  <li class="flex items-center gap-2 text-sm text-gray-600">
                    <span class="w-1.5 h-1.5 rounded-full" style="background-color: #3d4969; opacity: 0.4;" />
                    {item}
                  </li>
                ))}
              </ul>
              <span class="inline-block mt-6 text-sm font-medium group-hover:underline" style="color: #3d4969;">
                En savoir plus →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Section groupes (adaptée Événements) -->
  <section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-gray-500 italic mb-4">
        {t('evenements.groups.cta')}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={getLocalizedPath('/en-entreprise', lang)} class="text-white px-6 py-3 rounded-lg font-medium transition-colors" style="background-color: #3d4969;">
          Journée entreprise complète
        </a>
        <a href={getLocalizedPath('/contact', lang)} class="px-6 py-3 rounded-lg font-medium transition-colors" style="border: 1px solid #3d4969; color: #3d4969;">
          Demander un devis
        </a>
      </div>
    </div>
  </section>

  <!-- Cross-linking structurel -->
  <CrossLinkBlock currentPole="evenements" />
</BaseLayout>
