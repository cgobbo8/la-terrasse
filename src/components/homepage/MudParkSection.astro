---
/**
 * MUD PARK 2026 — Cross-promo de l'événement organisé par l'équipe La Terrasse
 * sur la base de loisir. Section homepage placée après "À proximité", avant le CTA final.
 */
import type { Lang } from '@/i18n/translations';
import { useTranslations } from '@/i18n/utils';
import Icon from '@/components/common/Icon.astro';
import Sunburst from '@/components/common/Sunburst.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const mudparkUrl = 'https://mud-park.fr/?utm_source=baseloisirs-saintferreol&utm_medium=cross-promo&utm_campaign=mudpark-2026';
---

<section class="relative py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite overflow-hidden">
  <!-- Decorative sunburst — top right, very subtle -->
  <div class="absolute top-6 right-2 lg:top-12 lg:right-8 w-32 lg:w-56 aspect-square opacity-[0.08] pointer-events-none -z-0">
    <Sunburst variant={1} size="100%" />
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">

      <!-- TEXT COLUMN -->
      <div class="lg:col-span-5 order-2 lg:order-1" data-reveal>
        <p class="section-eyebrow text-brun-terre/30 mb-5">{t('home.mudpark.eyebrow')}</p>
        <h2 class="font-heading text-3xl lg:text-5xl font-bold mb-6 leading-tight text-brun-terre">
          {t('home.mudpark.title')}
        </h2>
        <p class="text-lg text-brun-terre/80 font-medium mb-5 leading-relaxed">
          {t('home.mudpark.intro')}
        </p>
        <p class="text-gray-600 leading-relaxed mb-8">
          {t('home.mudpark.body')}
        </p>

        <!-- Info pill: date -->
        <div class="mb-9">
          <div class="inline-flex items-center gap-3 bg-white border border-gray-200 rounded-xl px-4 py-3">
            <div class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(255, 255, 128, 0.35);">
              <Icon name="lucide:calendar-days" class="w-4 h-4" style="color: #36342F;" />
            </div>
            <div class="min-w-0">
              <p class="text-[10px] uppercase tracking-wider text-gray-400 font-heading font-bold leading-none mb-1">
                {t('home.mudpark.dateLabel')}
              </p>
              <p class="font-heading font-bold text-sm text-brun-terre leading-tight">
                {t('home.mudpark.date')}
              </p>
            </div>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3">
          <a
            href={mudparkUrl}
            target="_blank"
            rel="noopener"
            class="plausible-event-name=Cross+Promo+Click plausible-event-target=mudpark plausible-event-source=baseloisir inline-flex items-center gap-2 bg-brun-terre text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all"
          >
            {t('home.mudpark.cta')}
            <Icon name="lucide:arrow-up-right" class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- IMAGE COLUMN -->
      <div class="lg:col-span-7 order-1 lg:order-2" data-reveal>
        <div class="relative group" data-mudpark-image>
          <div class="relative aspect-[4/5] lg:aspect-[5/4] rounded-2xl overflow-hidden bg-brun-terre/5 shadow-[0_20px_50px_-15px_rgba(54,52,47,0.25)]">
            <img
              src="/images/events/mudpark.webp"
              alt={t('home.mudpark.imageAlt')}
              class="card-zoom-img absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
            <!-- subtle bottom gradient for badge contrast -->
            <div
              class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
              style="background: linear-gradient(180deg, transparent 0%, rgba(54, 52, 47, 0.55) 100%);"
              aria-hidden="true"
            ></div>
            <!-- Highlighted "Save the date" pill — Soleil highlight (matching agenda highlighted style) -->
            <div class="absolute top-5 left-5 inline-flex items-center gap-2 bg-soleil px-4 py-2 rounded-full shadow-sm" data-mudpark-pill>
              <span class="w-1.5 h-1.5 rounded-full bg-brun-terre animate-pulse"></span>
              <p class="font-heading font-bold text-xs uppercase tracking-wider text-brun-terre">
                {t('home.mudpark.date')}
              </p>
            </div>
          </div>
          <!-- Decorative offset frame -->
          <div class="absolute -inset-3 border border-brun-terre/10 rounded-3xl -z-10" aria-hidden="true"></div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Subtle parallax on the pill when hovering the image — feels alive, respects reduced motion.
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const container = document.querySelector<HTMLElement>('[data-mudpark-image]');
    const pill = document.querySelector<HTMLElement>('[data-mudpark-pill]');
    if (container && pill) {
      container.addEventListener('mouseenter', () => {
        import('gsap').then(({ gsap }) => {
          gsap.to(pill, { y: -4, duration: 0.5, ease: 'power2.out' });
        });
      });
      container.addEventListener('mouseleave', () => {
        import('gsap').then(({ gsap }) => {
          gsap.to(pill, { y: 0, duration: 0.5, ease: 'power2.out' });
        });
      });
    }
  }
</script>
