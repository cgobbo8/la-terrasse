---
import { Icon } from 'astro-icon/components';
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedField, getLocalizedPath } from '@/i18n/utils';
import WeatherTimeCard from './WeatherTimeCard.svelte';
import { poleConfigs, brandColors } from '@/lib/pole-config';
interface Props {
  settings: Record<string, unknown>;
  lang: Lang;
}

const { settings, lang } = Astro.props;
const t = useTranslations(lang);

const seasonalMessage = getLocalizedField(settings, 'seasonalMessage', lang);
const openingHours = (settings.openingHours as string) ?? '';
const address = (settings.address as string) ?? '';
const phone = (settings.phone as string) ?? '';
const currentSeason = (settings.currentSeason as string) ?? 'printemps';

const seasonConfig: Record<string, { label: string; icon: string; gradient: string; accent: string }> = {
  printemps: { label: 'Printemps', icon: 'lucide:flower-2', gradient: 'from-emerald-50 via-green-50 to-lime-50', accent: poleConfigs.aventure.accent },
  ete: { label: 'Été', icon: 'lucide:sun', gradient: 'from-amber-50 via-yellow-50 to-orange-50', accent: brandColors.soleilDark },
  automne: { label: 'Automne', icon: 'lucide:leaf', gradient: 'from-orange-50 via-amber-50 to-yellow-50', accent: poleConfigs.restaurant.accent },
  hiver: { label: 'Hiver', icon: 'lucide:snowflake', gradient: 'from-slate-50 via-blue-50 to-indigo-50', accent: poleConfigs.salle.accent },
};

const season = seasonConfig[currentSeason] ?? seasonConfig.printemps;
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14" data-reveal>
      <p class="section-eyebrow text-brun-terre/40 mb-4">Pratique</p>
      <h2 class="font-heading text-3xl lg:text-5xl font-bold text-brun-terre">
        {t('home.bento.title')}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-4 lg:gap-5" data-reveal-stagger>

      {/* ── HORAIRES — soleil accent card, row-span-2 ── */}
      <div class="bento-cell rounded-2xl p-7 lg:p-8 flex flex-col md:row-span-2 relative overflow-hidden bg-soleil">
        <div class="flex flex-col h-full">
          <div class="w-12 h-12 rounded-xl bg-brun-terre/10 flex items-center justify-center mb-6">
            <Icon name="lucide:clock" class="w-6 h-6 text-brun-terre" />
          </div>
          <h3 class="font-heading font-bold text-xl text-brun-terre mb-6">{t('common.openingHours')}</h3>
          <div class="flex-1 space-y-4">
            <div>
              <p class="text-brun-terre/40 text-xs font-semibold uppercase tracking-wider mb-1.5">Période</p>
              <p class="text-brun-terre/70 text-sm leading-relaxed">Mai & septembre : weekends et jours fériés</p>
              <p class="text-brun-terre/70 text-sm leading-relaxed">Juin, juillet, août : tous les jours</p>
            </div>
            <div class="border-t border-brun-terre/10 pt-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-brun-terre/40 text-xs font-semibold uppercase tracking-wider">Activités</span>
                <span class="text-brun-terre font-heading font-bold text-sm">10h – 19h</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-brun-terre/40 text-xs font-semibold uppercase tracking-wider">Restaurant</span>
                <span class="text-brun-terre font-heading font-bold text-sm">9h – 22h</span>
              </div>
            </div>
          </div>
        </div>
        {/* Decorative circle */}
        <div class="absolute -bottom-10 -right-10 w-40 h-40 rounded-full bg-brun-terre/[0.04]" aria-hidden="true"></div>
      </div>

      {/* ── SAISON — colored gradient card ── */}
      <div class={`bento-cell rounded-2xl p-7 flex flex-col relative overflow-hidden bg-gradient-to-br ${season.gradient}`}>
        <div class="flex items-center justify-between mb-5">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center" style={`background-color: ${season.accent}15;`}>
            <Icon name={season.icon} class="w-5 h-5" style={`color: ${season.accent};`} />
          </div>
          <span class="text-xs font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-full" style={`background-color: ${season.accent}12; color: ${season.accent};`}>
            {season.label}
          </span>
        </div>
        <p class="text-gray-700 text-sm leading-relaxed flex-1">
          {seasonalMessage}
        </p>
        {/* Large decorative icon */}
        <div class="absolute -bottom-4 -right-4 opacity-[0.04] pointer-events-none" aria-hidden="true">
          <Icon name={season.icon} class="w-32 h-32" style={`color: ${season.accent};`} />
        </div>
      </div>

      {/* ── MÉTÉO — live weather (Svelte island) ── */}
      <WeatherTimeCard client:only="svelte" {lang} />

      {/* ── LAC ÉTÉ — photo ambiance, row-span-2 ── */}
      <div class="hidden md:block bento-cell rounded-2xl md:row-span-2 overflow-hidden relative">
        <img
          src="/images/bento-lac-ete.webp"
          alt="Baigneurs dans le lac de Saint-Ferréol en été"
          class="absolute inset-0 w-full h-full object-cover"
          loading="lazy"
        />
      </div>

      {/* ── NOUS TROUVER — wide location + contact card ── */}
      <div class="bento-cell rounded-2xl p-7 flex flex-col md:flex-row gap-6 md:col-span-2 bg-white border border-gray-200/60">
        {/* Address side */}
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-xl bg-brun-terre/8 flex items-center justify-center">
              <Icon name="lucide:map-pin" class="w-5 h-5 text-brun-terre" />
            </div>
            <h3 class="font-heading font-bold text-base text-brun-terre">{t('home.bento.info')}</h3>
          </div>
          <p class="text-gray-600 text-sm leading-relaxed whitespace-pre-line mb-3">
            {address}
          </p>
          <a
            href="https://maps.google.com/?q=Base+de+loisirs+Saint-Ferreol+31250+Revel"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs font-semibold text-brun-terre/70 hover:text-brun-terre transition-colors"
          >
            <Icon name="lucide:external-link" class="w-3.5 h-3.5" />
            Ouvrir dans Google Maps
          </a>
        </div>
        {/* Divider */}
        <div class="hidden md:block w-px bg-gray-200/80 self-stretch" aria-hidden="true"></div>
        <div class="block md:hidden h-px bg-gray-200/80" aria-hidden="true"></div>
        {/* Contact side */}
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-xl bg-brun-terre/8 flex items-center justify-center">
              <Icon name="lucide:phone" class="w-5 h-5 text-brun-terre" />
            </div>
            <h3 class="font-heading font-bold text-base text-brun-terre">Contact</h3>
          </div>
          {phone && (
            <a
              href={`tel:${phone.replace(/\s/g, '')}`}
              class="inline-flex items-center gap-2 text-lg font-heading font-bold text-brun-terre hover:underline underline-offset-4 mb-3"
            >
              {phone}
            </a>
          )}
          <p class="text-gray-400 text-xs">
            <Icon name="lucide:navigation" class="w-3 h-3 inline-block mr-1" />
            À 45 min de Toulouse
          </p>
        </div>
      </div>

      {/* ── CTA — full-width banner (soleil yellow) ── */}
      <div class="col-span-1 md:col-span-4 rounded-2xl px-8 py-6 flex flex-row items-center justify-between gap-4 relative overflow-hidden bg-soleil">
        <div>
          <h3 class="font-heading font-bold text-lg text-brun-terre mb-1">
            {t('home.bento.cta')}
          </h3>
          <p class="text-brun-terre/50 text-sm hidden sm:block">Une question ? Écrivez-nous.</p>
        </div>
        <a
          href={getLocalizedPath('/contact', lang)}
          class="inline-flex items-center gap-2 bg-brun-terre text-white px-6 py-3 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all shrink-0"
        >
          {t('common.contact')}
          <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </div>
</section>

