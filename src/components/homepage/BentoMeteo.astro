---
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedField, getLocalizedPath } from '@/i18n/utils';

interface Props {
  settings: Record<string, unknown>;
  lang: Lang;
}

const { settings, lang } = Astro.props;
const t = useTranslations(lang);

const seasonalMessage = getLocalizedField(settings, 'seasonalMessage', lang);
const promotionText = getLocalizedField(settings, 'promotionText', lang);
const openingHours = (settings.openingHours as string) ?? '';
const address = (settings.address as string) ?? '';
const phone = (settings.phone as string) ?? '';
const currentSeason = (settings.currentSeason as string) ?? 'printemps';

const seasonConfig: Record<string, { label: string; icon: string; color: string }> = {
  printemps: { label: 'Printemps', icon: '🌸', color: '#537b47' },
  ete: { label: 'Été', icon: '☀️', color: '#e8a520' },
  automne: { label: 'Automne', icon: '🍂', color: '#b5651d' },
  hiver: { label: 'Hiver', icon: '❄️', color: '#3d4969' },
};

const season = seasonConfig[currentSeason] ?? seasonConfig.printemps;
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-brun-terre text-center mb-12">
      {t('home.bento.title')}
    </h2>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 lg:gap-6">
      {/* Hours cell — spans 2 rows on md+ */}
      <div class="bg-white rounded-2xl p-6 shadow-sm md:row-span-2 flex flex-col">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-brun-terre/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-lg text-brun-terre">{t('common.openingHours')}</h3>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed whitespace-pre-line flex-1">
          {openingHours}
        </p>
      </div>

      {/* Season cell */}
      <div class="bg-white rounded-2xl p-6 shadow-sm flex flex-col">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-2xl">{season.icon}</span>
          <span class="text-xs font-semibold uppercase tracking-wider" style={`color: ${season.color}`}>
            {season.label}
          </span>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed">
          {seasonalMessage}
        </p>
      </div>

      {/* Promotion cell — only shown if promotionText is non-empty */}
      {promotionText && (
        <div class="bg-white rounded-2xl p-6 shadow-sm border-2" style={`border-color: ${season.color}20`}>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style={`background-color: ${season.color}15`}>
              <svg class="w-5 h-5" style={`color: ${season.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
              </svg>
            </div>
            <h3 class="font-heading font-bold text-sm text-gray-800">{t('home.bento.promo')}</h3>
          </div>
          <p class="text-gray-700 text-sm font-medium">
            {promotionText}
          </p>
        </div>
      )}

      {/* Info cell — practical info */}
      <div class="bg-white rounded-2xl p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-brun-terre/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-brun-terre" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-sm text-brun-terre">{t('home.bento.info')}</h3>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed whitespace-pre-line mb-3">
          {address}
        </p>
        {phone && (
          <a href={`tel:${phone.replace(/\s/g, '')}`} class="text-brun-terre text-sm font-medium hover:underline">
            {phone}
          </a>
        )}
      </div>

      {/* CTA cell — spans full width on mobile, single cell on desktop */}
      <div class="col-span-2 md:col-span-1 rounded-2xl p-6 shadow-sm bg-brun-terre text-white flex flex-col items-center justify-center text-center">
        <h3 class="font-heading font-bold text-lg mb-3">
          {t('home.bento.cta')}
        </h3>
        <a
          href={getLocalizedPath('/contact', lang)}
          class="inline-flex items-center gap-2 bg-white text-brun-terre px-5 py-2.5 rounded-lg font-medium text-sm hover:bg-white/90 transition-colors"
        >
          {t('common.contact')}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
