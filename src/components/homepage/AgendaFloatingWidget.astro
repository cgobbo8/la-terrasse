---
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedField, getLocalizedPath } from '@/i18n/utils';
import { Icon } from 'astro-icon/components';

interface EventEntry {
  slug: string;
  entry: Record<string, unknown> & {
    title: string;
    schedule: { date: string | null; startTime?: string; endTime?: string; category?: string };
    description: { fr?: string; en?: string; es?: string } | string;
    meta: { visible: boolean; highlighted?: boolean };
  };
}

interface Props {
  events: EventEntry[];
  lang: Lang;
}

const { events, lang } = Astro.props;
const t = useTranslations(lang);

// Filter visible + future events, sort chronologically, limit to 3
const now = new Date();
const upcomingEvents = events
  .filter((e) => {
    if (!e.entry.meta.visible) return false;
    if (!e.entry.schedule.date) return false;
    return new Date(e.entry.schedule.date) >= now;
  })
  .sort((a, b) => new Date(a.entry.schedule.date!).getTime() - new Date(b.entry.schedule.date!).getTime())
  .slice(0, 3);

const hasEvents = upcomingEvents.length > 0;

function formatDay(dateStr: string) {
  return new Intl.DateTimeFormat('fr', { day: 'numeric' }).format(new Date(dateStr));
}

function formatMonth(dateStr: string, locale: string) {
  return new Intl.DateTimeFormat(locale, { month: 'short' }).format(new Date(dateStr));
}

const displayEvents = upcomingEvents.map((event) => ({
  slug: event.slug,
  date: event.entry.schedule.date!,
  startTime: event.entry.schedule.startTime || '',
  endTime: event.entry.schedule.endTime || '',
  highlighted: !!event.entry.meta.highlighted,
  title: getLocalizedField(event.entry, 'title', lang) || event.slug,
  description: getLocalizedField(event.entry, 'description', lang),
}));

function formatTimeRange(start: string, end: string): string | null {
  if (!start) return null;
  const s = start.replace(':', 'h');
  if (!end) return s;
  return `${s} — ${end.replace(':', 'h')}`;
}
---

{hasEvents && (
  <div class="agenda-floating-widget relative z-10  lg:bg-none" style="--split-bg: linear-gradient(to bottom, transparent 50%, var(--color-offwhite, var(--color-offwhite)) 50%);" data-agenda-widget>
    <div class="px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto py-6 lg:py-0">
      <a
        href={getLocalizedPath('/agenda', lang)}
        class="agenda-widget-card block rounded-2xl p-5 lg:p-6 card-hover"
      >
        <div data-agenda-content>
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-brun-terre/8 flex items-center justify-center">
              <Icon name="lucide:calendar" class="w-4 h-4 text-brun-terre" />
            </div>
            <h2 class="font-heading text-base font-bold text-brun-terre">
              {t('home.upcoming.title')}
            </h2>
          </div>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-brun-terre whitespace-nowrap">
            {t('home.upcoming.cta')}
            <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
          </span>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
          {displayEvents.map((event) => (
            <div
              class:list={[
                'widget-event relative flex gap-3 items-start rounded-xl px-3 py-2.5',
                event.highlighted ? 'widget-event-highlighted overflow-hidden' : 'widget-event-default',
              ]}
            >
              <div
                class="flex-shrink-0 text-center rounded-lg p-2.5 w-14"
                style={event.highlighted
                  ? 'background-color: rgba(255, 255, 128, 0.8);'
                  : ''
                }
              >
                <span class="block text-lg font-bold text-brun-terre leading-none">
                  {formatDay(event.date)}
                </span>
                <span class:list={['block text-[0.5625rem] uppercase mt-1 font-semibold tracking-wide', event.highlighted ? 'text-brun-terre/60' : 'text-gray-400']}>
                  {formatMonth(event.date, lang)}
                </span>
              </div>
              <div class="min-w-0 pt-0.5">
                <h3 class="font-heading font-bold text-sm text-gray-900 leading-snug">
                  {event.title}
                </h3>
                {formatTimeRange(event.startTime, event.endTime) && (
                  <p class="text-[0.6875rem] text-gray-400 font-medium mt-0.5">
                    {formatTimeRange(event.startTime, event.endTime)}
                  </p>
                )}
                {event.description && (
                  <p class="text-xs text-gray-400 mt-1 line-clamp-1">
                    {event.description}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
        </div>
      </a>
    </div>
  </div>
)}

<style>
  [data-agenda-widget] {
    visibility: hidden;
  }
  [data-agenda-content] {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-agenda-widget] { visibility: visible !important; }
    [data-agenda-content] { opacity: 1 !important; }
  }

  .agenda-widget-card {
    background-color: rgb(255 255 255 / 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgb(255 255 255 / 0.7);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .widget-event-highlighted {
    background-color: rgba(255, 255, 128, 0.15);
  }

  .widget-event-highlighted::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255, 255, 200, 0.3) 40%,
      rgba(255, 255, 255, 0.45) 50%,
      rgba(255, 255, 200, 0.3) 60%,
      transparent 80%
    );
    pointer-events: none;
    animation: widget-glint 5s ease-in-out infinite;
  }

  @keyframes widget-glint {
    0%, 80%, 100% { left: -100%; opacity: 0; }
    10% { opacity: 1; }
    40% { left: 150%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .widget-event-highlighted::after { animation: none; display: none; }
  }

  @media (min-width: 1024px) {
    .agenda-floating-widget {
      margin-top: -4rem;
    }
  }
</style>

<script>
  const widget = document.querySelector<HTMLElement>('[data-agenda-widget]');
  if (widget && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    import('gsap').then(({ gsap }) => {
      const content = widget.querySelector<HTMLElement>('[data-agenda-content]');
      // Card slides up — visibility only, no opacity/filter to preserve glassmorphism
      gsap.fromTo(widget,
        { visibility: 'hidden', y: 24 },
        { visibility: 'visible', y: 0, duration: 0.9, ease: 'power3.out', delay: 0.85 }
      );
      // Content blur-in like hero title — inside the card, doesn't affect backdrop-filter
      if (content) {
        gsap.fromTo(content,
          { opacity: 0, filter: 'blur(10px)' },
          { opacity: 1, filter: 'blur(0px)', duration: 1.0, ease: 'power3.out', delay: 0.85 }
        );
      }
    });
  }
</script>
