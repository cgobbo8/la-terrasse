---
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedField, getLocalizedPath } from '@/i18n/utils';
import { Icon } from 'astro-icon/components';

interface EventEntry {
  slug: string;
  entry: Record<string, unknown> & {
    title: string;
    date: string | null;
    description: string;
    visible: boolean;
  };
}

interface Props {
  events: EventEntry[];
  lang: Lang;
}

const { events, lang } = Astro.props;
const t = useTranslations(lang);

// Filter visible + future events, sort chronologically, limit to 3
const now = new Date();
const upcomingEvents = events
  .filter((e) => {
    if (!e.entry.visible) return false;
    if (!e.entry.date) return false;
    return new Date(e.entry.date) >= now;
  })
  .sort((a, b) => new Date(a.entry.date!).getTime() - new Date(b.entry.date!).getTime())
  .slice(0, 3);

const hasEvents = upcomingEvents.length > 0;

function formatDay(dateStr: string) {
  return new Intl.DateTimeFormat('fr', { day: 'numeric' }).format(new Date(dateStr));
}

function formatMonth(dateStr: string, locale: string) {
  return new Intl.DateTimeFormat(locale, { month: 'short' }).format(new Date(dateStr));
}

const displayEvents = upcomingEvents.map((event) => ({
  slug: event.slug,
  date: event.entry.date!,
  title: getLocalizedField(event.entry, 'title', lang) || event.slug,
  description: getLocalizedField(event.entry, 'description', lang),
}));
---

{hasEvents && (
  <div class="agenda-floating-widget relative z-10  lg:bg-none" style="--split-bg: linear-gradient(to bottom, transparent 50%, var(--color-offwhite, #fafaf8) 50%);" data-agenda-widget>
    <div class="px-4 sm:px-6 lg:px-8 max-w-5xl mx-auto py-6 lg:py-0">
      <a
        href={getLocalizedPath('/agenda', lang)}
        class="agenda-widget-card block rounded-2xl p-5 lg:p-6 card-hover"
      >
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-lg bg-brun-terre/8 flex items-center justify-center">
              <Icon name="lucide:calendar" class="w-4 h-4 text-brun-terre" />
            </div>
            <h2 class="font-heading text-base font-bold text-brun-terre">
              {t('home.upcoming.title')}
            </h2>
          </div>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-brun-terre whitespace-nowrap">
            {t('home.upcoming.cta')}
            <Icon name="lucide:arrow-right" class="w-3.5 h-3.5" />
          </span>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
          {displayEvents.map((event) => (
            <div class="flex gap-3 items-start">
              <div class="flex-shrink-0 text-center rounded-xl p-2.5 w-14 border border-gray-200/60" style="background-color: #fafaf8;">
                <span class="block text-lg font-bold text-brun-terre leading-none">
                  {formatDay(event.date)}
                </span>
                <span class="block text-[0.5625rem] text-gray-400 uppercase mt-1 font-semibold tracking-wide">
                  {formatMonth(event.date, lang)}
                </span>
              </div>
              <div class="min-w-0 pt-0.5">
                <h3 class="font-heading font-bold text-sm text-gray-900 leading-snug">
                  {event.title}
                </h3>
                {event.description && (
                  <p class="text-xs text-gray-400 mt-1 line-clamp-1">
                    {event.description}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
      </a>
    </div>
  </div>
)}

<style>
  [data-agenda-widget] {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-agenda-widget] { opacity: 1 !important; }
  }

  .agenda-widget-card {
    background-color: rgb(255 255 255 / 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgb(255 255 255 / 0.7);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  @media (min-width: 1024px) {
    .agenda-floating-widget {
      margin-top: -4rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const widget = document.querySelector<HTMLElement>('[data-agenda-widget]');
  if (widget && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    // Slide up after hero text sequence completes
    // No blur: parent filter breaks child backdrop-filter (glassmorphism)
    gsap.fromTo(widget,
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.9, ease: 'power3.out', delay: 0.85 }
    );
  }
</script>
