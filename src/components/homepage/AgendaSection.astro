---
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedField } from '@/i18n/utils';

interface EventEntry {
  slug: string;
  entry: Record<string, unknown> & {
    title: string;
    schedule: { date: string | null; startTime?: string; endTime?: string; category?: string };
    description: { fr?: string; en?: string; es?: string } | string;
    meta: { visible: boolean; highlighted?: boolean };
  };
}

interface Props {
  events: EventEntry[];
  lang: Lang;
}

const { events, lang } = Astro.props;
const t = useTranslations(lang);

// Filter visible + future events, sort chronologically, limit to 4
const now = new Date();
const upcomingEvents = events
  .filter((e) => {
    if (!e.entry.meta.visible) return false;
    if (!e.entry.schedule.date) return false;
    return new Date(e.entry.schedule.date) >= now;
  })
  .sort((a, b) => new Date(a.entry.schedule.date!).getTime() - new Date(b.entry.schedule.date!).getTime())
  .slice(0, 4);

const hasEvents = upcomingEvents.length > 0;

function formatDay(dateStr: string) {
  return new Intl.DateTimeFormat('fr', { day: 'numeric' }).format(new Date(dateStr));
}

function formatMonth(dateStr: string, locale: string) {
  return new Intl.DateTimeFormat(locale, { month: 'short' }).format(new Date(dateStr));
}

// Pre-compute event display data
const displayEvents = upcomingEvents.map((event) => ({
  slug: event.slug,
  date: event.entry.schedule.date!,
  startTime: event.entry.schedule.startTime || '',
  endTime: event.entry.schedule.endTime || '',
  highlighted: !!event.entry.meta.highlighted,
  title: getLocalizedField(event.entry, 'title', lang) || event.slug,
  description: getLocalizedField(event.entry, 'description', lang),
}));

function formatTimeRange(start: string, end: string): string | null {
  if (!start) return null;
  const s = start.replace(':', 'h');
  if (!end) return s;
  return `${s} — ${end.replace(':', 'h')}`;
}
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-brun-terre text-center mb-12">
      {t('home.agenda.title')}
    </h2>

    {hasEvents ? (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6 max-w-4xl mx-auto">
        {displayEvents.map((event) => (
          <article
            class:list={[
              'flex gap-4 items-start p-5 rounded-2xl transition-all duration-300',
              event.highlighted
                ? 'section-event-highlighted relative overflow-hidden'
                : 'bg-white shadow-sm border border-gray-100',
            ]}
          >
            <div
              class:list={[
                'flex-shrink-0 text-center rounded-xl p-3 w-16',
                !event.highlighted && 'bg-offwhite',
              ]}
              style={event.highlighted ? 'background-color: rgba(255, 255, 128, 0.8);' : ''}
            >
              <span class="block text-2xl font-bold text-brun-terre leading-none">
                {formatDay(event.date)}
              </span>
              <span class="block text-xs text-gray-600 uppercase mt-1">
                {formatMonth(event.date, lang)}
              </span>
            </div>
            <div class="min-w-0">
              <h3 class="font-heading font-bold text-lg text-gray-900 leading-snug">
                {event.title}
              </h3>
              {formatTimeRange(event.startTime, event.endTime) && (
                <p class="text-xs text-gray-500 font-medium mt-0.5">
                  {formatTimeRange(event.startTime, event.endTime)}
                </p>
              )}
              {event.description && (
                <p class="text-sm text-gray-600 mt-1.5 leading-relaxed line-clamp-2">
                  {event.description}
                </p>
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p class="text-center text-gray-400 text-lg">
        {t('home.agenda.empty')}
      </p>
    )}
  </div>
</section>

<style>
  .section-event-highlighted {
    background-color: rgba(255, 255, 128, 0.18);
    border: 1px solid rgba(255, 255, 128, 0.4);
  }

  .section-event-highlighted::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 20%,
      rgba(255, 255, 200, 0.3) 40%,
      rgba(255, 255, 255, 0.45) 50%,
      rgba(255, 255, 200, 0.3) 60%,
      transparent 80%
    );
    pointer-events: none;
    animation: section-glint 5s ease-in-out infinite;
  }

  @keyframes section-glint {
    0%, 80%, 100% { left: -100%; opacity: 0; }
    10% { opacity: 1; }
    40% { left: 150%; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-event-highlighted::after { animation: none; display: none; }
  }
</style>
