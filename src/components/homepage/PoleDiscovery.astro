---
import { poleConfigs, type Pole } from '@/lib/pole-config';
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedPath } from '@/i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const poles: { key: Pole; href: string }[] = [
  { key: 'restaurant', href: '/restaurant' },
  { key: 'aventure', href: '/aventure' },
  { key: 'evenements', href: '/evenements' },
];
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-offwhite">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-3xl lg:text-4xl font-bold text-brun-terre text-center mb-12">
      {t('home.poles.title')}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {poles.map(({ key, href }) => {
        const config = poleConfigs[key];
        const description = t(`home.poles.description.${key}` as any);
        const ctaLabel = t(`home.poles.cta.${key}` as any);
        const localizedHref = getLocalizedPath(href, lang);

        return (
          <div class="rounded-2xl overflow-hidden bg-white shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all">
            <div class="aspect-[3/2] overflow-hidden" style={`background-color: ${config.light}`}>
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-sm opacity-40" style={`color: ${config.accent}`}>Photo {config.name}</span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-heading text-xl font-bold mb-2" style={`color: ${config.accent}`}>
                La Terrasse {config.name}
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
              <a
                href={localizedHref}
                class="inline-block mt-4 text-sm font-medium hover:underline"
                style={`color: ${config.accent}`}
              >
                {ctaLabel} &rarr;
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
