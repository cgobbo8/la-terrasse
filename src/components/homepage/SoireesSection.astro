---
import type { Lang } from '@/i18n/translations';
import { useTranslations, getLocalizedPath } from '@/i18n/utils';
import { Icon } from 'astro-icon/components';

interface Props {
  lang: Lang;
  hideRestaurantCta?: boolean;
}

const { lang, hideRestaurantCta = false } = Astro.props;
const t = useTranslations(lang);

const leftCards = [
  { icon: 'lucide:music',  label: 'Concerts en terrasse', description: 'Artistes locaux, coucher de soleil', color: '#537b47', rotate: '-3deg',  cx: '-10px', mt: '0px' },
  { icon: 'lucide:brain',  label: 'Blind tests',          description: 'Musique, ciné, culture',             color: '#3d4969', rotate: '-1.5deg', cx: '16px',  mt: '0px' },
];
const rightCards = [
  { icon: 'lucide:mic',    label: 'Soirées karaoké',      description: 'Votre scène, votre micro',           color: '#9b7b52', rotate: '2.5deg',  cx: '-14px', mt: '32px' },
  { icon: 'lucide:disc-3', label: 'DJ sets',              description: 'Électro, house, funk',               color: '#c27a2a', rotate: '3.5deg',  cx: '8px',   mt: '0px' },
];
const allCards = [...leftCards, ...rightCards];
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-brun-terre text-white grain-overlay overflow-hidden relative">

  <div
    class="absolute inset-0 pointer-events-none"
    aria-hidden="true"
    style="background: radial-gradient(ellipse 700px 500px at 50% 50%, rgba(255,255,255,0.05) 0%, transparent 68%);"
  ></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">

    <!-- ── Mobile ── -->
    <div class="lg:hidden">
      <div class="mb-10" data-reveal>
        <p class="section-eyebrow text-white/30 mb-4">Restaurant & soirées</p>
        <h2 class="font-heading text-3xl font-bold mb-5 leading-tight">{t('home.soirees.title')}</h2>
        <p class="text-base text-white/60 leading-relaxed mb-8">{t('home.soirees.body')}</p>
        <div class="flex flex-wrap gap-3">
          <a href={getLocalizedPath('/agenda', lang)} class="inline-flex items-center gap-2 bg-white text-brun-terre px-6 py-3 rounded-full font-heading font-semibold text-sm hover:shadow-lg transition-all">
            {t('home.soirees.ctaAgenda')} <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
          {!hideRestaurantCta && (
            <a href={getLocalizedPath('/restaurant', lang)} class="inline-flex items-center gap-2 border border-white/25 text-white px-6 py-3 rounded-full font-heading font-semibold text-sm hover:bg-white/10 transition-all">
              {t('home.soirees.ctaRestaurant')}
            </a>
          )}
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3" data-reveal-stagger>
        {allCards.map((item) => (
          <div class="rounded-2xl p-5" style={`background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-top: 2px solid ${item.color};`}>
            <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-3" style={`background: ${item.color}22;`}>
              <Icon name={item.icon} class="w-5 h-5" style={`color: ${item.color};`} />
            </div>
            <p class="font-heading font-bold text-sm text-white mb-1">{item.label}</p>
            <p class="text-xs text-white/40 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Desktop: triptych explosion ── -->
    <div class="hidden lg:flex items-center gap-10 xl:gap-16" data-soirees-explode>

      <!-- Left cards -->
      <div class="flex flex-col gap-5 w-[215px] xl:w-[235px] shrink-0">
        {leftCards.map((item) => (
          <div class="soiree-outer soiree-outer-left" style={`margin-top: ${item.mt};`}>
            <div class="soiree-card" style={`--cr: ${item.rotate}; --cx: ${item.cx}; --cc: ${item.color};`}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style={`background: ${item.color}20;`}>
                <Icon name={item.icon} class="w-6 h-6" style={`color: ${item.color};`} />
              </div>
              <p class="font-heading font-bold text-sm text-white mb-1.5">{item.label}</p>
              <p class="text-xs text-white/40 leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Center text -->
      <div class="soirees-center flex-1 text-center px-2">
        <p class="section-eyebrow text-white/30 mb-4">Restaurant & soirées</p>
        <h2 class="font-heading text-4xl xl:text-5xl font-bold mb-6 leading-tight">{t('home.soirees.title')}</h2>
        <p class="text-white/60 leading-relaxed mb-10 max-w-xs mx-auto">{t('home.soirees.body')}</p>
        <div class="flex flex-col items-center gap-3">
          <a href={getLocalizedPath('/agenda', lang)} class="inline-flex items-center gap-2 bg-white text-brun-terre px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:shadow-lg hover:-translate-y-px transition-all">
            {t('home.soirees.ctaAgenda')} <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
          {!hideRestaurantCta && (
            <a href={getLocalizedPath('/restaurant', lang)} class="inline-flex items-center gap-2 border border-white/25 text-white px-7 py-3.5 rounded-full font-heading font-semibold text-sm hover:bg-white/10 hover:border-white/40 transition-all">
              {t('home.soirees.ctaRestaurant')}
            </a>
          )}
        </div>
      </div>

      <!-- Right cards -->
      <div class="flex flex-col gap-5 w-[215px] xl:w-[235px] shrink-0">
        {rightCards.map((item) => (
          <div class="soiree-outer soiree-outer-right" style={`margin-top: ${item.mt};`}>
            <div class="soiree-card" style={`--cr: ${item.rotate}; --cx: ${item.cx}; --cc: ${item.color};`}>
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style={`background: ${item.color}20;`}>
                <Icon name={item.icon} class="w-6 h-6" style={`color: ${item.color};`} />
              </div>
              <p class="font-heading font-bold text-sm text-white mb-1.5">{item.label}</p>
              <p class="text-xs text-white/40 leading-relaxed">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    .soiree-outer { opacity: 0; }
    .soirees-center { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .soiree-outer, .soirees-center { opacity: 1 !important; }
  }

  .soiree-card {
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 2px solid var(--cc);
    transform: rotate(var(--cr, 0deg)) translateX(var(--cx, 0px));
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    cursor: default;
    will-change: transform;
  }

  .soiree-card:hover {
    transform: rotate(0deg) translateX(var(--cx, 0px)) translateY(-6px);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.12);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const wrapper = document.querySelector<HTMLElement>('[data-soirees-explode]');

  if (
    wrapper &&
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches &&
    window.innerWidth >= 1024
  ) {
    const center = wrapper.querySelector<HTMLElement>('.soirees-center')!;
    const leftOuters = wrapper.querySelectorAll<HTMLElement>('.soiree-outer-left');
    const rightOuters = wrapper.querySelectorAll<HTMLElement>('.soiree-outer-right');

    // Use IntersectionObserver instead of ScrollTrigger — unaffected by pin spacers
    // from client:only Svelte islands (JourneeTypeTimeline) that load asynchronously
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);

          gsap.fromTo(center,
            { opacity: 0, y: 16, filter: 'blur(8px)' },
            { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.7, ease: 'power3.out' }
          );
          leftOuters.forEach((el, i) => {
            gsap.fromTo(el,
              { x: 390, opacity: 0 },
              { x: 0, opacity: 1, duration: 0.8, ease: 'power4.out', delay: 0.1 + i * 0.1 }
            );
          });
          rightOuters.forEach((el, i) => {
            gsap.fromTo(el,
              { x: -390, opacity: 0 },
              { x: 0, opacity: 1, duration: 0.8, ease: 'power4.out', delay: 0.15 + i * 0.1 }
            );
          });
        });
      },
      { threshold: 0.25 }
    );

    observer.observe(wrapper);
  }
</script>
