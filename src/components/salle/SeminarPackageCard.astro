---
/**
 * SeminarPackageCard — Mobile card for seminar package display
 * Bleu ardoise (#3d4969) accent, consistent with événements pole DA
 * Pure Astro component — no JS shipped
 */
import { Icon } from 'astro-icon/components';
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

interface Props {
  title: string;
  subtitle: string;
  description: string;
  inclusions: string[];
  price: string;
  ctaHref: string;
  highlighted?: boolean;
  lang?: Lang;
}

const { title, subtitle, description, inclusions, price, ctaHref, highlighted = false, lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const accent = '#3d4969';
---

<div
  class:list={[
    'rounded-2xl overflow-hidden bg-white shadow-sm',
    highlighted ? 'ring-2' : 'border border-gray-200',
  ]}
  style={highlighted ? `--tw-ring-color: ${accent}` : undefined}
>
  {highlighted && (
    <div class="px-6 pt-4 lg:px-8">
      <span
        class="inline-block text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full"
        style={`background-color: ${accent}15; color: ${accent};`}
      >
        {t('common.recommended')}
      </span>
    </div>
  )}

  <div class:list={['px-6 pb-8 lg:px-8 lg:pb-10', highlighted ? 'pt-4' : 'pt-6 lg:pt-8']}>
    <h3 class="font-heading text-xl font-bold mb-1" style={`color: ${accent};`}>
      {title}
    </h3>
    <p class="text-sm font-medium uppercase tracking-wider mb-3" style={`color: ${accent}99;`}>
      {subtitle}
    </p>
    <p class="text-gray-600 text-sm mb-6 leading-relaxed">{description}</p>

    <ul class="space-y-2 mb-6">
      {inclusions.map((item) => (
        <li class="flex items-center gap-2 text-sm text-gray-600">
          <Icon name="lucide:check" class="w-4 h-4 shrink-0" style={`color: ${accent};`} aria-hidden="true" />
          {item}
        </li>
      ))}
    </ul>

    {price && (
      <p class="font-heading text-lg font-bold mb-4" style={`color: ${accent};`}>
        {price}
      </p>
    )}

    <a
      href={ctaHref}
      class="inline-block w-full text-center text-white px-6 py-3 rounded-lg font-medium hover:opacity-90 transition-opacity"
      style={`background-color: ${accent};`}
    >
      {t('common.requestQuote')}
    </a>
  </div>
</div>
