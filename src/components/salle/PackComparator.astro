---
/**
 * PackComparator — Side-by-side comparison table (desktop) + stacked cards (mobile)
 * Bleu ardoise accent via poleConfigs, clean professional table
 * Pure Astro component — no JS shipped
 */
import { Icon } from 'astro-icon/components';
import SeminarPackageCard from './SeminarPackageCard.astro';
import { poleConfigs } from '@/lib/pole-config';
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

interface Features {
  salleEquipee: boolean;
  videoprojecteur: boolean;
  wifi: boolean;
  parking: boolean;
  petitDejeuner: boolean;
  dejeuner: boolean;
  pausesCafe: boolean;
  teamBuilding: boolean;
  encadrement: boolean;
}

interface Package {
  slug: string;
  title: string;
  subtitle: string;
  description: string;
  includes: string[];
  priceFrom: string;
  features: Features;
  ctaHref: string;
  highlighted?: boolean;
}

interface Props {
  packages: Package[];
  lang?: Lang;
}

const { packages, lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const accent = poleConfigs.salle.accent;

const featureRows: { key: keyof Features; label: string }[] = [
  { key: 'salleEquipee', label: t('salle.feature.roomEquipped') },
  { key: 'videoprojecteur', label: t('salle.feature.projector') },
  { key: 'wifi', label: t('salle.feature.wifi') },
  // { key: 'parking', label: t('salle.feature.parking') }, // parking is public, not managed by us
  { key: 'petitDejeuner', label: t('salle.feature.breakfast') },
  { key: 'dejeuner', label: t('salle.feature.lunch') },
  { key: 'pausesCafe', label: t('salle.feature.coffeeBreaks') },
  { key: 'teamBuilding', label: t('salle.feature.teamBuilding') },
  { key: 'encadrement', label: t('salle.feature.coaching') },
];
---

<!-- Desktop: comparison table -->
<div class="hidden md:block">
  <div class="overflow-x-auto">
    <table class="w-full border-collapse">
      <!-- Header row: package names -->
      <thead>
        <tr>
          <th class="text-left py-4 pr-4 w-1/4"></th>
          {packages.map((pkg) => (
            <th class="text-center py-4 px-4" style={pkg.highlighted ? `border-top: 3px solid ${accent};` : undefined}>
              {pkg.highlighted && (
                <span
                  class="inline-block text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-2"
                  style={`background-color: ${accent}15; color: ${accent};`}
                >
                  {t('common.recommended')}
                </span>
              )}
              <p class="font-heading text-lg font-bold" style={`color: ${accent};`}>
                {pkg.title}
              </p>
              <p class="text-xs font-medium uppercase tracking-wider mt-1" style={`color: ${accent}99;`}>
                {pkg.subtitle}
              </p>
            </th>
          ))}
        </tr>
      </thead>

      <!-- Feature rows -->
      <tbody>
        {featureRows.map((feature, i) => (
          <tr class={i % 2 === 0 ? 'bg-gray-50/50' : ''}>
            <td class="py-3 pr-4 text-sm text-gray-700 font-medium">{feature.label}</td>
            {packages.map((pkg) => (
              <td class="py-3 px-4 text-center">
                {pkg.features[feature.key] ? (
                  <Icon name="lucide:check" class="w-5 h-5 mx-auto" style={`color: ${accent};`} aria-label="Inclus" />
                ) : (
                  <span class="text-gray-300 text-lg" aria-label="Non inclus">—</span>
                )}
              </td>
            ))}
          </tr>
        ))}

        <!-- Price row -->
        <tr class="border-t border-gray-200">
          <td class="py-4 pr-4 text-sm text-gray-700 font-bold">{t('common.price')}</td>
          {packages.map((pkg) => (
            <td class="py-4 px-4 text-center">
              <span class="font-heading text-lg font-bold" style={`color: ${accent};`}>
                {pkg.priceFrom}
              </span>
            </td>
          ))}
        </tr>

        <!-- CTA row -->
        <tr>
          <td class="py-4 pr-4"></td>
          {packages.map((pkg) => (
            <td class="py-4 px-4 text-center">
              <a
                href={pkg.ctaHref}
                class:list={[
                  'inline-block px-6 py-3 rounded-full font-heading font-semibold text-sm transition-all hover:shadow-md hover:-translate-y-px',
                  pkg.highlighted ? 'text-white' : '',
                ]}
                style={pkg.highlighted
                  ? `background-color: ${accent}; color: white;`
                  : `border: 1px solid ${accent}; color: ${accent};`
                }
              >
                {t('common.requestQuote')}
              </a>
            </td>
          ))}
        </tr>
      </tbody>
    </table>
  </div>
</div>

<!-- Mobile: stacked cards -->
<div class="md:hidden space-y-6">
  {packages.map((pkg) => (
    <SeminarPackageCard
      title={pkg.title}
      subtitle={pkg.subtitle}
      description={pkg.description}
      inclusions={pkg.includes}
      price={pkg.priceFrom}
      ctaHref={pkg.ctaHref}
      highlighted={pkg.highlighted}
      lang={lang}
    />
  ))}
</div>
