---
/**
 * VenueSpecs — Scannable spec sheet for corporate planners
 * Salle accent from poleConfigs, icon + label + value grid
 * Pure Astro component, no Svelte island needed
 */
import { Icon } from 'astro-icon/components';
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';
import { poleConfigs } from '@/lib/pole-config';

interface LayoutOption {
  name: string;
  capacity: number;
}

interface Props {
  capacitySeated: number;
  capacityStanding: number;
  surfaceM2: number;
  equipment: readonly string[];
  layoutOptions: readonly LayoutOption[];
  lang?: Lang;
}

const { capacitySeated, capacityStanding, surfaceM2, equipment, layoutOptions, lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const { accent, light } = poleConfigs.salle;
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Left column: venue photo + key figures -->
      <div class="space-y-8">
        <img
          src="/images/salle/espace.webp"
          alt="La salle événementielle"
          class="aspect-[4/3] w-full rounded-2xl object-cover"
          loading="lazy"
        />

        <!-- Key figures row -->
        <div class="grid grid-cols-3 gap-4">
          <div class="text-center rounded-xl p-4" style={`background-color: ${light};`}>
            <div class="font-heading text-2xl lg:text-3xl font-bold" style={`color: ${accent};`}>
              {capacitySeated}
            </div>
            <div class="text-sm text-gray-600 mt-1">{t('salle.venue.seatedLabel')}</div>
          </div>
          <div class="text-center rounded-xl p-4" style={`background-color: ${light};`}>
            <div class="font-heading text-2xl lg:text-3xl font-bold" style={`color: ${accent};`}>
              {capacityStanding}
            </div>
            <div class="text-sm text-gray-600 mt-1">{t('salle.venue.standingLabel')}</div>
          </div>
          <div class="text-center rounded-xl p-4" style={`background-color: ${light};`}>
            <div class="font-heading text-2xl lg:text-3xl font-bold" style={`color: ${accent};`}>
              {surfaceM2}<span class="text-base font-normal"> m²</span>
            </div>
            <div class="text-sm text-gray-600 mt-1">{t('salle.venue.surfaceLabel')}</div>
          </div>
        </div>
      </div>

      <!-- Right column: equipment + configurations -->
      <div class="space-y-8">
        <!-- Equipment -->
        <div>
          <h3 class="font-heading text-lg font-bold mb-4" style={`color: ${accent};`}>
            {t('salle.venue.equipmentTitle')}
          </h3>
          <div class="flex flex-wrap gap-2">
            {equipment.map((item) => (
              <span
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium"
                style={`background-color: ${light}; color: ${accent};`}
              >
                <Icon name="lucide:check" class="w-4 h-4 shrink-0" aria-hidden="true" />
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- Layout configurations -->
        <div>
          <h3 class="font-heading text-lg font-bold mb-4" style={`color: ${accent};`}>
            {t('salle.venue.configurationsTitle')}
          </h3>
          <div class="grid grid-cols-2 gap-3">
            {layoutOptions.map((layout) => (
              <div class="flex items-center justify-between rounded-xl border border-gray-200/60 px-4 py-3 bg-white">
                <span class="font-medium text-gray-800">{layout.name}</span>
                <span class="text-sm font-bold" style={`color: ${accent};`}>
                  {layout.capacity} {t('common.personsShort')}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
