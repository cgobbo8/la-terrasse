---
/**
 * VenueSpecs — Scannable spec sheet for corporate planners
 * Salle accent from poleConfigs, icon + label + value grid
 * Pure Astro component, no Svelte island needed
 */
import Icon from '@/components/common/Icon.astro';
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';
import { poleConfigs } from '@/lib/pole-config';

interface Props {
  capacityMax: number;
  surfaceM2: number;
  equipment: readonly string[];
  layoutSuggestions: readonly string[];
  lang?: Lang;
}

const { capacityMax, surfaceM2, equipment, layoutSuggestions, lang = 'fr' } = Astro.props;
const t = useTranslations(lang);
const { accent, light } = poleConfigs.salle;
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Left column: venue photo + key figures -->
      <div class="space-y-8">
        <img
          src="/images/salle/espace.webp"
          alt="La salle événementielle"
          class="aspect-[4/3] w-full rounded-2xl object-cover"
          loading="lazy"
        />

        <!-- Key figures row -->
        <div class="grid grid-cols-2 gap-4">
          <div class="text-center rounded-xl p-5" style={`background-color: ${light};`}>
            <div class="font-heading text-3xl lg:text-4xl font-bold" style={`color: ${accent};`}>
              {capacityMax}
            </div>
            <div class="text-sm text-gray-600 mt-1">{t('salle.venue.capacityLabel')}</div>
          </div>
          <div class="text-center rounded-xl p-5" style={`background-color: ${light};`}>
            <div class="font-heading text-3xl lg:text-4xl font-bold" style={`color: ${accent};`}>
              {surfaceM2}<span class="text-lg font-normal"> m²</span>
            </div>
            <div class="text-sm text-gray-600 mt-1">{t('salle.venue.surfaceLabel')}</div>
          </div>
        </div>
      </div>

      <!-- Right column: equipment + layout suggestions -->
      <div class="space-y-8">
        <!-- Equipment -->
        <div>
          <h3 class="font-heading text-lg font-bold mb-4 text-gray-900">
            {t('salle.venue.equipmentTitle')}
          </h3>
          <div class="flex flex-wrap gap-2">
            {equipment.map((item) => (
              <span
                class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium"
                style={`background-color: ${light}; color: ${accent};`}
              >
                <Icon name="lucide:check" class="w-4 h-4 shrink-0" aria-hidden="true" />
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- Layout suggestions -->
        <div>
          <h3 class="font-heading text-lg font-bold mb-4 text-gray-900">
            {t('salle.venue.layoutTitle')}
          </h3>
          <div class="flex flex-wrap gap-2">
            {layoutSuggestions.map((name) => (
              <span class="inline-flex items-center gap-2 rounded-xl border border-gray-200/60 px-4 py-2.5 bg-white text-sm font-medium text-gray-800">
                <Icon name="lucide:layout-grid" class="w-4 h-4 shrink-0" style={`color: ${accent};`} aria-hidden="true" />
                {name}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
