---
/**
 * Hero section — used on every pole page as the emotional entry point.
 * Adapts color accent based on the pole.
 */
import { Image } from 'astro:assets';
import Sunburst from '@/components/common/Sunburst.astro';

interface Props {
  tagline: string;
  subtitle?: string;
  pole?: 'restaurant' | 'aventure' | 'salle' | null;
  /** Optional background image path */
  image?: string;
  /** Show a sunburst decoration (variant number) — bottom right, pole-colored */
  sunburst?: 1 | 2 | 3;
  /** Extra CSS classes on the outer section (e.g. min-height) */
  class?: string;
}

const { tagline, subtitle, pole = null, image, sunburst, class: className } = Astro.props;

const accentColors: Record<string, string> = {
  restaurant: 'from-restaurant/80',
  aventure: 'from-aventure/80',
  salle: 'from-salle/80',
};

const overlayClass = pole ? accentColors[pole] ?? 'from-brun-terre/80' : 'from-brun-terre/80';
---

<section
  class:list={['relative overflow-hidden bg-brun-terre -mt-16 min-h-[60vh] lg:min-h-[80vh] flex flex-col', className]}
  data-hero-parallax
>
  {image && (
    <Image
      src={image}
      alt=""
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover scale-[1.15] will-change-transform"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
      data-hero-image
    />
  )}
  <div class:list={['absolute inset-0 bg-gradient-to-t to-transparent', overlayClass]} />
  <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent" />

  <div class="h-16 shrink-0" aria-hidden="true"></div>

  <div class="relative flex-1 flex items-end pb-16 lg:pb-24">
    <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1
        class="font-heading text-4xl sm:text-5xl lg:text-7xl font-bold text-white max-w-3xl leading-[1.05]"
        data-hero-heading
      >
        {tagline}
      </h1>
      {subtitle && (
        <p class="mt-6 text-lg lg:text-xl text-white/70 max-w-2xl font-light" data-hero-sub>
          {subtitle}
        </p>
      )}
      <div class="mt-10" data-hero-cta>
        <slot />
      </div>
    </div>
  </div>

  {sunburst && (
    <div class="absolute -bottom-[12%] -right-[8%] w-[clamp(200px,28vw,400px)] aspect-square opacity-[0.15] pointer-events-none z-[1]" aria-hidden="true" data-hero-sunburst>
      <Sunburst variant={sunburst} pole={pole} size="100%" />
    </div>
  )}
</section>

<style>
  /* Hidden until GSAP reveals them — prevents flash */
  [data-hero-heading],
  [data-hero-sub],
  [data-hero-cta] {
    opacity: 0;
  }
  @media (prefers-reduced-motion: reduce) {
    [data-hero-heading],
    [data-hero-sub],
    [data-hero-cta] {
      opacity: 1 !important;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll<HTMLElement>('[data-hero-parallax]').forEach((section) => {
      // ── Parallax on image ──
      const image = section.querySelector<HTMLElement>('[data-hero-image]');
      if (image) {
        gsap.to(image, {
          y: '20%',
          ease: 'none',
          scrollTrigger: { trigger: section, start: 'top top', end: 'bottom top', scrub: true },
        });
      }

      const heading = section.querySelector<HTMLElement>('[data-hero-heading]');
      const sub = section.querySelector<HTMLElement>('[data-hero-sub]');
      const cta = section.querySelector<HTMLElement>('[data-hero-cta]');

      // ── h1: blur + scale + y ──
      if (heading) {
        gsap.fromTo(heading,
          { opacity: 0, y: 36, filter: 'blur(16px)', scale: 0.96 },
          { opacity: 1, y: 0, filter: 'blur(0px)', scale: 1, duration: 1.1, ease: 'power3.out', delay: 0.1 }
        );
      }

      // ── subtitle: lighter blur, offset delay ──
      if (sub) {
        gsap.fromTo(sub,
          { opacity: 0, y: 22, filter: 'blur(10px)' },
          { opacity: 1, y: 0, filter: 'blur(0px)', duration: 0.95, ease: 'power3.out', delay: 0.35 }
        );
      }

      // ── CTA slot: simple fade-up, last ──
      if (cta) {
        gsap.fromTo(cta,
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out', delay: 0.55 }
        );
      }

      // ── Sunburst: slow rotation on scroll ──
      const heroSunburst = section.querySelector<HTMLElement>('[data-hero-sunburst]');
      if (heroSunburst) {
        gsap.to(heroSunburst, {
          rotation: 60,
          ease: 'none',
          scrollTrigger: { trigger: section, start: 'top top', end: 'bottom top', scrub: 1.5 },
        });
      }
    });
  }
</script>
