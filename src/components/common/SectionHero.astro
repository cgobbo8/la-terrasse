---
/**
 * Hero section — used on every page as the emotional entry point.
 * Adapts color accent based on the pole.
 */
import { Image } from 'astro:assets';

interface Props {
  tagline: string;
  subtitle?: string;
  pole?: 'restaurant' | 'aventure' | 'salle' | null;
  /** Optional background image path */
  image?: string;
  /** Extra CSS classes on the outer section (e.g. min-height) */
  class?: string;
}

const { tagline, subtitle, pole = null, image, class: className } = Astro.props;

const accentColors: Record<string, string> = {
  restaurant: 'from-restaurant/80',
  aventure: 'from-aventure/80',
  salle: 'from-bleu-ardoise/80',
};

const overlayClass = pole ? accentColors[pole] ?? 'from-brun-terre/80' : 'from-brun-terre/80';
---

<section class:list={['relative overflow-hidden bg-brun-terre', className]}>
  {image && (
    <Image
      src={image}
      alt=""
      width={1920}
      height={1080}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
  )}
  <div class:list={['absolute inset-0 bg-gradient-to-t to-transparent', overlayClass]} />

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36">
    <h1 class="font-heading text-4xl lg:text-6xl font-bold text-white max-w-3xl">
      {tagline}
    </h1>
    {subtitle && (
      <p class="mt-6 text-lg lg:text-xl text-white/80 max-w-2xl">
        {subtitle}
      </p>
    )}
    <div class="mt-8">
      <slot />
    </div>
  </div>
</section>
