---
interface Props {
  label: string;
  href: string;
  accentColor: string;
  variant?: 'primary' | 'secondary' | 'ghost';
}

const { label, href, accentColor, variant = 'primary' } = Astro.props;

const baseClasses = 'inline-flex items-center justify-center min-h-11 px-4 font-medium text-sm rounded-lg transition-[filter] duration-150 hover:brightness-90';

const variantStyles: Record<string, string> = {
  primary: `background-color: ${accentColor}; color: #fff;`,
  secondary: `border: 1.5px solid ${accentColor}; color: ${accentColor};`,
  ghost: `color: ${accentColor};`,
};

const variantClasses: Record<string, string> = {
  primary: '',
  secondary: 'bg-transparent',
  ghost: 'bg-transparent underline-offset-2 hover:underline',
};
---

<a
  href={href}
  class:list={[baseClasses, variantClasses[variant]]}
  style={variantStyles[variant]}
>
  {label}
</a>
