---
import Icon from '@/components/common/Icon.astro';

interface Props {
  phone?: string;
  email?: string;
  variant?: 'header' | 'footer';
}

const { phone = '', email = '', variant = 'header' } = Astro.props;

function formatPhone(raw: string): string {
  const digits = raw.replace(/\D/g, '');
  if (digits.startsWith('33') && digits.length === 11) {
    const national = '0' + digits.slice(2);
    return national.replace(/(\d{2})(?=\d)/g, '$1 ');
  }
  return raw;
}
---

{variant === 'header' ? (
  <a
    href={`tel:${phone}`}
    class="inline-flex items-center gap-1.5 min-h-11 text-sm text-gray-600 hover:text-brun-terre transition-colors"
  >
    <Icon name="lucide:phone" class="w-4 h-4 shrink-0" />
    <span>{formatPhone(phone)}</span>
  </a>
) : (
  <div class="flex flex-col gap-2 text-sm">
    <a
      href={`tel:${phone}`}
      class="inline-flex items-center gap-2 min-h-11 hover:text-brun-terre transition-colors"
    >
      <Icon name="lucide:phone" class="w-4 h-4 shrink-0" />
      <span>{formatPhone(phone)}</span>
    </a>
    {email && (
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 min-h-11 hover:text-brun-terre transition-colors"
      >
        <Icon name="lucide:mail" class="w-4 h-4 shrink-0" />
        <span>{email}</span>
      </a>
    )}
  </div>
)}
