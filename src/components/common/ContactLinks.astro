---
import { PHONE_NUMBER, EMAIL_ADDRESS } from '@/lib/pole-config';

interface Props {
  phone?: string;
  email?: string;
  variant?: 'header' | 'footer';
}

const { phone = PHONE_NUMBER, email = EMAIL_ADDRESS, variant = 'header' } = Astro.props;

function formatPhone(raw: string): string {
  const digits = raw.replace(/\D/g, '');
  if (digits.startsWith('33') && digits.length === 11) {
    const national = '0' + digits.slice(2);
    return national.replace(/(\d{2})(?=\d)/g, '$1 ');
  }
  return raw;
}
---

{variant === 'header' ? (
  <a
    href={`tel:${phone}`}
    class="inline-flex items-center gap-1.5 min-h-11 text-sm text-gray-600 hover:text-brun-terre transition-colors"
  >
    <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
    </svg>
    <span>{formatPhone(phone)}</span>
  </a>
) : (
  <div class="flex flex-col gap-2 text-sm">
    <a
      href={`tel:${phone}`}
      class="inline-flex items-center gap-2 min-h-11 hover:text-white transition-colors"
    >
      <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
      </svg>
      <span>{formatPhone(phone)}</span>
    </a>
    {email && (
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 min-h-11 hover:text-white transition-colors"
      >
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 7l-10 7L2 7" />
        </svg>
        <span>{email}</span>
      </a>
    )}
  </div>
)}
