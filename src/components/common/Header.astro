---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { languages, type Lang } from '@/i18n/translations';
import { getCtaForPole } from '@/lib/pole-config';
import MegaMenu from './MegaMenu.svelte';
import MobileMenu from './MobileMenu.svelte';
import LogoTerrasse from './LogoTerrasse.astro';
import LogoTerrasseFull from './LogoTerrasseFull.astro';

interface Props {
  pole?: 'restaurant' | 'aventure' | 'salle' | null;
  ctaLabel?: string;
  ctaHref?: string;
}

const { pole = null, ctaLabel: ctaLabelOverride, ctaHref: ctaHrefOverride } = Astro.props;
const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);
const cta = getCtaForPole(pole);

const ctaLabelLocalized = ctaLabelOverride ?? (pole === 'aventure'
  ? t('aventure.cta.label')
  : pole === 'restaurant'
    ? t('restaurant.cta.label')
    : pole === 'salle'
      ? t('common.contact')
      : t('common.contact'));

// Build navigation data for Svelte components
const megaMenuPoles = [
  {
    id: 'restaurant',
    label: t('nav.restaurant'),
    href: getLocalizedPath('/restaurant', lang),
    color: pole === 'restaurant' ? 'text-restaurant' : 'text-gray-600',
    accentColor: 'restaurant',
    subLinks: [
      { label: t('nav.restaurant.carte'), href: getLocalizedPath('/restaurant/carte', lang), description: t('nav.restaurant.carte.desc'), icon: 'menu' },
      { label: t('restaurant.producers.title'), href: getLocalizedPath('/restaurant/producteurs', lang), description: t('nav.restaurant.producteurs.desc'), icon: 'leaf' },
    ],
    featured: {
      title: t('nav.restaurant.featured.title'),
      description: t('nav.restaurant.featured.desc'),
      href: getLocalizedPath('/restaurant', lang),
      cta: t('nav.restaurant.featured.cta'),
    },
    crossSell: {
      text: t('nav.restaurant.crossSell'),
      href: getLocalizedPath('/aventure', lang),
      targetPole: 'aventure',
    },
  },
  {
    id: 'aventure',
    label: t('nav.aventure'),
    href: getLocalizedPath('/aventure', lang),
    color: pole === 'aventure' ? 'text-aventure' : 'text-gray-600',
    accentColor: 'aventure',
    subLinks: [
      { label: t('nav.aventure.aquatiques'), href: getLocalizedPath('/aventure', lang) + '#activites', description: t('nav.aventure.aquatiques.desc'), icon: 'waves' },
      { label: t('nav.aventure.terrestres'), href: getLocalizedPath('/aventure', lang) + '#terrestres', description: t('nav.aventure.terrestres.desc'), icon: 'flag' },
      { label: t('nav.aventure.passJournee'), href: getLocalizedPath('/aventure', lang) + '#pass-journee', description: t('nav.aventure.passJournee.desc'), icon: 'sun' },
    ],
    featured: {
      title: t('nav.aventure.featured.title'),
      description: t('nav.aventure.featured.desc'),
      href: getLocalizedPath('/aventure', lang),
      cta: t('nav.aventure.featured.cta'),
    },
    crossSell: {
      text: t('nav.aventure.crossSell'),
      href: getLocalizedPath('/restaurant', lang),
      targetPole: 'restaurant',
    },
  },
  {
    id: 'salle',
    label: t('nav.salle'),
    href: getLocalizedPath('/la-salle', lang),
    color: pole === 'salle' ? 'text-bleu-ardoise' : 'text-gray-600',
    accentColor: 'salle',
    subLinks: [
      { label: t('nav.salle.evenementiel'), href: getLocalizedPath('/la-salle/evenementiel', lang), description: t('nav.salle.evenementiel.desc'), icon: 'music' },
      { label: t('nav.salle.seminairesPro'), href: getLocalizedPath('/la-salle/seminaires', lang), description: t('nav.salle.seminairesPro.desc'), icon: 'briefcase' },
    ],
    featured: {
      title: t('nav.salle.featured.title'),
      description: t('nav.salle.featured.desc'),
      href: getLocalizedPath('/la-salle', lang),
      cta: t('nav.salle.featured.cta'),
    },
    crossSell: {
      text: t('nav.salle.crossSell'),
      href: getLocalizedPath('/restaurant', lang),
      targetPole: 'restaurant',
    },
  },
];

const agendaLink = { label: t('nav.agenda'), href: getLocalizedPath('/agenda', lang) };

const mobilePoles = megaMenuPoles.map(p => ({
  id: p.id,
  label: p.label,
  href: p.href,
  colorClass: p.color,
  subLinks: p.subLinks.map(s => ({ label: s.label, href: s.href })),
}));

const contactHref = ctaHrefOverride ?? getLocalizedPath('/contact', lang);

// Build language switcher paths
const langPaths: Record<string, string> = {};
for (const code of Object.keys(languages)) {
  const cleanPath = Astro.url.pathname.replace(/^\/(en|es)/, '');
  langPaths[code] = getLocalizedPath(cleanPath || '/', code as Lang);
}

const accentColors: Record<string, string> = {
  restaurant: 'text-restaurant',
  aventure: 'text-aventure',
  salle: 'text-bleu-ardoise',
};
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-[background-color,border-color,backdrop-filter] duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 transition-colors duration-300" data-header-logo>
        <!-- Mobile: single-letter logo -->
        <LogoTerrasse color="currentColor" height="1.5rem" class="lg:hidden" />
        <!-- Desktop: full logo + pole label -->
        <LogoTerrasseFull color="currentColor" height="1rem" class="hidden lg:block" />
        {pole && (
          <span class="hidden lg:inline whitespace-nowrap font-heading text-sm font-medium uppercase tracking-wider transition-colors duration-300" data-pole-label data-pole-color={accentColors[pole] ?? ''}>
            {pole === 'restaurant' ? t('nav.restaurant') : pole === 'aventure' ? t('nav.aventure') : t('nav.pole.salle')}
          </span>
        )}
      </a>

      <MegaMenu
        client:only="svelte"
        poles={megaMenuPoles}
        agendaLink={agendaLink}
        ctaLabel={ctaLabelLocalized}
        ctaHref={contactHref}
        ctaColor={cta.accent}
        currentPole={pole}
        languages={languages}
        currentLang={lang}
        langPaths={langPaths}
        labelExplore={t('nav.explore')}
      />

      <!-- Mobile: Burger only (slide-out panel portals to body) -->
      <MobileMenu
        client:only="svelte"
        poles={mobilePoles}
        agendaLink={agendaLink}
        ctaLabel={ctaLabelLocalized}
        ctaHref={contactHref}
        ctaColor={cta.accent}
        languages={languages}
        currentLang={lang}
        langPaths={langPaths}
        labelClose={t('nav.close')}
        labelCloseMenu={t('nav.closeMenu')}
        labelSubmenu={t('nav.submenu')}
      />
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById('site-header');
  function onScroll() {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
