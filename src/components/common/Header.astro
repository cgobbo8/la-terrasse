---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { languages, type Lang } from '@/i18n/translations';
import { getCtaForPole, PHONE_NUMBER } from '@/lib/pole-config';
import MegaMenu from './MegaMenu.svelte';
import MobileMenu from './MobileMenu.svelte';
import CTAButton from './CTAButton.astro';
import ContactLinks from './ContactLinks.astro';
import LogoTerrasse from './LogoTerrasse.astro';

interface Props {
  pole?: 'restaurant' | 'aventure' | 'evenements' | null;
}

const { pole = null } = Astro.props;
const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);
const cta = getCtaForPole(pole);

const ctaLabelLocalized = pole === 'aventure'
  ? t('aventure.cta.label')
  : pole === 'restaurant'
    ? t('restaurant.cta.label')
    : pole === 'evenements'
      ? t('common.requestQuote')
      : t('common.contact');

// Build navigation data for Svelte components
const megaMenuPoles = [
  {
    id: 'restaurant',
    label: t('nav.restaurant'),
    href: getLocalizedPath('/restaurant', lang),
    color: pole === 'restaurant' ? 'text-restaurant' : 'text-gray-600',
    accentColor: 'restaurant',
    subLinks: [
      { label: t('nav.restaurant.carte'), href: getLocalizedPath('/restaurant/carte', lang), description: t('nav.restaurant.carte.desc'), icon: 'menu' },
      { label: t('restaurant.producers.title'), href: getLocalizedPath('/restaurant/producteurs', lang), description: t('nav.restaurant.producteurs.desc'), icon: 'leaf' },
      { label: t('restaurant.groups.title'), href: getLocalizedPath('/restaurant/repas-groupe', lang), description: t('nav.restaurant.groupes.desc'), icon: 'users' },
    ],
    featured: {
      title: t('nav.restaurant.featured.title'),
      description: t('nav.restaurant.featured.desc'),
      href: getLocalizedPath('/restaurant', lang),
      cta: t('nav.restaurant.featured.cta'),
    },
    crossSell: {
      text: t('nav.restaurant.crossSell'),
      href: getLocalizedPath('/aventure', lang),
      targetPole: 'aventure',
    },
  },
  {
    id: 'aventure',
    label: t('nav.aventure'),
    href: getLocalizedPath('/aventure', lang),
    color: pole === 'aventure' ? 'text-aventure' : 'text-gray-600',
    accentColor: 'aventure',
    subLinks: [
      { label: t('nav.aventure.pedalo'), href: getLocalizedPath('/aventure/pedalo', lang), description: t('nav.aventure.pedalo.desc'), icon: 'boat' },
      { label: t('nav.aventure.paddle'), href: getLocalizedPath('/aventure/paddle', lang), description: t('nav.aventure.paddle.desc'), icon: 'waves' },
      { label: t('nav.aventure.miniGolf'), href: getLocalizedPath('/aventure/mini-golf', lang), description: t('nav.aventure.miniGolf.desc'), icon: 'flag' },
      { label: t('nav.aventure.all'), href: getLocalizedPath('/aventure', lang) + '#activites', description: t('nav.aventure.all.desc'), icon: 'compass' },
    ],
    featured: {
      title: t('nav.aventure.featured.title'),
      description: t('nav.aventure.featured.desc'),
      href: getLocalizedPath('/aventure', lang),
      cta: t('nav.aventure.featured.cta'),
    },
    crossSell: {
      text: t('nav.aventure.crossSell'),
      href: getLocalizedPath('/restaurant', lang),
      targetPole: 'restaurant',
    },
  },
  {
    id: 'evenements',
    label: t('nav.evenements'),
    href: getLocalizedPath('/evenements', lang),
    color: pole === 'evenements' ? 'text-bleu-ardoise' : 'text-gray-600',
    accentColor: 'evenements',
    subLinks: [
      { label: t('nav.evenements.salle'), href: getLocalizedPath('/evenements', lang) + '#salle', description: t('nav.evenements.salle.desc'), icon: 'building' },
      { label: t('nav.evenements.simple'), href: getLocalizedPath('/evenements/seminaire-simple', lang), description: t('nav.evenements.simple.desc'), icon: 'briefcase' },
      { label: t('nav.evenements.gourmet'), href: getLocalizedPath('/evenements/seminaire-gourmet', lang), description: t('nav.evenements.gourmet.desc'), icon: 'utensils' },
      { label: t('nav.evenements.aventure'), href: getLocalizedPath('/evenements/seminaire-aventure', lang), description: t('nav.evenements.aventure.desc'), icon: 'trophy' },
    ],
    featured: {
      title: t('nav.evenements.featured.title'),
      description: t('nav.evenements.featured.desc'),
      href: getLocalizedPath('/evenements', lang),
      cta: t('nav.evenements.featured.cta'),
    },
    crossSell: {
      text: t('nav.evenements.crossSell'),
      href: getLocalizedPath('/en-entreprise', lang),
      targetPole: 'evenements',
    },
  },
];

const transversalItems = [
  { label: t('nav.enFamille'), href: getLocalizedPath('/en-famille', lang), description: t('nav.famille.desc') },
  { label: t('nav.enGroupe'), href: getLocalizedPath('/en-groupe', lang), description: t('nav.groupe.desc') },
  { label: t('nav.enEntreprise'), href: getLocalizedPath('/en-entreprise', lang), description: t('nav.entreprise.desc') },
];

const mobilePoles = megaMenuPoles.map(p => ({
  id: p.id,
  label: p.label,
  href: p.href,
  colorClass: p.color,
  subLinks: p.subLinks.map(s => ({ label: s.label, href: s.href })),
}));

const mobileTransversal = transversalItems.map(t => ({ label: t.label, href: t.href }));

const contactHref = getLocalizedPath('/contact', lang);
const contactLabel = t('common.contact');
const phoneNumber = PHONE_NUMBER;

// Build language switcher paths
const langPaths: Record<string, string> = {};
for (const code of Object.keys(languages)) {
  const cleanPath = Astro.url.pathname.replace(/^\/(en|es)/, '');
  langPaths[code] = getLocalizedPath(cleanPath || '/', code as Lang);
}

const accentColors: Record<string, string> = {
  restaurant: 'text-restaurant',
  aventure: 'text-aventure',
  evenements: 'text-bleu-ardoise',
};
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2">
        <LogoTerrasse color="#2D2B1B" height="1.5rem" />
        {pole && (
          <span class={`font-heading text-sm font-medium uppercase tracking-wider ${accentColors[pole] ?? ''}`}>
            {pole === 'restaurant' ? t('nav.restaurant') : pole === 'aventure' ? t('nav.aventure') : t('nav.pole.evenement')}
          </span>
        )}
      </a>

      <!-- Desktop: CTA + Phone + Mega Menu -->
      <div class="hidden lg:flex items-center gap-3">
        <ContactLinks phone={phoneNumber} variant="header" />
      </div>

      <MegaMenu
        client:load
        poles={megaMenuPoles}
        transversalItems={transversalItems}
        ctaLabel={ctaLabelLocalized}
        ctaHref={cta.href}
        ctaColor={cta.accent}
        currentPole={pole}
        languages={languages}
        currentLang={lang}
        langPaths={langPaths}
        labelExplore={t('nav.explore')}
        labelExperiences={t('nav.experiences')}
        labelComposeDay={t('nav.composeDay')}
      />

      <!-- Mobile: Burger only (slide-out panel portals to body) -->
      <MobileMenu
        client:load
        poles={mobilePoles}
        transversalItems={mobileTransversal}
        ctaLabel={ctaLabelLocalized}
        ctaHref={cta.href}
        ctaColor={cta.accent}
        phoneNumber={phoneNumber}
        languages={languages}
        currentLang={lang}
        langPaths={langPaths}
        labelExperiences={t('nav.experiences')}
        labelClose={t('nav.close')}
        labelCloseMenu={t('nav.closeMenu')}
        labelSubmenu={t('nav.submenu')}
      />
    </div>
  </nav>
</header>
