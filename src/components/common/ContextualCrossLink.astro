---
/**
 * Contextual narrative cross-link (Layer 2)
 * Warm, page-specific suggestion to another pole.
 * Refined ghost style with arrow.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  /** Narrative sentence — must be unique per page, never generic */
  text: string;
  /** Destination link */
  href: string;
  /** Target pole — determines accent color */
  pole: 'restaurant' | 'aventure' | 'salle';
}

const { text, href, pole } = Astro.props;

const accentColors = {
  restaurant: '#2D2B1B',
  aventure: '#537b47',
  salle: '#3d4969',
} as const;

const accent = accentColors[pole];
---

<aside class="py-10 lg:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <a
      href={href}
      class="group inline-flex items-center gap-3 text-lg lg:text-xl italic font-semibold leading-relaxed transition-all hover:-translate-y-px"
      style={`color: ${accent}`}
    >
      <span class="underline underline-offset-4 decoration-current/30 group-hover:decoration-current/80 transition-colors">
        {text}
      </span>
      <Icon name="lucide:arrow-right" class="w-5 h-5 transition-transform duration-200 group-hover:translate-x-1 flex-shrink-0" />
    </a>
  </div>
</aside>
