---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import ContactLinks from './ContactLinks.astro';
import LogoTerrasseFull from './LogoTerrasseFull.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  phone: string;
  email: string;
  googleMapsUrl?: string;
  facebook?: string;
  instagram?: string;
}

const { phone, email, googleMapsUrl = '', facebook = '', instagram = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);
---

<footer class="bg-gray-100 text-gray-600 overflow-hidden">
  <!-- Decorative top border -->
  <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent" aria-hidden="true"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-10">
    <!-- Top section: logo + tagline -->
    <div class="mb-16 text-center">
      <LogoTerrasseFull class="mx-auto" />
      <p class="mt-3 text-sm text-gray-400 max-w-xs mx-auto">
        {t('footer.tagline')}
      </p>
    </div>

    <!-- Links grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-16">
      <!-- Restaurant -->
      <div>
        <h3 class="font-heading font-bold text-brun-terre text-xs uppercase tracking-[0.15em] mb-5">
          {t('nav.restaurant')}
        </h3>
        <ul class="space-y-3 text-sm">
          <li><a href={getLocalizedPath('/restaurant', lang)} class="hover:text-brun-terre transition-colors">{t('footer.restaurantLink')}</a></li>
          <li><a href={getLocalizedPath('/restaurant/carte', lang)} class="hover:text-brun-terre transition-colors">{t('nav.restaurant.carte')}</a></li>
          <li><a href={getLocalizedPath('/restaurant/producteurs', lang)} class="hover:text-brun-terre transition-colors">{t('restaurant.producers.title')}</a></li>
        </ul>
      </div>

      <!-- Aventure -->
      <div>
        <h3 class="font-heading font-bold text-brun-terre text-xs uppercase tracking-[0.15em] mb-5">
          {t('nav.aventure')}
        </h3>
        <ul class="space-y-3 text-sm">
          <li><a href={getLocalizedPath('/aventure', lang)} class="hover:text-brun-terre transition-colors">{t('footer.activitiesLink')}</a></li>
          <li><a href={getLocalizedPath('/agenda', lang)} class="hover:text-brun-terre transition-colors">{t('nav.agenda')}</a></li>
        </ul>
      </div>

      <!-- La Salle -->
      <div>
        <h3 class="font-heading font-bold text-brun-terre text-xs uppercase tracking-[0.15em] mb-5">
          {t('nav.salle')}
        </h3>
        <ul class="space-y-3 text-sm">
          <li><a href={getLocalizedPath('/la-salle', lang)} class="hover:text-brun-terre transition-colors">{t('footer.salleLink')}</a></li>
          <li><a href={getLocalizedPath('/la-salle/seminaires', lang)} class="hover:text-brun-terre transition-colors">{t('nav.salle.seminairesPro')}</a></li>
          <li><a href={getLocalizedPath('/la-salle/evenementiel', lang)} class="hover:text-brun-terre transition-colors">{t('nav.salle.evenementiel')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading font-bold text-brun-terre text-xs uppercase tracking-[0.15em] mb-5">
          {t('common.contact')}
        </h3>
        <div class="text-sm space-y-4">
          <!-- Address mini-card → Google Maps -->
          <a
            href={googleMapsUrl || '#'}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t('contact.map.fallback')}
            class="group flex items-start gap-3 p-3 -mx-1 rounded-lg border border-gray-200/70 bg-white/50 hover:bg-white hover:border-brun-terre/30 transition-all"
          >
            <span class="flex-shrink-0 w-8 h-8 rounded-md bg-brun-terre/5 flex items-center justify-center group-hover:bg-brun-terre/10 transition-colors">
              <Icon name="lucide:map-pin" class="w-4 h-4 text-brun-terre/70 group-hover:text-brun-terre transition-colors" stroke-width="1.5" />
            </span>
            <div class="flex-1 min-w-0 leading-snug">
              <p class="text-gray-700 group-hover:text-brun-terre transition-colors">{t('contact.info.address')}</p>
              <p class="text-xs text-gray-400 mt-0.5">{t('contact.info.city')}</p>
            </div>
          </a>

          <!-- Phone + email -->
          <ContactLinks phone={phone} email={email} variant="footer" />

          <!-- Socials -->
          {(facebook || instagram) && (
            <div class="flex items-center gap-4 pt-1">
              {facebook && (
                <a
                  href={facebook}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Facebook"
                  class="inline-flex items-center justify-center w-8 h-8 hover:text-brun-terre transition-colors"
                >
                  <Icon name="lucide:facebook" class="w-4 h-4" stroke-width="1.5" />
                </a>
              )}
              {instagram && (
                <a
                  href={instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Instagram"
                  class="inline-flex items-center justify-center w-8 h-8 hover:text-brun-terre transition-colors"
                >
                  <Icon name="lucide:instagram" class="w-4 h-4" stroke-width="1.5" />
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Bottom bar: copyright + legal links -->
    <div class="mt-16 pt-8 border-t border-gray-200 flex flex-col items-center gap-4 text-xs text-gray-400">
      <p class="italic text-gray-400/60">{t('footer.photoDisclaimer')}</p>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 w-full">
      <p>&copy; {new Date().getFullYear()} La Terrasse — Base de loisirs de Saint-Ferréol</p>
      <nav class="flex items-center gap-6" aria-label="Legal">
        <a href={getLocalizedPath('/mentions-legales', lang)} class="hover:text-brun-terre transition-colors">
          {t('footer.legalNotice')}
        </a>
        <a href={getLocalizedPath('/confidentialite', lang)} class="hover:text-brun-terre transition-colors">
          {t('footer.privacy')}
        </a>
      </nav>
      </div>
    </div>
  </div>
</footer>
