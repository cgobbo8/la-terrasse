---
/**
 * Cross-linking structural block (Layer 1)
 * Compact, discreet links at bottom of every pole page.
 */
import { Icon } from 'astro-icon/components';
import { getLangFromUrl, useTranslations, getLocalizedPath, getLocalizedField } from '@/i18n/utils';
import { poleConfigs, type Pole } from '@/lib/pole-config';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

interface Props {
  /** Current pole to exclude from suggestions */
  currentPole: Pole;
}

const { currentPole } = Astro.props;
const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const reader = createReader(process.cwd(), keystaticConfig);
const crosslinks = await reader.singletons.crosslinks.read();
const polesDesc = (crosslinks?.polesDescription ?? {}) as Record<string, unknown>;

const poles = [
  {
    id: 'restaurant' as const,
    label: t('nav.restaurant'),
    description: getLocalizedField(polesDesc, 'restaurant', lang),
    href: getLocalizedPath('/restaurant', lang),
    accent: poleConfigs.restaurant.accent,
    icon: 'lucide:utensils',
  },
  {
    id: 'aventure' as const,
    label: t('nav.aventure'),
    description: getLocalizedField(polesDesc, 'aventure', lang),
    href: getLocalizedPath('/aventure', lang),
    accent: poleConfigs.aventure.accent,
    icon: 'lucide:mountain',
  },
  {
    id: 'salle' as const,
    label: t('nav.salle'),
    description: getLocalizedField(polesDesc, 'salle', lang),
    href: getLocalizedPath('/la-salle', lang),
    accent: poleConfigs.salle.accent,
    icon: 'lucide:building-2',
  },
];

const otherPoles = poles.filter((p) => p.id !== currentPole);
---

<section class="py-10 lg:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="section-eyebrow text-gray-400 text-center mb-6">
      {t('common.alsoAt')}
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {otherPoles.map((pole) => (
        <a
          href={pole.href}
          class="group flex items-center gap-4 p-5 rounded-2xl border border-gray-200/60 bg-white card-hover"
        >
          <span
            class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center"
            style={`background-color: ${pole.accent}0a;`}
          >
            <Icon
              name={pole.icon}
              class="w-5 h-5"
              style={`color: ${pole.accent};`}
            />
          </span>
          <span class="min-w-0 flex-1">
            <span class="block text-sm font-bold text-gray-800 group-hover:text-gray-900 transition-colors">
              La Terrasse {pole.label}
            </span>
            <span class="block text-xs text-gray-400 mt-0.5">{pole.description}</span>
          </span>
          <Icon
            name="lucide:arrow-right"
            class="w-4 h-4 text-gray-300 group-hover:text-gray-500 transition-all duration-200 group-hover:translate-x-0.5 flex-shrink-0"
          />
        </a>
      ))}
    </div>
  </div>
</section>
