---
/**
 * Cross-linking structural block (Layer 1)
 * Permanent block at bottom of every pole page:
 * "La Terrasse c'est aussi..."
 */
import { getLangFromUrl, useTranslations, getLocalizedPath } from '@/i18n/utils';
import { Image } from 'astro:assets';

interface Props {
  /** Current pole to exclude from suggestions */
  currentPole: 'restaurant' | 'aventure' | 'salle';
}

const { currentPole } = Astro.props;
const lang = getLangFromUrl(Astro.url, Astro.currentLocale);
const t = useTranslations(lang);

const poles = [
  {
    id: 'restaurant' as const,
    label: t('nav.restaurant'),
    description: t('crosslink.restaurant.description'),
    href: getLocalizedPath('/restaurant', lang),
    color: 'bg-restaurant-light border-restaurant/20',
    textColor: 'text-restaurant',
    accent: '#2D2B1B',
    image: '/images/placeholders/emma-harper.webp',
  },
  {
    id: 'aventure' as const,
    label: t('nav.aventure'),
    description: t('crosslink.aventure.description'),
    href: getLocalizedPath('/aventure', lang),
    color: 'bg-aventure-light border-aventure/20',
    textColor: 'text-aventure',
    accent: '#537b47',
    image: '/images/placeholders/pietro-de-grandi.webp',
  },
  {
    id: 'salle' as const,
    label: t('nav.salle'),
    description: t('crosslink.salle.description'),
    href: getLocalizedPath('/la-salle', lang),
    color: 'bg-salle-light border-bleu-ardoise/20',
    textColor: 'text-bleu-ardoise',
    accent: '#3d4969',
    image: '/images/placeholders/nils-lindner.webp',
  },
];

const otherPoles = poles.filter((p) => p.id !== currentPole);
---

<section class="py-(--spacing-section-mobile) lg:py-(--spacing-section) bg-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="font-heading text-2xl font-bold text-brun-terre mb-8 text-center">
      {t('common.alsoAt')}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {otherPoles.map((pole) => (
        <a
          href={pole.href}
          class:list={[
            'group block rounded-2xl border overflow-hidden transition-all hover:shadow-lg hover:-translate-y-1',
            pole.color,
          ]}
        >
          <div class="aspect-[16/9] overflow-hidden">
            <Image
              src={pole.image}
              alt={`La Terrasse ${pole.label}`}
              width={800}
              height={450}
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="p-6">
            <h3 class:list={['font-heading text-xl font-bold mb-2', pole.textColor]}>
              La Terrasse {pole.label}
            </h3>
            <p class="text-gray-600 text-sm mb-4">{pole.description}</p>
            <span
              class="text-sm font-medium transition-all group-hover:underline"
              style={`color: ${pole.accent}`}
            >
              {t('common.discover')} →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
