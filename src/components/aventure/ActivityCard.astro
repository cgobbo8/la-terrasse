---
/**
 * ActivityCard — Reusable card for activity grid (Aventure pole).
 * Zero JS shipped — pure Astro with CSS-only hover.
 * Matches original card design: rounded-2xl, translate-y hover, "Découvrir →" CTA.
 */
import { getLocalizedField, getLocalizedPath } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

interface Activity {
  title: string;
  slug: string;
  price: string;
  priceDetails: string;
  age_min: number | null;
  duration: string;
  image: string | null;
  description: string;
  title_en?: string;
  title_es?: string;
  description_en?: string;
  description_es?: string;
}

interface Props {
  activity: Activity;
  lang: Lang;
  placeholderImage: string;
  /** Card background — aventure-light for aquatic, white for terrestrial */
  variant?: 'aquatique' | 'terrestre';
}

const { activity, lang, placeholderImage, variant = 'terrestre' } = Astro.props;
const t = useTranslations(lang);

const localizedTitle = getLocalizedField(activity, 'title', lang);
const imageSrc = activity.image || placeholderImage;
const href = getLocalizedPath(`/aventure/${activity.slug}`, lang);

const cardBg = variant === 'aquatique' ? 'bg-aventure-light' : 'bg-white';
const cardBorder = variant === 'aquatique' ? 'border-aventure/10' : 'border-gray-200';
---

<a
  href={href}
  class:list={[
    'group block rounded-2xl overflow-hidden border hover:shadow-lg hover:-translate-y-1 transition-all',
    cardBg,
    cardBorder,
  ]}
>
  <div class="aspect-[16/10] overflow-hidden">
    <img
      src={imageSrc}
      alt={localizedTitle}
      width="640"
      height="400"
      loading="lazy"
      class="w-full h-full object-cover"
    />
  </div>

  <div class="p-6">
    <h3 class="font-heading text-lg font-bold text-aventure">{localizedTitle}</h3>

    <p class="mt-2 text-sm text-gray-600">
      <span class="font-semibold">{activity.price}</span>
      {activity.priceDetails && (
        <span class="text-gray-400"> — {activity.priceDetails}</span>
      )}
    </p>

    <div class="mt-2 flex flex-wrap gap-1.5">
      {activity.age_min != null && activity.age_min > 0 && (
        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
          </svg>
          Dès {activity.age_min} ans
        </span>
      )}
      {activity.duration && (
        <span class="inline-flex items-center gap-1 text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
          </svg>
          {activity.duration}
        </span>
      )}
    </div>

    <span class="inline-block mt-3 text-sm text-aventure font-medium group-hover:underline">
      {t('common.discover')} →
    </span>
  </div>
</a>
