---
/**
 * ActivityCard — Reusable card for activity grid (Aventure pole).
 * Zero JS shipped — pure Astro with CSS-only hover.
 */
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { getLocalizedField, getLocalizedPath } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import type { Lang } from '@/i18n/translations';

interface Activity {
  title: string;
  slug: string;
  price: string;
  priceDetails: string;
  age_min: number | null;
  duration: string;
  image: string | null;
  description: string;
  title_en?: string;
  title_es?: string;
  description_en?: string;
  description_es?: string;
  isPremium?: boolean;
}

interface Props {
  activity: Activity;
  lang: Lang;
  placeholderImage: string;
  /** Card background — aventure-light for aquatic, white for terrestrial */
  variant?: 'aquatique' | 'terrestre';
}

const { activity, lang, placeholderImage, variant = 'terrestre' } = Astro.props;
const t = useTranslations(lang);

const localizedTitle = getLocalizedField(activity, 'title', lang);
const imageSrc = activity.image || placeholderImage;
const href = getLocalizedPath(`/aventure/${activity.slug}`, lang);

const cardBg = 'bg-white';
const cardBorder = 'border-gray-200/60';
---

<a
  href={href}
  class:list={[
    'group block rounded-2xl overflow-hidden border card-hover',
    cardBg,
    cardBorder,
  ]}
>
  <div class="relative aspect-[16/10] overflow-hidden">
    <Image
      src={imageSrc}
      alt={localizedTitle}
      width={640}
      height={400}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover card-zoom-img"
    />
    {activity.isPremium && (
      <div class="absolute top-3 right-3 bg-white/95 backdrop-blur-sm rounded-full px-2.5 py-1 flex items-center gap-1 shadow-sm" title="Activité phare — éligible à l'offre journée">
        <Icon name="lucide:star" class="w-3.5 h-3.5 text-amber-500" />
        <span class="text-xs font-semibold text-gray-700">Activité phare</span>
      </div>
    )}
  </div>

  <div class="p-6">
    <h3 class="font-heading text-lg font-bold text-gray-900">{localizedTitle}</h3>

    <p class="mt-2 text-sm text-gray-600">
      <span class="font-semibold">{activity.price}</span>
      {activity.priceDetails && (
        <span class="text-gray-400"> — {activity.priceDetails}</span>
      )}
    </p>

    <div class="mt-3 flex flex-wrap gap-1.5">
      {activity.age_min != null && activity.age_min > 0 && (
        <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-gray-100 text-gray-500 font-medium">
          <Icon name="lucide:user" class="w-3 h-3" />
          Dès {activity.age_min} ans
        </span>
      )}
      {activity.duration && (
        <span class="inline-flex items-center gap-1 text-xs px-2.5 py-1 rounded-full bg-gray-100 text-gray-500 font-medium">
          <Icon name="lucide:clock" class="w-3 h-3" />
          {activity.duration}
        </span>
      )}
    </div>

    <span class="inline-flex items-center gap-1.5 mt-4 text-sm text-aventure font-semibold group-hover:gap-2.5 transition-all">
      {t('common.discover')}
      <Icon name="lucide:arrow-right" class="w-4 h-4" />
    </span>
  </div>
</a>
