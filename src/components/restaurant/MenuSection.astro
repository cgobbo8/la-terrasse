---
/**
 * MenuSection — A single category within the menu (e.g. Burgers, Salads).
 * Airy editorial design with generous spacing and elegant typography.
 */
interface Dish {
  name: string;
  description?: string;
  price?: string;
  tags?: string[];
}

interface Props {
  title: string;
  dishes: Dish[];
  accent: string;
  hideTitle?: boolean;
}

const { title, dishes, accent, hideTitle = false } = Astro.props;

function formatPrice(raw: string): string {
  const num = parseFloat(raw);
  if (isNaN(num)) return raw;
  return num.toFixed(2).replace('.', ',') + ' \u20AC';
}
---

<div class="menu-category" data-reveal>
  {!hideTitle && (
    <div class="flex items-center gap-4 mb-6">
      <span class="h-px flex-1" style={`background: ${accent}20`}></span>
      <h3
        class="font-heading text-xs sm:text-sm uppercase tracking-[0.2em] font-bold shrink-0"
        style={`color: ${accent}`}
      >
        {title}
      </h3>
      <span class="h-px flex-1" style={`background: ${accent}20`}></span>
    </div>
  )}

  <ul class="space-y-5">
    {dishes.map((dish) => (
      <li>
        <div class="flex items-baseline gap-2">
          <span class="font-heading text-base lg:text-lg font-semibold text-gray-800 shrink-0">
            {dish.name}
          </span>
          {dish.tags && dish.tags.length > 0 && (
            <span class="inline-flex gap-1 shrink-0">
              {dish.tags.map((tag) => (
                <span
                  class="text-[0.65rem] font-semibold px-2 py-0.5 rounded-full"
                  style={`background-color: ${accent}12; color: ${accent}`}
                >
                  {tag}
                </span>
              ))}
            </span>
          )}
          {dish.price && dish.price.trim() !== '' && (
            <>
              <span class="flex-1 border-b border-dotted min-w-[2rem]" style={`border-color: ${accent}25`}></span>
              <span
                class="font-heading font-bold text-base shrink-0"
                style={`color: ${accent}; font-variant-numeric: tabular-nums`}
              >
                {formatPrice(dish.price)}
              </span>
            </>
          )}
        </div>
        {dish.description && (
          <p class="text-sm text-gray-500 mt-1 leading-relaxed max-w-xl">{dish.description}</p>
        )}
      </li>
    ))}
  </ul>
</div>

<style>
  .menu-category + .menu-category {
    margin-top: 2.5rem;
  }
</style>
