---
/**
 * GroupFormulaCard — A single group dining formula card
 * Brun terre accent, designed for the persona "Karine" (group organizer)
 */
interface Props {
  name: string;
  pricePerPerson: number;
  minGroupSize: number;
  inclusions: string[];
  recommended?: boolean;
  perPersonLabel: string;
  minSizeLabel: string;
  recommendedLabel: string;
  accent: string;
}

const {
  name,
  pricePerPerson,
  minGroupSize,
  inclusions,
  recommended = false,
  perPersonLabel,
  minSizeLabel,
  recommendedLabel,
  accent,
} = Astro.props;
---

<div
  class:list={[
    'relative bg-white rounded-lg p-6 lg:p-8 border',
    recommended ? 'ring-2 shadow-lg' : 'shadow-sm',
  ]}
  style={recommended ? `border-color: ${accent}; ring-color: ${accent}` : `border-color: ${accent}20`}
>
  {/* Accent top border */}
  <div class="absolute top-0 left-0 right-0 h-1 rounded-t-lg" style={`background-color: ${accent}`} />

  {/* Recommended badge */}
  {recommended && (
    <span
      class="inline-block text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4"
      style={`background-color: ${accent}`}
    >
      {recommendedLabel}
    </span>
  )}

  {/* Formula name */}
  <h3 class="font-heading text-xl lg:text-2xl font-bold mb-4" style={`color: ${accent}`}>
    {name}
  </h3>

  {/* Price */}
  <div class="mb-4">
    <span class="text-2xl lg:text-[28px] font-bold" style={`color: ${accent}`}>
      {pricePerPerson}
    </span>
    <span class="text-base text-gray-500 ml-1">{perPersonLabel}</span>
  </div>

  {/* Minimum group size */}
  <div class="flex items-center gap-2 text-gray-500 text-sm mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
    </svg>
    <span>{minSizeLabel.replace('{min}', String(minGroupSize))}</span>
  </div>

  {/* Inclusions list */}
  <ul class="space-y-2">
    {inclusions.map((item) => (
      <li class="flex items-start gap-2 text-gray-600 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style={`color: ${accent}`}>
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
