---
/**
 * GroupFormulaCard — A single group dining formula card
 * Brun terre accent, designed for the persona "Karine" (group organizer)
 * DA: rounded-2xl, shadow-sm — matches ProducerCard / ActivityCard
 */
interface Props {
  name: string;
  pricePerPerson: number;
  minGroupSize: number;
  inclusions: string[];
  recommended?: boolean;
  perPersonLabel: string;
  minSizeLabel: string;
  recommendedLabel: string;
  accent: string;
}

const {
  name,
  pricePerPerson,
  minGroupSize,
  inclusions,
  recommended = false,
  perPersonLabel,
  minSizeLabel,
  recommendedLabel,
  accent,
} = Astro.props;
---

<article
  class:list={[
    'rounded-2xl overflow-hidden bg-white shadow-sm',
    recommended && 'ring-2',
  ]}
  style={recommended ? `--tw-ring-color: ${accent}` : undefined}
>
  {/* Header band with formula name */}
  <div class="px-6 pt-6 lg:px-8 lg:pt-8">
    {recommended && (
      <span
        class="inline-block text-[11px] font-medium uppercase tracking-wider px-2 py-0.5 rounded-full mb-3"
        style={`background-color: ${accent}15; color: ${accent}`}
      >
        {recommendedLabel}
      </span>
    )}

    <h3 class="font-heading text-xl font-bold" style={`color: ${accent}`}>
      {name}
    </h3>

    {/* Price */}
    <p class="mt-2">
      <span class="text-2xl lg:text-3xl font-bold" style={`color: ${accent}; font-variant-numeric: tabular-nums`}>
        {pricePerPerson}
      </span>
      <span class="text-sm text-gray-500 ml-1">{perPersonLabel}</span>
    </p>

    {/* Minimum group size */}
    <p class="text-sm text-gray-400 mt-1">
      {minSizeLabel.replace('{min}', String(minGroupSize))}
    </p>
  </div>

  {/* Separator */}
  <div class="mx-6 lg:mx-8 my-4 border-t" style={`border-color: ${accent}15`} />

  {/* Inclusions list */}
  <div class="px-6 pb-6 lg:px-8 lg:pb-8">
    <ul class="space-y-2">
      {inclusions.map((item) => (
        <li class="flex items-start gap-2 text-sm text-gray-600">
          <span class="mt-0.5 shrink-0 text-xs" style={`color: ${accent}99`}>&#x2022;</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</article>
