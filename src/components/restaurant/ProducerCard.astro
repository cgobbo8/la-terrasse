---
/**
 * ProducerCard — displays a local producer portrait with story.
 * Brun terre pole identity. Pure Astro, zero JS.
 * Entire card is clickable if website is provided (stretched link pattern).
 */
import { Icon } from 'astro-icon/components';

interface Props {
  name: string;
  photo: string;
  product: string;
  story: string;
  location?: string;
  distance?: number | null;
  website?: string | null;
}

const { name, photo, product, story, location, distance, website } = Astro.props;

import { poleConfigs } from '@/lib/pole-config';
const accent = poleConfigs.restaurant.accent;

const Tag = website ? 'a' : 'div';
const linkProps = website ? { href: website, target: '_blank', rel: 'noopener' } : {};
---

<article class="group relative rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover">
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={photo}
      alt={`${name}, ${product}`}
      loading="lazy"
      class="w-full h-full object-cover card-zoom-img"
    />
    {location && (
      <span
        class="absolute top-3 right-3 inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1.5 rounded-full"
        style={`background-color: ${accent}; color: white`}
      >
        <Icon name="lucide:map-pin" class="w-3.5 h-3.5 shrink-0" />
        {location}
        {distance != null && (
          <span class="font-bold opacity-80">&middot; {distance}&nbsp;km</span>
        )}
      </span>
    )}
  </div>
  <div class="p-6 lg:p-7">
    <h3 class="font-heading text-xl font-bold text-gray-900">
      {name}
    </h3>
    <p class="text-xs font-bold uppercase tracking-[0.15em] mt-1.5" style={`color: ${accent}90`}>
      {product}
    </p>
    <p class="text-sm text-gray-600 mt-3 leading-relaxed">
      {story}
    </p>
    {website && (
      <p class="inline-flex items-center gap-1.5 text-sm font-medium mt-4 transition-colors group-hover:underline underline-offset-4" style={`color: ${accent}`}>
        Découvrir
        <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
      </p>
    )}
  </div>
  {/* Stretched link — covers entire card */}
  {website && (
    <a
      href={website}
      target="_blank"
      rel="noopener"
      class="absolute inset-0 z-10"
      aria-label={`Visiter le site de ${name}`}
    ><span class="sr-only">Visiter le site de {name}</span></a>
  )}
</article>
