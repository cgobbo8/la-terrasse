---
/**
 * ProducerCard — displays a local producer portrait with story.
 * Brun terre pole identity. Pure Astro, zero JS.
 * Design: image-forward card matching site DA (rounded-2xl, shadow-sm).
 */
interface Props {
  name: string;
  photo: string;
  product: string;
  story: string;
}

const { name, photo, product, story } = Astro.props;
---

<article class="group rounded-2xl overflow-hidden bg-white border border-gray-200/60 card-hover">
  <div class="aspect-[4/3] overflow-hidden">
    <img
      src={photo}
      alt={`${name}, ${product}`}
      loading="lazy"
      class="w-full h-full object-cover card-zoom-img"
    />
  </div>
  <div class="p-6 lg:p-7">
    <h3 class="font-heading text-xl font-bold" style="color: #2D2B1B">
      {name}
    </h3>
    <p class="text-xs font-bold uppercase tracking-[0.15em] mt-1.5" style="color: #2D2B1B80">
      {product}
    </p>
    <p class="text-sm text-gray-600 mt-3 leading-relaxed">
      {story}
    </p>
  </div>
</article>
