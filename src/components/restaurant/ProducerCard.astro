---
/**
 * ProducerCard — displays a local producer portrait with story.
 * Brun terre pole identity. Pure Astro, zero JS.
 */
interface Props {
  name: string;
  photo: string;
  product: string;
  story: string;
}

const { name, photo, product, story } = Astro.props;
---

<article class="flex flex-col items-center text-center md:flex-row md:items-start md:text-left gap-6 md:gap-8 p-6 md:p-8 rounded-2xl bg-white border-l-4" style="border-color: #2D2B1B">
  <img
    src={photo}
    alt={`${name}, ${product}`}
    loading="lazy"
    class="w-[120px] h-[120px] md:w-[160px] md:h-[160px] rounded-full object-cover flex-none"
  />
  <div class="flex-1 min-w-0">
    <h3 class="font-heading text-xl font-bold" style="color: #2D2B1B">
      {name}
    </h3>
    <p class="text-sm font-medium uppercase tracking-wider mt-1" style="color: #2D2B1B">
      {product}
    </p>
    <p class="text-base text-gray-600 mt-3 leading-[1.7]">
      {story}
    </p>
  </div>
</article>
