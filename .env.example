# ============================================
# Keystatic — GitHub storage mode (production)
# ============================================
# GitHub App or PAT with repo write access
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
# Repository coordinates (e.g., "my-org" / "base-de-loisir-saint-ferreol")
KEYSTATIC_GITHUB_REPO_OWNER=
KEYSTATIC_GITHUB_REPO_NAME=base-de-loisir-saint-ferreol

# ============================================
# Site
# ============================================
SITE_URL=https://laterrasse-saintferreol.fr

# ============================================
# Deployment webhook (optional — used by webhook handler)
# ============================================
DEPLOY_WEBHOOK_SECRET=

# ============================================
# Analytics (optional)
# ============================================
PLAUSIBLE_DOMAIN=laterrasse-saintferreol.fr
